@using Models
@using Models.ViewModels
@model Models.ViewModels.StudentDashboardVM

@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Dashboard";

    // ─── Language ───────────────────────────────────────────
    var currentLang = Context.Session.GetString("Language") ?? "en";
    var isArabic    = currentLang == "ar";
    var direction   = isArabic ? "rtl" : "ltr";

    // ─── Student name + greeting ─────────────────────────────
    var studentName  = isArabic
        ? (Model.StudentNameAr?.Trim().Length > 0 ? Model.StudentNameAr : Model.StudentNameEn ?? "")
        : (Model.StudentNameEn?.Trim().Length > 0 ? Model.StudentNameEn : Model.StudentNameAr ?? "");
    var firstName = studentName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? studentName;

    var hour     = DateTime.Now.Hour;
    var greeting = isArabic
        ? (hour < 12 ? "صباح الخير" : "مساء الخير")
        : (hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening");

    // ─── Overall progress (average across courses) ────────────
    var avgProgress = (Model.Courses != null && Model.Courses.Any())
        ? (int)Math.Round(Model.Courses.Average(c => (double)c.ProgressPercent))
        : 0;

    // ─── Next upcoming lecture ────────────────────────────────
    var now         = DateTime.Now;
    var nextLecture = Model.UpcomingLectures?
        .Where(l => l.Date >= now || (l.EndDate.HasValue && l.EndDate.Value > now))
        .OrderBy(l => l.Date)
        .FirstOrDefault();

    var isLive         = Model.CanJoinNow && Model.NextStudentAppointmentId != null;
    var alertCssClass  = isLive ? "live" : (nextLecture != null ? "" : "no-lecture");
    var alertTitle     = isLive
        ? (isArabic ? "محاضرة مباشرة الآن!" : "Live lecture now!")
        : (nextLecture != null
            ? (isArabic ? nextLecture.SubjectName : nextLecture.SubjectName)
            : (isArabic ? "لا توجد محاضرات قادمة" : "No upcoming lectures"));
    var alertCourse    = isLive
        ? (isArabic ? "انضم الآن قبل فوات الأوان" : "Join before it's too late")
        : (nextLecture != null
            ? (isArabic ? "المُدرس: " + nextLecture.InstructorName : "Instructor: " + nextLecture.InstructorName)
            : "");

    // ISO string for JS countdown — marked as Egypt time (UTC+2) so browser converts correctly
    var nextJoinAtStr = nextLecture != null
        ? nextLecture.Date.ToString("yyyy-MM-ddTHH:mm:ss") + "+02:00"
        : (isLive && Model.NextJoinAt.HasValue ? Model.NextJoinAt.Value.ToString("yyyy-MM-ddTHH:mm:ss") + "+02:00" : "");

    // ─── Today's sessions ─────────────────────────────────────
    var todaySessions = Model.UpcomingLectures?
        .Where(l => l.Date.Date == now.Date || (l.EndDate.HasValue && l.EndDate.Value.Date == now.Date))
        .OrderBy(l => l.Date)
        .ToList() ?? new List<UpcomingLectureVM>();

    // ─── Grades chart data (JSON) ────────────────────────────
    var gradesChartJson = System.Text.Json.JsonSerializer.Serialize(
        (Model.CourseGrades ?? new List<CourseGradeVM>()).Select(cg => new {
            name  = isArabic
                ? (cg.CourseNameAr?.Trim().Length > 0 ? cg.CourseNameAr : cg.CourseNameEn)
                : (cg.CourseNameEn?.Trim().Length > 0 ? cg.CourseNameEn : cg.CourseNameAr),
            grade = cg.AverageGrade
        }).ToList()
    );

    // ─── Session dates for calendar (JSON) ───────────────────
    var sessionDatesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.UpcomingLectures?
            .Select(l => l.Date.ToString("yyyy-MM-dd"))
            .Distinct()
            .ToList() ?? new List<string>()
    );
}

<div class="sd-wrap" dir="@direction">
    <div class="sd-grid">

        <!-- ══════════════════════════════════════════════════
             WELCOME BANNER (grid child — first on mobile)
             ══════════════════════════════════════════════════ -->
        <div class="sd-welcome">
            <div class="sd-welcome-greeting">
                👋 <span id="sdGreeting">@greeting</span>
                <span class="sd-welcome-name"> @firstName</span>
            </div>
            <div class="sd-welcome-sub">
                @if (isArabic)
                {
                    <text>أنت <b>أنجزت @avgProgress%</b> من هدفك للأسبوع دا!</text>
                }
                else
                {
                    <text>You've <b>achieved @avgProgress%</b> of your weekly goal!</text>
                }
            </div>
        </div>


        <!-- ══════════════════════════════════════════════════
             CENTER COLUMN
             ══════════════════════════════════════════════════ -->
        <main class="sd-center">

            <!-- My Courses -->
            <div class="sd-courses-card">
                <div class="sd-courses-head">
                    <div class="sd-courses-head-title">
                        <i class="fa-solid fa-book-open"></i>
                        @(isArabic ? "المواد الدراسية" : "My Courses")
                    </div>
                    <a class="sd-courses-head-link"
                       asp-area="StudentArea"
                       asp-controller="Course"
                       asp-action="Index">
                        @(isArabic ? "عرض الكل" : "View all")
                        <i class="fa-solid fa-arrow-@(isArabic ? "left" : "right") ms-1"></i>
                    </a>
                </div>

                <div class="sd-courses-body">
                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        var colorIndex = 0;
                        foreach (var c in Model.Courses.Take(4))
                        {
                            var title = isArabic
                                ? (c.CourseTitleAr?.Trim().Length > 0 ? c.CourseTitleAr : c.CourseTitleEn)
                                : (c.CourseTitleEn?.Trim().Length > 0 ? c.CourseTitleEn : c.CourseTitleAr);
                            var pct = c.ProgressPercent;
                            var ciClass = "ci-" + (colorIndex % 4);
                            // SVG stroke-dasharray: circumference=100 (r≈15.915)
                            var dash  = pct;
                            var space = 100 - pct;

                            <div class="sd-ci">
                                <div class="sd-ci-info">
                                    <div class="sd-ci-name" title="@title">@title</div>
                                    <div class="sd-ci-count">
                                        @if (c.GoalCount > 0)
                                        {
                                            if (isArabic)
                                            {
                                                <text>حضرت <strong>@c.AttendedCount</strong> من <strong>@c.GoalCount</strong> محاضرة</text>
                                            }
                                            else
                                            {
                                                <text>Attended <strong>@c.AttendedCount</strong> of <strong>@c.GoalCount</strong> lectures</text>
                                            }
                                        }
                                        else
                                        {
                                            <text>@(isArabic ? "لا توجد محاضرات بعد" : "No lectures yet")</text>
                                        }
                                    </div>
                                    <a class="sd-ci-btn"
                                       asp-area="StudentArea"
                                       asp-controller="Course"
                                       asp-action="Details"
                                       asp-route-id="@c.CourseId">
                                        <i class="fa-solid fa-play fa-xs"></i>
                                        @(isArabic ? "واصل التعلم" : "Continue")
                                    </a>
                                </div>

                                <!-- Circular SVG progress -->
                                <svg class="sd-circ" viewBox="0 0 36 36" aria-hidden="true">
                                    <circle class="sd-circ-bg"
                                            cx="18" cy="18" r="15.9155" />
                                    <circle class="sd-circ-bar @ciClass"
                                            cx="18" cy="18" r="15.9155"
                                            stroke-dasharray="@dash @space"
                                            stroke-dashoffset="0" />
                                    <text class="sd-circ-pct" x="18" y="18">@pct%</text>
                                </svg>
                            </div>
                            colorIndex++;
                        }
                    }
                    else
                    {
                        <div class="sd-empty">
                            <i class="fa-solid fa-book-open me-2"></i>
                            @(isArabic ? "لا توجد كورسات مسجل بها بعد." : "No courses enrolled yet.")
                        </div>
                    }
                </div>
            </div>

            @if (Model.CourseGrades != null && Model.CourseGrades.Any())
            {
                <!-- Grades Bar Chart -->
                <div class="sd-chart-card">
                    <div class="sd-chart-head">
                        <i class="fa-solid fa-chart-column"></i>
                        @(isArabic ? "متوسط الدرجات لكل مادة" : "Average Grade per Course")
                    </div>
                    <div class="sd-chart-body">
                        <canvas id="gradesChart"></canvas>
                    </div>
                </div>
            }

        </main>


        <!-- ══════════════════════════════════════════════════
             LECTURE ALERT (grid child — controls mobile order)
             ══════════════════════════════════════════════════ -->
        <div id="sdLectureAlert" class="sd-lecture-alert @alertCssClass">
            <div class="sd-la-top">
                <div class="sd-la-icon">
                    <i class="fa-solid @(isLive ? "fa-circle-play" : "fa-chalkboard-user")"></i>
                </div>
                <div id="sdLaTimer" class="sd-la-timer">
                    @(isLive ? (isArabic ? "مباشر" : "LIVE") : "--:--:--")
                </div>
            </div>

            <div class="sd-la-title" id="sdLaTitle">@alertTitle</div>
            <div class="sd-la-course" id="sdLaCourse">@alertCourse</div>

            <div class="sd-la-actions">
                @if (isLive && Model.NextStudentAppointmentId != null)
                {
                    <a class="sd-la-btn sd-la-btn-join"
                       asp-area="StudentArea"
                       asp-controller="Appointments"
                       asp-action="Join"
                       asp-route-studentAppointmentId="@Model.NextStudentAppointmentId">
                        <i class="fa-solid fa-play"></i>
                        @(isArabic ? "انضم الآن" : "Join Now")
                    </a>
                }
                else if (nextLecture != null)
                {
                    <span class="sd-la-status" id="sdLaStatusText">
                        <i class="fa-regular fa-clock"></i>
                        @(isArabic ? "لم تبدأ بعد" : "Not started yet")
                    </span>
                }
                else
                {
                    <span class="sd-la-status">
                        <i class="fa-solid fa-calendar-xmark"></i>
                        @(isArabic ? "لا توجد محاضرات" : "No lectures scheduled")
                    </span>
                }
            </div>
        </div>


        <!-- ══════════════════════════════════════════════════
             LEFT COLUMN
             ══════════════════════════════════════════════════ -->
        <aside class="sd-left">

            <!-- Overall Performance Gauge -->
            <div class="sd-perf-card">
                <div class="sd-perf-title">
                    <i class="fa-solid fa-gauge-high"></i>
                    @(isArabic ? "الأداء العام للطالب" : "Overall Performance")
                </div>

                <div class="sd-gauge-wrap">
                    <div class="sd-gauge-donut" style="--pct: @Model.OverallProgress">
                        <div class="sd-gauge-inner">
                            <span class="sd-gauge-num">@Model.OverallProgress%</span>
                            <span class="sd-gauge-label-inner">@(isArabic ? "تقدم" : "Progress")</span>
                        </div>
                    </div>

                    <div class="sd-gauge-sub">
                        @if (Model.OverallProgress >= 70)
                        {
                            <span>@(isArabic ? "🎉 أداء ممتاز! استمر هكذا" : "🎉 Excellent! Keep it up")</span>
                        }
                        else if (Model.OverallProgress >= 40)
                        {
                            <span>@(isArabic ? "👍 أداء جيد، واصل التعلم" : "👍 Good progress, keep going")</span>
                        }
                        else
                        {
                            <span>@(isArabic ? "💪 استمر في التعلم!" : "💪 Keep learning!")</span>
                        }
                    </div>

                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        <div class="sd-perf-stats">
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.Courses.Count()</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "كورسات" : "Courses")</div>
                            </div>
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.AttendanceRate%</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "معدل الحضور" : "Attendance")</div>
                            </div>
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.UpcomingLectures.Count</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "محاضرات قادمة" : "Upcoming")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </aside>


        <!-- ══════════════════════════════════════════════════
             RIGHT COLUMN
             ══════════════════════════════════════════════════ -->
        <aside class="sd-right">

            <!-- ① Mini Calendar -->
            <div class="sd-cal-card">
                <div class="sd-cal-header">
                    <div class="sd-cal-title" id="sdCalTitle"></div>
                    <div class="sd-cal-nav">
                        <button class="sd-cal-nav-btn" id="sdCalPrev" type="button" title="Previous">
                            <i class="fa-solid fa-chevron-@(isArabic ? "right" : "left")"></i>
                        </button>
                        <button class="sd-cal-nav-btn" id="sdCalNext" type="button" title="Next">
                            <i class="fa-solid fa-chevron-@(isArabic ? "left" : "right")"></i>
                        </button>
                    </div>
                </div>
                <div class="sd-cal-grid" id="sdCalGrid"></div>
            </div>

            <!-- ② Today's Sessions -->
            <div class="sd-sessions-card">
                <div class="sd-sessions-head">
                    <i class="fa-solid fa-calendar-day"></i>
                    @(isArabic ? "الحصص" : "Sessions")
                    @if (todaySessions.Any())
                    {
                        <span id="sdTodayDateLabel" style="margin-@(isArabic ? "right" : "left"):auto; font-size:12px; font-weight:600; color:var(--sd-muted)">
                            @now.ToString(isArabic ? "dd MMMM" : "MMM dd")
                        </span>
                    }
                </div>

                <div class="sd-sessions-body">
                    @if (todaySessions.Any())
                    {
                        foreach (var s in todaySessions)
                        {
                            var sessionLive = now >= s.Date && (!s.EndDate.HasValue || now <= s.EndDate.Value);
                            var sessionClass = sessionLive ? "sd-session live" : "sd-session";

                            <div class="@sessionClass">
                                <div class="sd-session-dot"></div>
                                <div class="sd-session-info">
                                    <div class="sd-session-name" title="@s.SubjectName">@s.SubjectName</div>
                                    <div class="sd-session-meta">@s.InstructorName</div>
                                    <div class="sd-session-time">
                                        <i class="fa-regular fa-clock fa-xs"></i>
                                        <span data-egypt-dt='@s.Date.ToString("yyyy-MM-ddTHH:mm:ss")' data-dt-format="time">@s.Date.ToString("HH:mm")</span>
                                        @if (s.EndDate.HasValue)
                                        {
                                            <text> — <span data-egypt-dt='@s.EndDate.Value.ToString("yyyy-MM-ddTHH:mm:ss")' data-dt-format="time">@s.EndDate.Value.ToString("HH:mm")</span></text>
                                        }
                                    </div>

                                    @if (sessionLive && !string.IsNullOrWhiteSpace(s.ZoomLink))
                                    {
                                        <a class="sd-session-join" href="/StudentArea/Appointments/Join?studentAppointmentId=@s.Id">
                                            <i class="fa-solid fa-play fa-xs"></i>
                                            @(isArabic ? "انضم" : "Join")
                                        </a>
                                    }
                                    else if (!sessionLive)
                                    {
                                        <span class="sd-session-pending">
                                            <i class="fa-regular fa-hourglass fa-xs"></i>
                                            @(isArabic ? "لم تبدأ بعد" : "Not started")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        var nextSessions = Model.UpcomingLectures
                            .Where(l => l.Date > now)
                            .OrderBy(l => l.Date)
                            .Take(3)
                            .ToList();

                        if (nextSessions.Any())
                        {
                            <div style="font-size:12px; color:var(--sd-muted); padding:4px 0 8px; font-weight:600">
                                @(isArabic ? "المحاضرات القادمة" : "Upcoming lectures")
                            </div>

                            foreach (var s in nextSessions)
                            {
                                <div class="sd-session">
                                    <div class="sd-session-dot"></div>
                                    <div class="sd-session-info">
                                        <div class="sd-session-name" title="@s.SubjectName">@s.SubjectName</div>
                                        <div class="sd-session-meta">@s.InstructorName</div>
                                        <div class="sd-session-time">
                                            <i class="fa-regular fa-clock fa-xs"></i>
                                            <span data-egypt-dt='@s.Date.ToString("yyyy-MM-ddTHH:mm:ss")' data-dt-format="datetime-short">@s.Date.ToString("ddd, dd MMM • HH:mm")</span>
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sd-empty">
                                <i class="fa-regular fa-calendar fa-lg mb-2 d-block"></i>
                                @(isArabic ? "لا توجد محاضرات اليوم" : "No sessions today")
                            </div>
                        }
                    }
                </div>
            </div>

        </aside>

    </div>
</div>

@section Scripts {
    <!-- Timezone localization: converts Egypt times (UTC+2) to user's local timezone -->
    <script>
        (function () {
            const _isArabic = '@currentLang' === 'ar';

            function localizeEgyptTimes() {
                document.querySelectorAll('[data-egypt-dt]').forEach(function (el) {
                    var raw = el.getAttribute('data-egypt-dt');
                    var fmt = el.getAttribute('data-dt-format') || 'time';
                    var d = new Date(raw + '+02:00');
                    if (isNaN(d.getTime())) return;
                    try {
                        if (fmt === 'time') {
                            el.textContent = d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
                        } else if (fmt === 'datetime-short') {
                            var datePart = d.toLocaleDateString(undefined, { weekday: 'short', day: '2-digit', month: 'short' });
                            var timePart = d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
                            el.textContent = datePart + ' • ' + timePart;
                        }
                    } catch (e) {}
                });
            }

            function localizeTodayLabel() {
                var el = document.getElementById('sdTodayDateLabel');
                if (!el) return;
                var d = new Date();
                try {
                    el.textContent = d.toLocaleDateString(_isArabic ? 'ar-EG' : undefined, { day: '2-digit', month: 'long' });
                } catch (e) {}
            }

            document.addEventListener('DOMContentLoaded', function () {
                localizeEgyptTimes();
                localizeTodayLabel();
            });
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Lecture Alert: countdown timer + live-switch
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic      = '@currentLang' === 'ar';
            const nextJoinAtStr = '@nextJoinAtStr';
            const nextId        = '@(Model.NextStudentAppointmentId?.ToString() ?? "")';
            const isLive        = @(isLive ? "true" : "false");
            const nextMeetLink  = '@Html.Raw(Model.NextAppointmentMeetingLink)';

            const alertEl      = document.getElementById('sdLectureAlert');
            const timerEl      = document.getElementById('sdLaTimer');
            const actionsEl    = alertEl?.querySelector('.sd-la-actions');

            function pad(n) { return String(n).padStart(2, '0'); }

            function formatCountdown(ms) {
                if (ms <= 0) return isArabic ? 'الآن!' : 'NOW!';
                const totalSec = Math.floor(ms / 1000);
                const h = Math.floor(totalSec / 3600);
                const m = Math.floor((totalSec % 3600) / 60);
                const s = totalSec % 60;
                return `${pad(h)}:${pad(m)}:${pad(s)}`;
            }

            function switchToLive() {
                if (!alertEl) return;
                alertEl.classList.add('live');
                alertEl.classList.remove('urgent');

                if (timerEl) timerEl.textContent = isArabic ? 'مباشر' : 'LIVE';

                if (actionsEl && nextId) {
                    actionsEl.innerHTML = `
                        <a class="sd-la-btn sd-la-btn-join" href="/StudentArea/Appointments/Join?studentAppointmentId=${nextId}">
                            <i class="fa-solid fa-play"></i>
                            ${isArabic ? 'انضم الآن' : 'Join Now'}
                        </a>`;
                }
            }

            // If already live, nothing to count down
            if (isLive) return;

            if (!nextJoinAtStr || !timerEl) return;

            const target = new Date(nextJoinAtStr).getTime();
            if (isNaN(target)) return;

            function tick() {
                const diff = target - Date.now();
                if (diff <= 0) {
                    switchToLive();
                    clearInterval(timer);
                    return;
                }
                timerEl.textContent = formatCountdown(diff);

                // add urgent pulse in last 5 minutes
                if (diff < 5 * 60 * 1000 && alertEl) {
                    alertEl.classList.add('urgent');
                    if (actionsEl) {
                        const statusEl = actionsEl.querySelector('.sd-la-status');
                        if (statusEl) {
                            statusEl.innerHTML = `<i class="fa-solid fa-exclamation-triangle"></i>
                                ${isArabic ? 'لازم تدخل المحاضرة قريب!' : 'Join the lecture soon!'}`;
                        }
                    }
                }
            }

            tick();
            const timer = setInterval(tick, 1000);
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Mini Calendar
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic   = '@currentLang' === 'ar';
            const sessionDates = @Html.Raw(sessionDatesJson);
            const sessionSet   = new Set(sessionDates);

            const monthsEn = ['January','February','March','April','May','June',
                               'July','August','September','October','November','December'];
            const monthsAr = ['يناير','فبراير','مارس','أبريل','مايو','يونيو',
                               'يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
            const dowEn    = ['Su','Mo','Tu','We','Th','Fr','Sa'];
            const dowAr    = ['أح','إث','ثل','أر','خم','جم','سب'];

            let viewYear  = new Date().getFullYear();
            let viewMonth = new Date().getMonth();

            const titleEl = document.getElementById('sdCalTitle');
            const gridEl  = document.getElementById('sdCalGrid');
            const prevBtn = document.getElementById('sdCalPrev');
            const nextBtn = document.getElementById('sdCalNext');

            function isoDate(y, m, d) {
                return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
            }

            function render() {
                if (!titleEl || !gridEl) return;

                const months = isArabic ? monthsAr : monthsEn;
                const dows   = isArabic ? dowAr    : dowEn;

                titleEl.textContent = `${months[viewMonth]} ${viewYear}`;

                const today     = new Date();
                const todayIso  = isoDate(today.getFullYear(), today.getMonth(), today.getDate());
                const firstDay  = new Date(viewYear, viewMonth, 1).getDay();
                const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

                let html = '';

                // Day-of-week headers
                for (const d of dows) {
                    html += `<div class="sd-cal-dow">${d}</div>`;
                }

                // Leading blanks
                for (let i = 0; i < firstDay; i++) {
                    html += `<div class="sd-cal-day other-month"></div>`;
                }

                // Days
                for (let d = 1; d <= daysInMonth; d++) {
                    const iso     = isoDate(viewYear, viewMonth, d);
                    let   classes = 'sd-cal-day';
                    if (iso === todayIso)     classes += ' today';
                    if (sessionSet.has(iso))  classes += ' has-session';
                    html += `<div class="${classes}">${d}</div>`;
                }

                gridEl.innerHTML = html;
            }

            prevBtn?.addEventListener('click', () => {
                viewMonth--;
                if (viewMonth < 0) { viewMonth = 11; viewYear--; }
                render();
            });

            nextBtn?.addEventListener('click', () => {
                viewMonth++;
                if (viewMonth > 11) { viewMonth = 0; viewYear++; }
                render();
            });

            render();
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Greeting update (based on real-time hour in browser)
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic = '@currentLang' === 'ar';
            const h = new Date().getHours();
            const g = isArabic
                ? (h < 12 ? 'صباح الخير' : 'مساء الخير')
                : (h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening');
            const el = document.getElementById('sdGreeting');
            if (el) el.textContent = g;
        })();
    </script>


    @if (Model.CourseGrades != null && Model.CourseGrades.Any())
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.1/chart.umd.min.js"></script>
        <script>
            (function () {
                const isArabic = '@currentLang' === 'ar';
                const raw = @Html.Raw(gradesChartJson);

                const labels = raw.map(d => d.name);
                const values = raw.map(d => d.grade);
                const colors = values.map(v =>
                    v >= 70 ? 'rgba(16,185,129,0.85)'
                    : v >= 40 ? 'rgba(245,158,11,0.85)'
                    : 'rgba(239,68,68,0.85)'
                );

                new Chart(document.getElementById('gradesChart').getContext('2d'), {
                    type: 'bar',
                    data: {
                        labels,
                        datasets: [{
                            label: isArabic ? 'متوسط الدرجة' : 'Avg Grade',
                            data: values,
                            backgroundColor: colors,
                            borderRadius: 8,
                            borderSkipped: false,
                        }]
                    },
                    options: {
                        responsive: true,
                        maintainAspectRatio: false,
                        plugins: {
                            legend: { display: false },
                            tooltip: {
                                rtl: isArabic,
                                callbacks: {
                                    label: ctx => ` ${ctx.raw} / 100`
                                }
                            }
                        },
                        scales: {
                            y: {
                                beginAtZero: true,
                                max: 100,
                                ticks: {
                                    font: { family: 'Cairo', size: 11 },
                                    color: '#64748B',
                                    stepSize: 25,
                                    callback: v => v + '%'
                                },
                                grid: { color: '#F1F5F9' }
                            },
                            x: {
                                ticks: {
                                    font: { family: 'Cairo', weight: '700', size: 12 },
                                    color: '#0F172A',
                                    maxRotation: 0,
                                    callback: function(val) {
                                        const label = this.getLabelForValue(val);
                                        return label.length > 12 ? label.slice(0, 12) + '…' : label;
                                    }
                                },
                                grid: { display: false }
                            }
                        }
                    }
                });
            })();
        </script>
    }

    <script>
        function toggleLastLesson(btn) {
            const row = btn.closest('.sd-last-row');
            const details = row.querySelector('.sd-last-details');
            document.querySelectorAll('.sd-last-row').forEach(r => {
                if (r !== row) { r.classList.remove('active'); const d=r.querySelector('.sd-last-details'); if(d) d.style.maxHeight=null; }
            });
            row.classList.toggle('active');
            if (row.classList.contains('active')) details.style.maxHeight = details.scrollHeight + "px";
            else details.style.maxHeight = null;
        }
    </script>
}
