@using Models
@using Models.ViewModels
@model Models.ViewModels.StudentDashboardVM

@{
    Layout = "_StudentLayout";
    ViewData["Title"] = "Dashboard";

    // ─── Language ───────────────────────────────────────────
    var currentLang = Context.Session.GetString("Language") ?? "en";
    var isArabic    = currentLang == "ar";
    var direction   = isArabic ? "rtl" : "ltr";

    // ─── Student name + greeting ─────────────────────────────
    var studentName  = isArabic
        ? (Model.StudentNameAr?.Trim().Length > 0 ? Model.StudentNameAr : Model.StudentNameEn ?? "")
        : (Model.StudentNameEn?.Trim().Length > 0 ? Model.StudentNameEn : Model.StudentNameAr ?? "");
    var firstName = studentName.Split(' ', StringSplitOptions.RemoveEmptyEntries).FirstOrDefault() ?? studentName;

    var hour     = DateTime.Now.Hour;
    var greeting = isArabic
        ? (hour < 12 ? "صباح الخير" : "مساء الخير")
        : (hour < 12 ? "Good morning" : hour < 17 ? "Good afternoon" : "Good evening");

    // ─── Overall progress (average across courses) ────────────
    var avgProgress = (Model.Courses != null && Model.Courses.Any())
        ? (int)Math.Round(Model.Courses.Average(c => (double)c.ProgressPercent))
        : 0;

    // ─── Next upcoming lecture ────────────────────────────────
    var now         = DateTime.Now;
    var nextLecture = Model.UpcomingLectures?
        .Where(l => l.Date >= now || (l.EndDate.HasValue && l.EndDate.Value > now))
        .OrderBy(l => l.Date)
        .FirstOrDefault();

    var isLive         = Model.CanJoinNow && Model.NextStudentAppointmentId != null;
    var alertCssClass  = isLive ? "live" : (nextLecture != null ? "" : "no-lecture");
    var alertTitle     = isLive
        ? (isArabic ? "محاضرة مباشرة الآن!" : "Live lecture now!")
        : (nextLecture != null
            ? (isArabic ? nextLecture.SubjectName : nextLecture.SubjectName)
            : (isArabic ? "لا توجد محاضرات قادمة" : "No upcoming lectures"));
    var alertCourse    = isLive
        ? (isArabic ? "انضم الآن قبل فوات الأوان" : "Join before it's too late")
        : (nextLecture != null
            ? (isArabic ? "المُدرس: " + nextLecture.InstructorName : "Instructor: " + nextLecture.InstructorName)
            : "");

    // ISO string for JS countdown
    var nextJoinAtStr = nextLecture != null
        ? nextLecture.Date.ToString("O")
        : (isLive && Model.NextJoinAt.HasValue ? Model.NextJoinAt.Value.ToString("O") : "");

    // ─── Today's sessions ─────────────────────────────────────
    var todaySessions = Model.UpcomingLectures?
        .Where(l => l.Date.Date == now.Date || (l.EndDate.HasValue && l.EndDate.Value.Date == now.Date))
        .OrderBy(l => l.Date)
        .ToList() ?? new List<UpcomingLectureVM>();

    // ─── Session dates for calendar (JSON) ───────────────────
    var sessionDatesJson = System.Text.Json.JsonSerializer.Serialize(
        Model.UpcomingLectures?
            .Select(l => l.Date.ToString("yyyy-MM-dd"))
            .Distinct()
            .ToList() ?? new List<string>()
    );
}

<div class="sd-wrap" dir="@direction">
    <div class="sd-grid">

        <!-- ══════════════════════════════════════════════════
             LEFT COLUMN
             ══════════════════════════════════════════════════ -->
        <aside class="sd-left">

            <!-- ① Lecture Alert Badge -->
            <div id="sdLectureAlert" class="sd-lecture-alert @alertCssClass">
                <div class="sd-la-top">
                    <div class="sd-la-icon">
                        <i class="fa-solid @(isLive ? "fa-circle-play" : "fa-chalkboard-user")"></i>
                    </div>
                    <div id="sdLaTimer" class="sd-la-timer">
                        @(isLive ? (isArabic ? "مباشر" : "LIVE") : "--:--:--")
                    </div>
                </div>

                <div class="sd-la-title" id="sdLaTitle">@alertTitle</div>
                <div class="sd-la-course" id="sdLaCourse">@alertCourse</div>

                <div class="sd-la-actions">
                    @if (isLive && Model.NextStudentAppointmentId != null)
                    {
                        <a class="sd-la-btn sd-la-btn-join"
                           asp-area="StudentArea"
                           asp-controller="Lectures"
                           asp-action="Join"
                           asp-route-studentAppointmentId="@Model.NextStudentAppointmentId">
                            <i class="fa-solid fa-play"></i>
                            @(isArabic ? "انضم الآن" : "Join Now")
                        </a>
                    }
                    else if (nextLecture != null)
                    {
                        <span class="sd-la-status" id="sdLaStatusText">
                            <i class="fa-regular fa-clock"></i>
                            @(isArabic ? "لم تبدأ بعد" : "Not started yet")
                        </span>
                    }
                    else
                    {
                        <span class="sd-la-status">
                            <i class="fa-solid fa-calendar-xmark"></i>
                            @(isArabic ? "لا توجد محاضرات" : "No lectures scheduled")
                        </span>
                    }
                </div>
            </div>

            <!-- ② Overall Performance Gauge -->
            <div class="sd-perf-card">
                <div class="sd-perf-title">
                    <i class="fa-solid fa-gauge-high"></i>
                    @(isArabic ? "الأداء العام للطالب" : "Overall Performance")
                </div>

                <div class="sd-gauge-wrap">
                    <div class="sd-gauge-donut" style="--pct: @avgProgress">
                        <div class="sd-gauge-inner">
                            <span class="sd-gauge-num">@avgProgress%</span>
                            <span class="sd-gauge-label-inner">@(isArabic ? "تقدم" : "Progress")</span>
                        </div>
                    </div>

                    <div class="sd-gauge-sub">
                        @if (avgProgress >= 70)
                        {
                            <span>@(isArabic ? "🎉 أداء ممتاز! استمر هكذا" : "🎉 Excellent! Keep it up")</span>
                        }
                        else if (avgProgress >= 40)
                        {
                            <span>@(isArabic ? "👍 أداء جيد، واصل التعلم" : "👍 Good progress, keep going")</span>
                        }
                        else
                        {
                            <span>@(isArabic ? "💪 استمر في التعلم!" : "💪 Keep learning!")</span>
                        }
                    </div>

                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        <div class="sd-perf-stats">
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.Courses.Count()</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "كورسات" : "Courses")</div>
                            </div>
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.Courses.Sum(c => c.AttendedCount)</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "حصص حضرتها" : "Attended")</div>
                            </div>
                            <div class="sd-perf-stat">
                                <div class="sd-perf-stat-num">@Model.UpcomingLectures.Count</div>
                                <div class="sd-perf-stat-label">@(isArabic ? "محاضرات قادمة" : "Upcoming")</div>
                            </div>
                        </div>
                    }
                </div>
            </div>

        </aside>


        <!-- ══════════════════════════════════════════════════
             CENTER COLUMN
             ══════════════════════════════════════════════════ -->
        <main class="sd-center">

            <!-- ① Welcome Banner -->
            <div class="sd-welcome">
                <div class="sd-welcome-greeting">
                    👋 <span id="sdGreeting">@greeting</span>
                    <span class="sd-welcome-name"> @firstName</span>
                </div>
                <div class="sd-welcome-sub">
                    @if (isArabic)
                    {
                        <text>أنت <b>أنجزت @avgProgress%</b> من هدفك للأسبوع دا!</text>
                    }
                    else
                    {
                        <text>You've <b>achieved @avgProgress%</b> of your weekly goal!</text>
                    }
                </div>
            </div>

            <!-- ② My Courses -->
            <div class="sd-courses-card">
                <div class="sd-courses-head">
                    <div class="sd-courses-head-title">
                        <i class="fa-solid fa-book-open"></i>
                        @(isArabic ? "المواد الدراسية" : "My Courses")
                    </div>
                    <a class="sd-courses-head-link"
                       asp-area="StudentArea"
                       asp-controller="Course"
                       asp-action="Index">
                        @(isArabic ? "عرض الكل" : "View all")
                        <i class="fa-solid fa-arrow-@(isArabic ? "left" : "right") ms-1"></i>
                    </a>
                </div>

                <div class="sd-courses-body">
                    @if (Model.Courses != null && Model.Courses.Any())
                    {
                        var colorIndex = 0;
                        foreach (var c in Model.Courses.Take(4))
                        {
                            var title = isArabic
                                ? (c.CourseTitleAr?.Trim().Length > 0 ? c.CourseTitleAr : c.CourseTitleEn)
                                : (c.CourseTitleEn?.Trim().Length > 0 ? c.CourseTitleEn : c.CourseTitleAr);
                            var pct = c.ProgressPercent;
                            var ciClass = "ci-" + (colorIndex % 4);
                            // SVG stroke-dasharray: circumference=100 (r≈15.915)
                            var dash  = pct;
                            var space = 100 - pct;

                            <div class="sd-ci">
                                <div class="sd-ci-info">
                                    <div class="sd-ci-name" title="@title">@title</div>
                                    <div class="sd-ci-count">
                                        @(isArabic ? "عدد الحصص" : "Sessions")
                                        @c.AttendedCount / @c.GoalCount
                                    </div>
                                    <a class="sd-ci-btn"
                                       asp-area="StudentArea"
                                       asp-controller="Course"
                                       asp-action="Details"
                                       asp-route-id="@c.CourseId">
                                        <i class="fa-solid fa-play fa-xs"></i>
                                        @(isArabic ? "واصل التعلم" : "Continue")
                                    </a>
                                </div>

                                <!-- Circular SVG progress -->
                                <svg class="sd-circ" viewBox="0 0 36 36" aria-hidden="true">
                                    <circle class="sd-circ-bg"
                                            cx="18" cy="18" r="15.9155" />
                                    <circle class="sd-circ-bar @ciClass"
                                            cx="18" cy="18" r="15.9155"
                                            stroke-dasharray="@dash @space"
                                            stroke-dashoffset="0" />
                                    <text class="sd-circ-pct" x="18" y="18">@pct%</text>
                                </svg>
                            </div>
                            colorIndex++;
                        }
                    }
                    else
                    {
                        <div class="sd-empty">
                            <i class="fa-solid fa-book-open me-2"></i>
                            @(isArabic ? "لا توجد كورسات مسجل بها بعد." : "No courses enrolled yet.")
                        </div>
                    }
                </div>
            </div>

        </main>


        <!-- ══════════════════════════════════════════════════
             RIGHT COLUMN
             ══════════════════════════════════════════════════ -->
        <aside class="sd-right">

            <!-- ① Mini Calendar -->
            <div class="sd-cal-card">
                <div class="sd-cal-header">
                    <div class="sd-cal-title" id="sdCalTitle"></div>
                    <div class="sd-cal-nav">
                        <button class="sd-cal-nav-btn" id="sdCalPrev" type="button" title="Previous">
                            <i class="fa-solid fa-chevron-@(isArabic ? "right" : "left")"></i>
                        </button>
                        <button class="sd-cal-nav-btn" id="sdCalNext" type="button" title="Next">
                            <i class="fa-solid fa-chevron-@(isArabic ? "left" : "right")"></i>
                        </button>
                    </div>
                </div>
                <div class="sd-cal-grid" id="sdCalGrid"></div>
            </div>

            <!-- ② Today's Sessions -->
            <div class="sd-sessions-card">
                <div class="sd-sessions-head">
                    <i class="fa-solid fa-calendar-day"></i>
                    @(isArabic ? "الحصص" : "Sessions")
                    @if (todaySessions.Any())
                    {
                        <span style="margin-@(isArabic ? "right" : "left"):auto; font-size:12px; font-weight:600; color:var(--sd-muted)">
                            @now.ToString(isArabic ? "dd MMMM" : "MMM dd")
                        </span>
                    }
                </div>

                <div class="sd-sessions-body">
                    @if (todaySessions.Any())
                    {
                        foreach (var s in todaySessions)
                        {
                            var sessionLive = now >= s.Date && (!s.EndDate.HasValue || now <= s.EndDate.Value);
                            var sessionClass = sessionLive ? "sd-session live" : "sd-session";
                            var timeStr = s.Date.ToString(isArabic ? "HH:mm" : "hh:mm tt");
                            var endStr  = s.EndDate.HasValue
                                ? s.EndDate.Value.ToString(isArabic ? "HH:mm" : "hh:mm tt")
                                : "";

                            <div class="@sessionClass">
                                <div class="sd-session-dot"></div>
                                <div class="sd-session-info">
                                    <div class="sd-session-name" title="@s.SubjectName">@s.SubjectName</div>
                                    <div class="sd-session-meta">@s.InstructorName</div>
                                    <div class="sd-session-time">
                                        <i class="fa-regular fa-clock fa-xs"></i>
                                        @timeStr @(endStr.Length > 0 ? "— " + endStr : "")
                                    </div>

                                    @if (sessionLive && !string.IsNullOrWhiteSpace(s.ZoomLink))
                                    {
                                        <a class="sd-session-join" href="@s.ZoomLink" target="_blank" rel="noopener">
                                            <i class="fa-solid fa-play fa-xs"></i>
                                            @(isArabic ? "انضم" : "Join")
                                        </a>
                                    }
                                    else if (!sessionLive)
                                    {
                                        <span class="sd-session-pending">
                                            <i class="fa-regular fa-hourglass fa-xs"></i>
                                            @(isArabic ? "لم تبدأ بعد" : "Not started")
                                        </span>
                                    }
                                </div>
                            </div>
                        }
                    }
                    else
                    {
                        var nextSessions = Model.UpcomingLectures
                            .Where(l => l.Date > now)
                            .OrderBy(l => l.Date)
                            .Take(3)
                            .ToList();

                        if (nextSessions.Any())
                        {
                            <div style="font-size:12px; color:var(--sd-muted); padding:4px 0 8px; font-weight:600">
                                @(isArabic ? "المحاضرات القادمة" : "Upcoming lectures")
                            </div>

                            foreach (var s in nextSessions)
                            {
                                var timeStr = s.Date.ToString(isArabic ? "ddd, dd MMM • HH:mm" : "ddd, dd MMM • hh:mm tt");

                                <div class="sd-session">
                                    <div class="sd-session-dot"></div>
                                    <div class="sd-session-info">
                                        <div class="sd-session-name" title="@s.SubjectName">@s.SubjectName</div>
                                        <div class="sd-session-meta">@s.InstructorName</div>
                                        <div class="sd-session-time">
                                            <i class="fa-regular fa-clock fa-xs"></i>
                                            @timeStr
                                        </div>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="sd-empty">
                                <i class="fa-regular fa-calendar fa-lg mb-2 d-block"></i>
                                @(isArabic ? "لا توجد محاضرات اليوم" : "No sessions today")
                            </div>
                        }
                    }
                </div>
            </div>

        </aside>

    </div>
</div>


@* ──────────────────────────────────────────────────────────
   Chat Widget (kept as-is)
   ────────────────────────────────────────────────────────── *@
<button id="chatFab" class="chat-fab" type="button" aria-label="Open chat">
    <span class="chat-fab-icon" aria-hidden="true">
        <i class="fa-regular fa-comment-dots"></i>
    </span>
    <span id="chatFabBadge" class="chat-fab-badge hidden">0</span>
</button>

<div id="chatWidget" class="chat-widget" aria-hidden="true">
    @Html.AntiForgeryToken()
    <div class="chat-header">
        <div class="header-left">
            <button id="chatBackBtn" class="chat-btn-icon hidden" type="button" aria-label="Back">←</button>
            <div class="title" id="chatHeaderTitle">
                <div id="chatHeaderName">@(isArabic ? "المحادثات" : "Chats")</div>
                <div id="chatHeaderStatus" class="chat-status"></div>
            </div>
        </div>
        <div class="actions">
            <button class="chat-btn-icon" id="chatCloseBtn" type="button" aria-label="Close">✕</button>
        </div>
    </div>

    <div class="chat-screen" id="screenList">
        <div class="chat-search">
            <input id="chatSearch" type="text" placeholder="@(isArabic ? "ابحث عن المُدرسين..." : "Search instructors...")" autocomplete="off" />
        </div>
        <div class="chat-items" id="chatItems"></div>
    </div>

    <div class="chat-screen hidden" id="screenThread">
        <div class="messages" id="messagesBox"></div>
        <div class="composer">
            <div id="attachChip" class="attach-chip hidden">
                <span id="attachName"></span>
                <button type="button" id="attachClearBtn" class="attach-clear" aria-label="Remove file">×</button>
            </div>
            <input id="chatInput" type="text" placeholder="@(isArabic ? "اكتب رسالة..." : "Type a message...")" autocomplete="off" />
            <input type="file" id="chatFile" hidden />
            <button type="button" id="attachBtn" class="chat-attach-btn" title="Attach file">
                <i class="fa-solid fa-paperclip"></i>
            </button>
            <button id="sendBtn" type="button" aria-label="Send">➤</button>
        </div>
    </div>
</div>


<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/6.0.1/signalr.min.js"></script>

    <input type="hidden" id="currentUserId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />

    <!-- ══════════════════════════════════════════════════════
         Lecture Alert: countdown timer + live-switch
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic     = '@currentLang' === 'ar';
            const nextJoinAtStr= '@nextJoinAtStr';
            const nextId       = '@(Model.NextStudentAppointmentId?.ToString() ?? "")';
            const isLive       = @(isLive ? "true" : "false");

            const alertEl      = document.getElementById('sdLectureAlert');
            const timerEl      = document.getElementById('sdLaTimer');
            const actionsEl    = alertEl?.querySelector('.sd-la-actions');

            function pad(n) { return String(n).padStart(2, '0'); }

            function formatCountdown(ms) {
                if (ms <= 0) return isArabic ? 'الآن!' : 'NOW!';
                const totalSec = Math.floor(ms / 1000);
                const h = Math.floor(totalSec / 3600);
                const m = Math.floor((totalSec % 3600) / 60);
                const s = totalSec % 60;
                return `${pad(h)}:${pad(m)}:${pad(s)}`;
            }

            function switchToLive() {
                if (!alertEl) return;
                alertEl.classList.add('live');
                alertEl.classList.remove('urgent');

                if (timerEl) timerEl.textContent = isArabic ? 'مباشر' : 'LIVE';

                if (actionsEl && nextId) {
                    actionsEl.innerHTML = `
                        <a class="sd-la-btn sd-la-btn-join"
                           href="/StudentArea/Lectures/Join?studentAppointmentId=${nextId}">
                            <i class="fa-solid fa-play"></i>
                            ${isArabic ? 'انضم الآن' : 'Join Now'}
                        </a>`;
                }
            }

            // If already live, nothing to count down
            if (isLive) return;

            if (!nextJoinAtStr || !timerEl) return;

            const target = new Date(nextJoinAtStr).getTime();

            function tick() {
                const diff = target - Date.now();
                if (diff <= 0) {
                    switchToLive();
                    clearInterval(timer);
                    return;
                }
                timerEl.textContent = formatCountdown(diff);

                // add urgent pulse in last 5 minutes
                if (diff < 5 * 60 * 1000 && alertEl) {
                    alertEl.classList.add('urgent');
                    if (actionsEl) {
                        const statusEl = actionsEl.querySelector('.sd-la-status');
                        if (statusEl) {
                            statusEl.innerHTML = `<i class="fa-solid fa-exclamation-triangle"></i>
                                ${isArabic ? 'لازم تدخل المحاضرة قريب!' : 'Join the lecture soon!'}`;
                        }
                    }
                }
            }

            tick();
            const timer = setInterval(tick, 1000);
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Mini Calendar
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic   = '@currentLang' === 'ar';
            const sessionDates = @Html.Raw(sessionDatesJson);
            const sessionSet   = new Set(sessionDates);

            const monthsEn = ['January','February','March','April','May','June',
                               'July','August','September','October','November','December'];
            const monthsAr = ['يناير','فبراير','مارس','أبريل','مايو','يونيو',
                               'يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
            const dowEn    = ['Su','Mo','Tu','We','Th','Fr','Sa'];
            const dowAr    = ['أح','إث','ثل','أر','خم','جم','سب'];

            let viewYear  = new Date().getFullYear();
            let viewMonth = new Date().getMonth();

            const titleEl = document.getElementById('sdCalTitle');
            const gridEl  = document.getElementById('sdCalGrid');
            const prevBtn = document.getElementById('sdCalPrev');
            const nextBtn = document.getElementById('sdCalNext');

            function isoDate(y, m, d) {
                return `${y}-${String(m+1).padStart(2,'0')}-${String(d).padStart(2,'0')}`;
            }

            function render() {
                if (!titleEl || !gridEl) return;

                const months = isArabic ? monthsAr : monthsEn;
                const dows   = isArabic ? dowAr    : dowEn;

                titleEl.textContent = `${months[viewMonth]} ${viewYear}`;

                const today     = new Date();
                const todayIso  = isoDate(today.getFullYear(), today.getMonth(), today.getDate());
                const firstDay  = new Date(viewYear, viewMonth, 1).getDay();
                const daysInMonth = new Date(viewYear, viewMonth + 1, 0).getDate();

                let html = '';

                // Day-of-week headers
                for (const d of dows) {
                    html += `<div class="sd-cal-dow">${d}</div>`;
                }

                // Leading blanks
                for (let i = 0; i < firstDay; i++) {
                    html += `<div class="sd-cal-day other-month"></div>`;
                }

                // Days
                for (let d = 1; d <= daysInMonth; d++) {
                    const iso     = isoDate(viewYear, viewMonth, d);
                    let   classes = 'sd-cal-day';
                    if (iso === todayIso)     classes += ' today';
                    if (sessionSet.has(iso))  classes += ' has-session';
                    html += `<div class="${classes}">${d}</div>`;
                }

                gridEl.innerHTML = html;
            }

            prevBtn?.addEventListener('click', () => {
                viewMonth--;
                if (viewMonth < 0) { viewMonth = 11; viewYear--; }
                render();
            });

            nextBtn?.addEventListener('click', () => {
                viewMonth++;
                if (viewMonth > 11) { viewMonth = 0; viewYear++; }
                render();
            });

            render();
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Greeting update (based on real-time hour in browser)
         ══════════════════════════════════════════════════════ -->
    <script>
        (function () {
            const isArabic = '@currentLang' === 'ar';
            const h = new Date().getHours();
            const g = isArabic
                ? (h < 12 ? 'صباح الخير' : 'مساء الخير')
                : (h < 12 ? 'Good morning' : h < 17 ? 'Good afternoon' : 'Good evening');
            const el = document.getElementById('sdGreeting');
            if (el) el.textContent = g;
        })();
    </script>

    <!-- ══════════════════════════════════════════════════════
         Chat Widget (full implementation kept intact)
         ══════════════════════════════════════════════════════ -->
    <script>
        const API = {
            conversations: '/StudentArea/Home/GetMyConversations',
            history:       '/StudentArea/Home/GetChatHistory',
            save:          '/StudentArea/Home/SaveMessage',
            saveWithFile:  '/StudentArea/Home/SendMessageWithFile',
            markRead:      '/StudentArea/Home/MarkAsRead',
            download:      '/StudentArea/Home/DownloadAttachment'
        };

        const chatFab         = document.getElementById('chatFab');
        const chatFabBadge    = document.getElementById('chatFabBadge');
        const chatWidget      = document.getElementById('chatWidget');
        const chatCloseBtn    = document.getElementById('chatCloseBtn');
        const chatBackBtn     = document.getElementById('chatBackBtn');
        const chatHeaderTitle = document.getElementById('chatHeaderTitle');
        const screenList      = document.getElementById('screenList');
        const screenThread    = document.getElementById('screenThread');
        const chatSearch      = document.getElementById('chatSearch');
        const chatItemsBox    = document.getElementById('chatItems');
        const messagesBox     = document.getElementById('messagesBox');
        const chatInput       = document.getElementById('chatInput');
        const sendBtn         = document.getElementById('sendBtn');
        const attachBtn       = document.getElementById('attachBtn');
        const chatFile        = document.getElementById('chatFile');
        const attachName      = document.getElementById('attachName');
        const attachChip      = document.getElementById('attachChip');
        const attachClearBtn  = document.getElementById('attachClearBtn');
        const currentUserId   = document.getElementById('currentUserId')?.value;
        const headerNameEl    = document.getElementById('chatHeaderName');
        const headerStatusEl  = document.getElementById('chatHeaderStatus');

        function getAntiForgeryToken() {
            const el = chatWidget?.querySelector('input[name="__RequestVerificationToken"]')
                || document.querySelector('input[name="__RequestVerificationToken"]');
            return el?.value || '';
        }

        function addCsrfHeader(headersObj) {
            const token = getAntiForgeryToken();
            if (token) headersObj['RequestVerificationToken'] = token;
            return headersObj;
        }

        const readCache = new Set();
        const state = {
            isOpen: false, currentInstructorId: null, currentInstructorName: '',
            conversationId: null, conversationsCache: [],
            take: 10, hasMore: true, oldestId: null, isLoadingOlder: false
        };

        let audioReady = false, audioCtx = null;
        function initAudio() {
            if (audioReady) return;
            try { audioCtx = new (window.AudioContext || window.webkitAudioContext)(); audioReady = true; } catch {}
        }

        function setFabUnread(count) {
            const n = Math.max(0, parseInt(count || 0));
            if (!chatFabBadge) return;
            if (n === 0) { chatFabBadge.classList.add('hidden'); chatFab.classList.remove('pulse'); chatFabBadge.textContent = '0'; }
            else { chatFabBadge.classList.remove('hidden'); chatFabBadge.textContent = (n > 99) ? '99+' : String(n); chatFab.classList.add('pulse'); }
        }

        function calcTotalUnread() { return (state.conversationsCache || []).reduce((s, c) => s + (c.unread || 0), 0); }
        function syncFabUnreadFromList() { setFabUnread(calcTotalUnread()); }

        function escapeHtml(str) {
            return (str ?? '').replaceAll('&','&amp;').replaceAll('<','&lt;').replaceAll('>','&gt;').replaceAll('"','&quot;').replaceAll("'","&#039;");
        }

        function toTime(sentAt) {
            if (!sentAt) return '';
            const d = new Date(sentAt);
            if (Number.isNaN(d.getTime())) return '';
            return d.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
        }

        function initials(name) {
            const s = (name ?? '').trim();
            if (!s) return 'IN';
            const parts = s.split(/\s+/).filter(Boolean);
            const first = parts[0]?.[0] ?? 'I';
            const second = (parts.length > 1 ? parts[1]?.[0] : parts[0]?.[1]) ?? 'N';
            return (first + second).toUpperCase();
        }

        function isImageContentType(ct) { return typeof ct === 'string' && ct.toLowerCase().startsWith('image/'); }
        function buildDownloadUrl(messageId) { return `${API.download}?messageId=${encodeURIComponent(messageId)}`; }

        function ensureImageModal() {
            if (document.getElementById('imgPreviewModal')) return;
            const modal = document.createElement('div');
            modal.id = 'imgPreviewModal';
            modal.className = 'img-preview-modal hidden';
            modal.innerHTML = `<div class="img-preview-backdrop"></div><div class="img-preview-content" role="dialog" aria-modal="true"><button type="button" class="img-preview-close" aria-label="Close">✕</button><img class="img-preview-img" alt="Preview" /></div>`;
            document.body.appendChild(modal);
            const close = () => modal.classList.add('hidden');
            modal.querySelector('.img-preview-backdrop')?.addEventListener('click', close);
            modal.querySelector('.img-preview-close')?.addEventListener('click', close);
            document.addEventListener('keydown', (e) => { if (e.key === 'Escape' && !modal.classList.contains('hidden')) close(); });
        }

        function openImagePreview(src) {
            if (!src) return;
            ensureImageModal();
            const modal = document.getElementById('imgPreviewModal');
            modal.querySelector('.img-preview-img').src = src;
            modal.classList.remove('hidden');
        }

        const presenceMap = new Map();
        function setHeaderStatus(isOnline) {
            if (!headerStatusEl) return;
            headerStatusEl.textContent = isOnline ? "● Online" : "● Offline";
            headerStatusEl.classList.toggle("online", !!isOnline);
            headerStatusEl.classList.toggle("offline", !isOnline);
        }

        function getSelectedFile() { return (chatFile && chatFile.files && chatFile.files.length > 0) ? chatFile.files[0] : null; }
        function showAttachmentName(name) {
            if (attachChip) { attachChip.classList.remove("hidden"); const n = attachChip.querySelector("#attachName"); if (n) n.textContent = name; return; }
            if (attachName) { attachName.style.display = "inline-block"; attachName.textContent = name; }
        }
        function hideAttachmentName() {
            if (attachChip) { attachChip.classList.add("hidden"); const n = attachChip.querySelector("#attachName"); if (n) n.textContent = ""; }
            if (attachName) { attachName.style.display = "none"; attachName.textContent = ""; }
        }
        function clearAttachmentUI() { if (chatFile) chatFile.value = ""; hideAttachmentName(); }

        if (attachBtn && chatFile) {
            attachBtn.addEventListener("click", () => chatFile.click());
            chatFile.addEventListener("change", () => { const f = getSelectedFile(); if (f) showAttachmentName(f.name); else clearAttachmentUI(); });
        }
        attachClearBtn?.addEventListener("click", () => clearAttachmentUI());

        function showWidget() {
            state.isOpen = true; chatWidget.classList.add('open'); chatWidget.setAttribute('aria-hidden','false'); chatFab.style.display = 'none';
            showListScreen(); loadMyConversations();
        }
        function hideWidget() {
            state.isOpen = false; chatWidget.classList.remove('open'); chatWidget.setAttribute('aria-hidden','true'); chatFab.style.display = 'block';
            state.currentInstructorId = null; state.currentInstructorName = ''; state.conversationId = null;
            state.hasMore = true; state.oldestId = null; state.isLoadingOlder = false;
            messagesBox.innerHTML = ''; chatInput.value = ''; chatSearch.value = ''; clearAttachmentUI();
            if (headerNameEl) headerNameEl.textContent = "Chats";
            if (headerStatusEl) headerStatusEl.textContent = "";
        }
        function showListScreen() {
            screenThread.classList.add('hidden'); screenList.classList.remove('hidden'); chatBackBtn.classList.add('hidden');
            if (headerNameEl) headerNameEl.textContent = "Chats";
            if (headerStatusEl) headerStatusEl.textContent = "";
            state.currentInstructorId = null; state.currentInstructorName = ''; state.conversationId = null;
            state.hasMore = true; state.oldestId = null; state.isLoadingOlder = false;
            messagesBox.innerHTML = ''; clearAttachmentUI();
        }
        function showThreadScreen(n) {
            screenList.classList.add('hidden'); screenThread.classList.remove('hidden'); chatBackBtn.classList.remove('hidden');
            if (headerNameEl) headerNameEl.textContent = n || "Chat";
        }
        function setActiveItem(id) { document.querySelectorAll('.chat-item').forEach(x => x.classList.toggle('active', x.dataset.instructorId === id)); }
        function findItem(id) { return document.querySelector(`.chat-item[data-instructor-id="${CSS.escape(id)}"]`); }
        function removeBadge(id) { const b = findItem(id)?.querySelector('.badge'); if (b) b.remove(); }
        function incrementBadge(id) {
            const item = findItem(id);
            if (!item) return;
            let b = item.querySelector('.badge');
            if (!b) { b = document.createElement('div'); b.className = 'badge'; b.textContent = '1'; item.appendChild(b); }
            else b.textContent = (parseInt(b.textContent||'0')+1).toString();
        }

        async function loadMyConversations() {
            try {
                const res = await fetch(API.conversations);
                const data = await res.json();
                state.conversationsCache = Array.isArray(data) ? data : [];
                renderConversations(state.conversationsCache);
                syncFabUnreadFromList();
            } catch(e) { console.error(e); chatItemsBox.innerHTML = `<div class="empty">Failed to load chats</div>`; }
        }

        function renderConversations(list) {
            chatItemsBox.innerHTML = '';
            if (!list || list.length === 0) { chatItemsBox.innerHTML = `<div class="empty">No chats yet</div>`; return; }
            for (const c of list) {
                const idStr  = String(c.instructorId ?? '');
                const name   = c.instructorName ?? 'Instructor';
                const unread = c.unread ?? 0;
                const avatarHtml = c.photoUrl
                    ? `<img class="avatar-img" src="${escapeHtml(c.photoUrl)}" alt="${escapeHtml(name)}" />`
                    : `<div class="avatar-text">${escapeHtml(initials(name))}</div>`;
                const unreadHtml = unread > 0 ? `<div class="badge">${unread}</div>` : '';
                const isOnline = presenceMap.get(idStr) === true;
                chatItemsBox.insertAdjacentHTML('beforeend', `
                    <div class="chat-item" data-instructor-id="${escapeHtml(idStr)}" data-instructor-name="${escapeHtml(name)}">
                        <div class="avatar">${avatarHtml}<span class="presence-dot ${isOnline?'online':'offline'}" data-presence-id="${escapeHtml(idStr)}"></span></div>
                        <div class="meta"><div class="name">${escapeHtml(name)}</div><div class="preview">${escapeHtml(c.lastMessage??'')}</div></div>
                        ${unreadHtml}
                    </div>`);
            }
            if (state.currentInstructorId) setActiveItem(state.currentInstructorId);
        }

        chatItemsBox.addEventListener('click', (e) => {
            const item = e.target.closest('.chat-item');
            if (!item) return;
            openChat(item.dataset.instructorId, item.dataset.instructorName);
        });

        chatSearch.addEventListener('input', () => {
            const q = (chatSearch.value??'').trim().toLowerCase();
            renderConversations(!q ? state.conversationsCache : state.conversationsCache.filter(x=>(x.instructorName??'').toLowerCase().includes(q)));
            if (state.currentInstructorId) setActiveItem(state.currentInstructorId);
        });

        async function openChat(instructorId, instructorName) {
            state.currentInstructorId = instructorId; state.currentInstructorName = instructorName;
            setActiveItem(instructorId); showThreadScreen(instructorName); clearAttachmentUI();
            await loadChatHistoryFirstPage();
            await markAsRead(instructorId); scheduleMarkAsReadHub(); removeBadge(instructorId);
            await loadMyConversations(); messagesBox.scrollTop = messagesBox.scrollHeight;
            try {
                if (headerNameEl) headerNameEl.textContent = instructorName || "Chat";
                const cached = presenceMap.get(String(state.currentInstructorId));
                if (cached !== undefined) { setHeaderStatus(cached); return; }
                const isOnline = await studentConnection.invoke("IsUserOnline", state.currentInstructorId);
                presenceMap.set(String(state.currentInstructorId), !!isOnline); setHeaderStatus(!!isOnline);
            } catch(e) { console.error("IsUserOnline:", e); }
        }

        async function markAsRead(id) {
            try { await fetch(API.markRead, { method:'POST', headers: addCsrfHeader({'Content-Type':'application/x-www-form-urlencoded; charset=UTF-8'}), body: new URLSearchParams({instructorId:id}) }); } catch(e) { console.error(e); }
        }

        async function loadChatHistoryFirstPage() {
            messagesBox.innerHTML = ''; state.hasMore = true; state.oldestId = null; state.isLoadingOlder = false;
            await loadOlderMessages();
        }

        async function loadOlderMessages() {
            if (!state.currentInstructorId || !state.hasMore || state.isLoadingOlder) return;
            state.isLoadingOlder = true;
            const prevH = messagesBox.scrollHeight, prevT = messagesBox.scrollTop;
            const url = `${API.history}?instructorId=${encodeURIComponent(state.currentInstructorId)}&take=${state.take}${state.oldestId?`&beforeId=${state.oldestId}`:''}`;
            try {
                const res = await fetch(url); const data = await res.json();
                const list = data.messages??[]; state.conversationId = data.conversationId??null; state.hasMore = data.hasMore===true;
                if (!list.length) { state.isLoadingOlder = false; return; }
                const frag = document.createDocumentFragment();
                for (const m of list) frag.appendChild(messageNode(m));
                messagesBox.prepend(frag); state.oldestId = list[0].id??list[0].Id;
                messagesBox.scrollTop = (messagesBox.scrollHeight - prevH) + prevT;
            } catch(e) { console.error(e); } finally { state.isLoadingOlder = false; }
        }

        messagesBox.addEventListener('scroll', () => {
            if (messagesBox.scrollTop <= 10) loadOlderMessages();
            if (messagesBox.scrollTop + messagesBox.clientHeight >= messagesBox.scrollHeight - 6) scheduleMarkAsReadHub();
        });

        function ticksHtml(isMine, isRead) {
            if (!isMine) return '';
            return `<span class="${isRead?'ticks read':'ticks'}" title="${isRead?'Read':'Sent'}">✓✓</span>`;
        }

        function readAttachmentFromMessage(m) {
            const a = m.attachment??m.Attachment??null;
            return {
                storedName:    m.attachmentStoredName??m.AttachmentStoredName??a?.storedName??a?.StoredName??null,
                originalName:  m.attachmentOriginalName??m.AttachmentOriginalName??a?.name??a?.Name??null,
                contentType:   m.attachmentContentType??m.AttachmentContentType??a?.type??a?.Type??null,
                size:          m.attachmentSize??m.AttachmentSize??a?.size??a?.Size??null,
                attachmentUrl: m.attachmentUrl??m.AttachmentUrl??null,
                previewUrl:    m.previewUrl??null
            };
        }

        function messageNode(m) {
            const id = (m.id??m.Id??''); const senderId = (m.senderId??m.SenderId??'');
            const content = (m.content??m.Content??''); const sentAt = (m.sentAt??m.SentAt);
            const isRead = (m.isRead??m.IsRead)===true; const alreadyRead = isRead||readCache.has(String(id||''));
            const isMine = currentUserId && senderId === currentUserId;
            const att = readAttachmentFromMessage(m);
            let attachmentHtml = '';
            if (att.attachmentUrl) {
                if (isImageContentType(att.contentType)) attachmentHtml = `<div class="att"><img class="att-img js-preview-img" src="${escapeHtml(att.attachmentUrl)}" data-full-src="${escapeHtml(att.attachmentUrl)}" alt="${escapeHtml(att.originalName||'image')}" /></div>`;
                else attachmentHtml = `<div class="att"><a class="att-file" href="${escapeHtml(att.attachmentUrl)}" target="_blank" rel="noopener">📎 ${escapeHtml(att.originalName||'file')}</a></div>`;
            } else if (att.previewUrl && isImageContentType(att.contentType)) {
                attachmentHtml = `<div class="att"><img class="att-img js-preview-img" src="${escapeHtml(att.previewUrl)}" data-full-src="${escapeHtml(att.previewUrl)}" alt="${escapeHtml(att.originalName||'image')}" /></div>`;
            } else if (id && (att.storedName||att.originalName)) {
                const dl = buildDownloadUrl(id);
                if (isImageContentType(att.contentType)) attachmentHtml = `<div class="att"><img class="att-img js-preview-img" src="${escapeHtml(dl)}" data-full-src="${escapeHtml(dl)}" alt="${escapeHtml(att.originalName||'image')}" /></div>`;
                else attachmentHtml = `<div class="att"><a class="att-file" href="${escapeHtml(dl)}" target="_blank" rel="noopener">📎 ${escapeHtml(att.originalName||'file')}</a></div>`;
            }
            const wrapper = document.createElement('div');
            wrapper.className = `msg-row ${isMine?'mine':''}`;
            wrapper.dataset.messageId = String(id||'');
            const textHtml = content ? `<div class="att-text">${escapeHtml(content)}</div>` : '';
            wrapper.innerHTML = `<div class="bubble">${textHtml}${attachmentHtml}<span class="time">${escapeHtml(toTime(sentAt))} ${ticksHtml(isMine,alreadyRead)}</span></div>`;
            return wrapper;
        }

        function renderMessage(m) {
            const id = (m.id??m.Id??null);
            if (id) { const ex = messagesBox.querySelector(`.msg-row[data-message-id="${CSS.escape(String(id))}"]`); if (ex) return ex; }
            const node = messageNode(m); messagesBox.appendChild(node); return node;
        }

        function markMessagesReadInUI(messageIds) {
            if (!Array.isArray(messageIds)||!messageIds.length) return;
            messageIds.forEach(id => {
                readCache.add(String(id));
                const tick = messagesBox.querySelector(`.msg-row[data-message-id="${CSS.escape(String(id))}"] .ticks`);
                if (tick) { tick.classList.add("read"); tick.title = "Read"; }
            });
        }

        messagesBox.addEventListener('click', (e) => {
            const img = e.target.closest('img.js-preview-img');
            if (!img) return;
            openImagePreview(img.getAttribute('data-full-src')||img.src);
        });

        function patchOptimisticToReal(el, payload) {
            if (!el||!payload) return;
            const realId = payload.id??payload.Id;
            if (!realId) return;
            el.dataset.messageId = String(realId);
            const attUrl = payload.attachmentUrl??payload.AttachmentUrl??null;
            const ct = payload.attachmentContentType??payload.AttachmentContentType??'';
            if (!attUrl) return;
            const img = el.querySelector('img.att-img'), a = el.querySelector('a.att-file');
            if (isImageContentType(ct)) { if (img) { img.src=attUrl; img.setAttribute('data-full-src',attUrl); } }
            else { if (a) a.href=attUrl; }
        }

        async function sendMessageFromUI() {
            const text = (chatInput.value||'').trim(); const file = getSelectedFile();
            if (!state.currentInstructorId||(!text&&!file)) return;
            const nowIso = new Date().toISOString(); const tempId = `tmp-${Date.now()}`;
            let previewUrl=null, fileType=null, fileName=null;
            if (file) { fileType=file.type||''; fileName=file.name||'file'; if(isImageContentType(fileType)) previewUrl=URL.createObjectURL(file); }
            const optimisticNode = renderMessage({ id:tempId, senderId:currentUserId, receiverId:state.currentInstructorId, content:text, sentAt:nowIso, isRead:false, attachment:file?{name:fileName,type:fileType,size:file.size}:null, previewUrl });
            messagesBox.scrollTop = messagesBox.scrollHeight; chatInput.value = ''; clearAttachmentUI();
            const item = findItem(state.currentInstructorId);
            if (item) { const p = item.querySelector('.preview'); if (p) p.textContent = text||(file?`📎 ${fileName}`:''); }
            try {
                if (file) {
                    const fd = new FormData(); fd.append("ReceiverId",state.currentInstructorId); fd.append("Content",text); fd.append("File",file);
                    const res = await fetch(API.saveWithFile,{method:'POST',headers:addCsrfHeader({}),body:fd});
                    if (!res.ok) { console.error("SendMessageWithFile failed:", await res.text()); return; }
                    const payload = await res.json(); patchOptimisticToReal(optimisticNode,payload);
                    if (previewUrl) URL.revokeObjectURL(previewUrl);
                    return;
                }
                const res = await fetch(API.save,{method:'POST',headers:addCsrfHeader({'Content-Type':'application/x-www-form-urlencoded; charset=UTF-8'}),body:new URLSearchParams({receiverId:state.currentInstructorId,content:text})});
                const data = await res.json();
                if (!data||data.success!==true) { console.log('SaveMessage failed:',data); return; }
                const realId = data.id??data.Id??data.messageId??data.savedMessageId??data.data?.id??data.data?.Id??data.message?.id??data.message?.Id;
                if (realId&&optimisticNode) optimisticNode.dataset.messageId = String(realId);
                await sendRealtimeToInstructor(state.currentInstructorId, text);
            } catch(e) { console.error(e); }
        }

        sendBtn.addEventListener('click', sendMessageFromUI);
        chatInput.addEventListener('keydown', (e) => { if (e.key==='Enter') sendMessageFromUI(); });
        chatFab.addEventListener('click', () => { initAudio(); showWidget(); });
        chatCloseBtn.addEventListener('click', hideWidget);
        chatBackBtn.addEventListener('click', showListScreen);

        const studentConnection = new signalR.HubConnectionBuilder()
            .withUrl("/chatHub",{transport:signalR.HttpTransportType.LongPolling,skipNegotiation:false})
            .withAutomaticReconnect().build();

        studentConnection.on("PresenceChanged", (userId, isOnline) => {
            const id = String(userId); presenceMap.set(id, !!isOnline);
            if (state.currentInstructorId && String(state.currentInstructorId)===id) setHeaderStatus(!!isOnline);
            const dot = document.querySelector(`.presence-dot[data-presence-id="${CSS.escape(id)}"]`);
            if (dot) { dot.classList.toggle("online",!!isOnline); dot.classList.toggle("offline",!isOnline); }
        });

        studentConnection.onreconnected(async () => {
            if (!state.currentInstructorId) return;
            try { const ok = await studentConnection.invoke("IsUserOnline",state.currentInstructorId); presenceMap.set(String(state.currentInstructorId),!!ok); setHeaderStatus(!!ok); } catch(e) { console.error(e); }
        });

        studentConnection.start().then(()=>console.log("SignalR Connected!")).catch(e=>console.error(e.toString()));

        let readDebounceTimer = null;
        function scheduleMarkAsReadHub() {
            clearTimeout(readDebounceTimer);
            readDebounceTimer = setTimeout(() => {
                if (!state.isOpen||!state.conversationId||!state.currentInstructorId) return;
                studentConnection.invoke("MarkAsRead",state.conversationId,state.currentInstructorId).catch(e=>console.error(e));
            }, 200);
        }

        studentConnection.on("ReceiveMessage", async (arg1, arg2, arg3) => {
            if (arg1 && typeof arg1==='object') {
                const p = arg1;
                const senderId   = String(p.senderId??p.SenderId??'');
                const receiverId = String(p.receiverId??p.ReceiverId??'');
                const messageId  = (p.id??p.Id??null);
                const sameOpenChat = state.isOpen && state.currentInstructorId && (senderId===String(state.currentInstructorId)||senderId===String(currentUserId));
                if (sameOpenChat) {
                    if (messageId) { const ex=messagesBox.querySelector(`.msg-row[data-message-id="${CSS.escape(String(messageId))}"]`); if(ex) return; }
                    renderMessage(p); messagesBox.scrollTop=messagesBox.scrollHeight; scheduleMarkAsReadHub();
                    if (senderId===String(state.currentInstructorId)) { await markAsRead(senderId); removeBadge(senderId); }
                    await loadMyConversations(); return;
                }
                const otherId = senderId===String(currentUserId)?receiverId:senderId;
                const item = findItem(otherId);
                if (item) {
                    const pEl = item.querySelector('.preview');
                    const pText = (p.content??p.Content??'').trim()||(p.attachmentOriginalName??p.AttachmentOriginalName?`📎 ${(p.attachmentOriginalName??p.AttachmentOriginalName)}`:'');
                    if (pEl) pEl.textContent = pText;
                    if (senderId!==String(currentUserId)) { incrementBadge(otherId); syncFabUnreadFromList(); }
                }
                await loadMyConversations(); return;
            }
            // old signature
            const senderId=arg1, message=arg2, timestamp=arg3;
            const sameOpenChat = state.isOpen&&state.currentInstructorId&&senderId===state.currentInstructorId;
            if (sameOpenChat) {
                renderMessage({senderId,receiverId:currentUserId,content:message,sentAt:timestamp});
                messagesBox.scrollTop=messagesBox.scrollHeight; scheduleMarkAsReadHub();
                await markAsRead(senderId); removeBadge(senderId); await loadMyConversations(); return;
            }
            const item = findItem(senderId);
            if (item) { const p=item.querySelector('.preview'); if(p) p.textContent=message; incrementBadge(senderId); syncFabUnreadFromList(); }
            await loadMyConversations();
        });

        studentConnection.on("MessagesRead", (payload) => {
            if (!payload||!state.isOpen||!state.conversationId||String(payload.conversationId)!==String(state.conversationId)) return;
            markMessagesReadInUI(payload.messageIds);
        });

        studentConnection.on("UpdateConversationList", () => { loadMyConversations(); });

        async function sendRealtimeToInstructor(id, msg) {
            try { await studentConnection.invoke("SendMessage",id,msg); } catch(e) { console.error(e); }
        }
    </script>

    <script>
        function toggleLastLesson(btn) {
            const row = btn.closest('.sd-last-row');
            const details = row.querySelector('.sd-last-details');
            document.querySelectorAll('.sd-last-row').forEach(r => {
                if (r !== row) { r.classList.remove('active'); const d=r.querySelector('.sd-last-details'); if(d) d.style.maxHeight=null; }
            });
            row.classList.toggle('active');
            if (row.classList.contains('active')) details.style.maxHeight = details.scrollHeight + "px";
            else details.style.maxHeight = null;
        }
    </script>
}

@section Styles {
    <link rel="stylesheet" href="~/css/ChatMessage.css" asp-append-version="true" />
}
