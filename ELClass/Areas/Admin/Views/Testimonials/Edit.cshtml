@model Models.Testimonial

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "تعديل شهادة" : "Edit Testimonial";
    var dir = Model.Language == "en" ? "ltr" : "rtl";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
        <i class="ti ti-edit me-2"></i>
        @(isAr ? "تعديل الشهادة" : "Edit Testimonial")
    </h4>
    <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
       class="btn btn-outline-secondary btn-sm">
        <i class="ti ti-arrow-left me-1"></i> @(isAr ? "رجوع" : "Back")
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body" style="direction:@dir">
                <form asp-action="Edit" method="post" enctype="multipart/form-data">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="Language" value="@Model.Language" />
                    <input type="hidden" name="CountryCode" value="@Model.CountryCode" />
                    <input type="hidden" name="ImageFileName" value="@Model.ImageFileName" />

                    <div class="row g-3">
                        <div class="col-12">
                            <label class="form-label fw-semibold">
                                @(isAr ? "الاسم" : "Name")
                                <span class="text-danger">*</span>
                            </label>
                            <input name="Name" class="form-control" value="@Model.Name" required />
                        </div>
                        <div class="col-12">
                            <label class="form-label fw-semibold">
                                @(isAr ? "الاقتباس / رأي العميل" : "Quote / Review")
                                <span class="text-danger">*</span>
                            </label>
                            <textarea name="Quote" class="form-control" rows="4" required>@Model.Quote</textarea>
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@(isAr ? "الترتيب" : "Sort Order")</label>
                            <input type="number" name="SortOrder" class="form-control" value="@Model.SortOrder" min="0" />
                            <small class="text-muted">@(isAr ? "الأصغر يظهر أولاً" : "Lower numbers appear first")</small>
                        </div>
                        <div class="col-md-6 d-flex align-items-center">
                            <div class="form-check mt-3">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive"
                                       @(Model.IsActive ? "checked" : "") />
                                <label class="form-check-label fw-semibold" for="isActive">
                                    @(isAr ? "نشط (ظاهر في الصفحة)" : "Active (visible on page)")
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i>
                            @(isAr ? "حفظ التغييرات" : "Save Changes")
                        </button>
                        <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
                           class="btn btn-outline-secondary">
                            @(isAr ? "إلغاء" : "Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <div class="card border-0 bg-light">
            <div class="card-body">
                <h6 class="fw-semibold mb-3">
                    <i class="ti ti-eye me-1 text-primary"></i>
                    @(isAr ? "معاينة" : "Preview")
                </h6>
                <div style="background:#fff;border-radius:12px;padding:16px;box-shadow:0 2px 8px rgba(0,0,0,.08);" dir="@dir">
                    <div style="color:#f59e0b;font-size:14px;margin-bottom:8px;">★★★★★</div>
                    <p style="font-size:13px;color:#444;margin-bottom:12px;font-style:italic;">
                        "@(Model.Quote ?? (isAr ? "نص الاقتباس..." : "Quote text..."))"
                    </p>
                    <div style="display:flex;align-items:center;gap:10px;">
                        <div style="width:36px;height:36px;border-radius:50%;background:linear-gradient(135deg,#1E5FD8,#2DA84F);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:14px;flex-shrink:0;">
                            @(Model.Name?.Length > 0 ? Model.Name[0].ToString().ToUpper() : "?")
                        </div>
                        <div style="font-size:13px;font-weight:600;">@(Model.Name ?? (isAr ? "الاسم" : "Name"))</div>
                    </div>
                </div>
                <ul class="list-unstyled mt-3 small text-muted">
                    <li class="mb-1"><i class="ti ti-check text-success me-1"></i> @(isAr ? "الاسم والاقتباس يظهران" : "Name and quote are shown")</li>
                    <li class="mb-1"><i class="ti ti-x text-muted me-1"></i> @(isAr ? "الصورة غير مستخدمة (دائرة ملونة تلقائياً)" : "Photo not used (auto-colored circle)")</li>
                    <li><i class="ti ti-x text-muted me-1"></i> @(isAr ? "التقييم غير مستخدم (دائماً 5 نجوم)" : "Rating not used (always 5 stars)")</li>
                </ul>
            </div>
        </div>
    </div>
</div>
