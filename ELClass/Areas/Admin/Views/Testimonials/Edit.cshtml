@model Models.Testimonial

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "تعديل شهادة" : "Edit Testimonial";
    var dir = Model.Language == "en" ? "ltr" : "rtl";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0"><i class="ti ti-edit me-2"></i> @(isAr ? "تعديل الشهادة" : "Edit Testimonial")</h4>
    <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
       class="btn btn-outline-secondary btn-sm">
        <i class="ti ti-arrow-left me-1"></i> @(isAr ? "رجوع" : "Back")
    </a>
</div>

<div class="card shadow-sm">
    <div class="card-body" style="direction:@dir">
        <form asp-action="Edit" method="post" enctype="multipart/form-data">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" value="@Model.Id" />
            <input type="hidden" name="Language" value="@Model.Language" />
            <input type="hidden" name="CountryCode" value="@Model.CountryCode" />

            @if (!string.IsNullOrEmpty(Model.ImageFileName))
            {
                <div class="mb-3">
                    <label class="form-label fw-semibold">@(isAr ? "الصورة الحالية" : "Current Photo")</label><br />
                    <img src="/uploads/testimonials/@Model.ImageFileName" width="80" height="80"
                         style="object-fit:cover;border-radius:50%;" />
                    <input type="hidden" name="ImageFileName" value="@Model.ImageFileName" />
                </div>
            }

            <div class="row g-3">
                <div class="col-md-6">
                    <label class="form-label fw-semibold">@(isAr ? "اسم العميل" : "Client Name") <span class="text-danger">*</span></label>
                    <input name="Name" class="form-control" value="@Model.Name" required />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">@(isAr ? "التقييم" : "Rating")</label>
                    <input type="number" name="Rating" class="form-control" value="@Model.Rating" min="1" max="5" step="0.1" />
                </div>
                <div class="col-md-3">
                    <label class="form-label fw-semibold">@(isAr ? "الترتيب" : "Sort Order")</label>
                    <input type="number" name="SortOrder" class="form-control" value="@Model.SortOrder" />
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-semibold">@(isAr ? "تغيير الصورة (اختياري)" : "Change Photo (optional)")</label>
                    <input type="file" name="ImageFile" class="form-control" accept="image/*" />
                </div>
                <div class="col-md-6 d-flex align-items-end">
                    <div class="form-check mb-2">
                        <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive"
                               @(Model.IsActive ? "checked" : "") />
                        <label class="form-check-label" for="isActive">@(isAr ? "نشط" : "Active")</label>
                    </div>
                </div>
                <div class="col-12">
                    <label class="form-label fw-semibold">@(isAr ? "الاقتباس / رأي العميل" : "Quote / Review")</label>
                    <textarea name="Quote" class="form-control" rows="4">@Model.Quote</textarea>
                </div>
            </div>

            <div class="mt-4 d-flex gap-2">
                <button type="submit" class="btn btn-primary">
                    <i class="ti ti-device-floppy me-1"></i> @(isAr ? "حفظ التغييرات" : "Save Changes")
                </button>
                <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
                   class="btn btn-outline-secondary">@(isAr ? "إلغاء" : "Cancel")</a>
            </div>
        </form>
    </div>
</div>
