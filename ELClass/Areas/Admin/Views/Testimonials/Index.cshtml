@model List<Models.Testimonial>
@using ELClass.Areas.Admin.Controllers

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "الشهادات والآراء" : "Testimonials";
    var dir = isAr ? "rtl" : "ltr";

    string lang = ViewBag.Lang ?? "en";
    string? country = ViewBag.Country;
    var countries = (IEnumerable<(string Code, string NameAr, string NameEn)>)ViewBag.Countries;
}

<div class="d-flex justify-content-between align-items-center mb-3" style="direction:@dir">
    <h4 class="mb-0">
        <i class="ti ti-stars me-2"></i>
        @(isAr ? "إدارة الشهادات والآراء" : "Manage Testimonials")
    </h4>
    <a asp-action="Create" asp-route-lang="@lang" asp-route-country="@country" class="btn btn-primary btn-sm">
        <i class="ti ti-plus me-1"></i> @(isAr ? "إضافة شهادة" : "Add Testimonial")
    </a>
</div>

<div class="alert alert-info d-flex gap-2 align-items-start mb-3" style="direction:@dir; font-size:.875rem;">
    <i class="ti ti-info-circle fs-5 flex-shrink-0 mt-1"></i>
    <div>
        @if (isAr)
        {
            <span>الحقول المستخدمة في صفحة الهوم: <strong>الاسم</strong> و<strong>الاقتباس</strong>. الصورة الشخصية تُولَّد تلقائياً (دائرة ملونة).</span>
        }
        else
        {
            <span>Fields used on the home page: <strong>Name</strong> and <strong>Quote</strong>. Profile avatars are auto-generated (colored circles).</span>
        }
    </div>
</div>

<!-- Language / Country Tabs -->
<ul class="nav nav-tabs mb-3" style="direction:ltr; flex-wrap:wrap; gap:4px;">
    <li class="nav-item">
        <a class="nav-link @(lang == "en" ? "active" : "")"
           asp-action="Index" asp-route-lang="en" asp-route-country="">
            <i class="fi fi-gb me-1"></i> English
        </a>
    </li>
    @foreach (var c in countries)
    {
        <li class="nav-item">
            <a class="nav-link @(lang == "ar" && country == c.Code ? "active" : "")"
               asp-action="Index" asp-route-lang="ar" asp-route-country="@c.Code">
                <i class="fi fi-@c.Code.ToLower() me-1"></i>
                @(isAr ? c.NameAr : c.NameEn)
            </a>
        </li>
    }
</ul>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="ti ti-mood-empty" style="font-size:3rem;"></i>
                <p class="mt-2">@(isAr ? "لا توجد شهادات بعد. أضف أولاها الآن." : "No testimonials yet. Add the first one.")</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0" style="direction:@dir">
                <thead class="table-light">
                    <tr>
                        <th style="width:48px;"></th>
                        <th>@(isAr ? "الاسم" : "Name")</th>
                        <th>@(isAr ? "الاقتباس" : "Quote")</th>
                        <th style="width:80px;">@(isAr ? "الترتيب" : "Order")</th>
                        <th style="width:80px;">@(isAr ? "نشط" : "Active")</th>
                        <th style="width:100px;"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                <div style="width:38px;height:38px;border-radius:50%;background:linear-gradient(135deg,#1E5FD8,#2DA84F);color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:.9rem;">
                                    @(item.Name?.Length > 0 ? item.Name[0].ToString().ToUpper() : "?")
                                </div>
                            </td>
                            <td class="fw-semibold">@item.Name</td>
                            <td>
                                <span class="text-muted" style="display:block;max-width:400px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;" title="@item.Quote">
                                    @item.Quote
                                </span>
                            </td>
                            <td class="text-center text-muted">@item.SortOrder</td>
                            <td class="text-center">
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success-subtle text-success">@(isAr ? "نشط" : "Active")</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary-subtle text-secondary">@(isAr ? "مخفي" : "Hidden")</span>
                                }
                            </td>
                            <td>
                                <div class="d-flex gap-1 justify-content-end">
                                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary">
                                        <i class="ti ti-edit"></i>
                                    </a>
                                    <form asp-action="Delete" method="post" style="display:inline;"
                                          onsubmit="return confirm('@(isAr ? "هل تريد حذف هذه الشهادة؟" : "Delete this testimonial?")')">
                                        @Html.AntiForgeryToken()
                                        <input type="hidden" name="id" value="@item.Id" />
                                        <button type="submit" class="btn btn-sm btn-outline-danger">
                                            <i class="ti ti-trash"></i>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
