@model List<Models.Testimonial>
@using ELClass.Areas.Admin.Controllers

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "الشهادات والتقييمات" : "Testimonials";
    var dir = isAr ? "rtl" : "ltr";

    string lang = ViewBag.Lang ?? "en";
    string? country = ViewBag.Country;
    var countries = (IEnumerable<(string Code, string NameAr, string NameEn)>)ViewBag.Countries;
}

<div class="d-flex justify-content-between align-items-center mb-4" style="direction:@dir">
    <h4 class="mb-0">
        <i class="ti ti-stars me-2"></i>
        @(isAr ? "إدارة الشهادات والتقييمات" : "Manage Testimonials")
    </h4>
    <a asp-action="Create" asp-route-lang="@lang" asp-route-country="@country" class="btn btn-primary btn-sm">
        <i class="ti ti-plus me-1"></i> @(isAr ? "إضافة شهادة" : "Add Testimonial")
    </a>
</div>

<ul class="nav nav-tabs mb-3" style="direction:ltr; flex-wrap:wrap; gap:4px;">
    <li class="nav-item">
        <a class="nav-link @(lang == "en" ? "active" : "")"
           asp-action="Index" asp-route-lang="en" asp-route-country="">
            <i class="fi fi-gb me-1"></i> English
        </a>
    </li>
    @foreach (var c in countries)
    {
        <li class="nav-item">
            <a class="nav-link @(lang == "ar" && country == c.Code ? "active" : "")"
               asp-action="Index" asp-route-lang="ar" asp-route-country="@c.Code">
                <i class="fi fi-@c.Code.ToLower() me-1"></i>
                @(isAr ? c.NameAr : c.NameEn)
            </a>
        </li>
    }
</ul>

<div class="card shadow-sm">
    <div class="card-body p-0">
        @if (!Model.Any())
        {
            <div class="text-center py-5 text-muted">
                <i class="ti ti-mood-empty" style="font-size:3rem;"></i>
                <p class="mt-2">@(isAr ? "لا توجد شهادات. أضف أولى الشهادات الآن." : "No testimonials yet.")</p>
            </div>
        }
        else
        {
            <table class="table table-hover mb-0" style="direction:@dir">
                <thead class="table-light">
                    <tr>
                        <th>@(isAr ? "الصورة" : "Image")</th>
                        <th>@(isAr ? "الاسم" : "Name")</th>
                        <th>@(isAr ? "الاقتباس" : "Quote")</th>
                        <th>@(isAr ? "التقييم" : "Rating")</th>
                        <th>@(isAr ? "الترتيب" : "Order")</th>
                        <th>@(isAr ? "نشط" : "Active")</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>
                                @if (!string.IsNullOrEmpty(item.ImageFileName))
                                {
                                    <img src="/uploads/testimonials/@item.ImageFileName" width="50" height="50"
                                         style="object-fit:cover; border-radius:50%;" />
                                }
                                else
                                {
                                    <div style="width:50px;height:50px;border-radius:50%;background:#0053B3;color:#fff;display:flex;align-items:center;justify-content:center;font-weight:700;">
                                        @(item.Name?.Substring(0, 1) ?? "?")
                                    </div>
                                }
                            </td>
                            <td>@item.Name</td>
                            <td style="max-width:300px;">
                                <span class="text-truncate d-block" style="max-width:280px;" title="@item.Quote">@item.Quote</span>
                            </td>
                            <td>
                                <span class="badge bg-warning text-dark">⭐ @item.Rating</span>
                            </td>
                            <td>@item.SortOrder</td>
                            <td>
                                @if (item.IsActive)
                                {
                                    <span class="badge bg-success">@(isAr ? "نعم" : "Yes")</span>
                                }
                                else
                                {
                                    <span class="badge bg-secondary">@(isAr ? "لا" : "No")</span>
                                }
                            </td>
                            <td>
                                <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-outline-primary me-1">
                                    <i class="ti ti-edit"></i>
                                </a>
                                <form asp-action="Delete" method="post" style="display:inline;"
                                      onsubmit="return confirm('@(isAr ? "هل تريد حذف هذه الشهادة؟" : "Delete this testimonial?")')">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="id" value="@item.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger">
                                        <i class="ti ti-trash"></i>
                                    </button>
                                </form>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
