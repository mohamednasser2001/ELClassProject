@model List<Models.HomePageContent>
@using ELClass.Areas.Admin.Controllers

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "محتوى الصفحة الرئيسية" : "Homepage Content";

    var activeTab = ViewContext.HttpContext.Request.Query["activeTab"].ToString();
    if (string.IsNullOrEmpty(activeTab)) activeTab = "en";

    var tabs = new List<(string Id, string Label, Models.HomePageContent? Record)>
    {
        ("en", "English", Model.FirstOrDefault(x => x.Language == "en")),
    };
    foreach (var (code, nameAr, nameEn) in HomePageContentController.Countries)
    {
        tabs.Add((code, isAr ? nameAr : nameEn, Model.FirstOrDefault(x => x.Language == "ar" && x.CountryCode == code)));
    }
}

<div class="d-flex justify-content-between align-items-center mb-3" style="direction:@(isAr?"rtl":"ltr")">
    <h4 class="mb-0">
        <i class="ti ti-home me-2"></i>
        @(isAr ? "إدارة محتوى الصفحة الرئيسية" : "Homepage Content Management")
    </h4>
    <a href="/" target="_blank" class="btn btn-outline-primary btn-sm">
        <i class="ti ti-eye me-1"></i> @(isAr ? "معاينة الموقع" : "Preview Site")
    </a>
</div>

<div class="alert alert-info d-flex gap-2 align-items-start mb-3" style="direction:@(isAr?"rtl":"ltr"); font-size:.875rem;">
    <i class="ti ti-info-circle fs-5 flex-shrink-0 mt-1"></i>
    <div>
        @if (isAr)
        {
            <span>هذه الصفحة تتحكم في النصوص القابلة للتعديل فقط. المدرسون والشهادات وخطط الأسعار تُدار من صفحاتها الخاصة.</span>
        }
        else
        {
            <span>This page controls only the editable text fields. Instructors, testimonials, and pricing plans are managed from their own pages.</span>
        }
    </div>
</div>

<!-- Language / Country Tabs -->
<ul class="nav nav-tabs mb-0" id="contentTabs" role="tablist" style="direction:ltr; flex-wrap:wrap; gap:4px;">
    @foreach (var tab in tabs)
    {
        <li class="nav-item" role="presentation">
            <button class="nav-link @(activeTab == tab.Id ? "active" : "")"
                    id="btn-tab-@tab.Id"
                    data-bs-toggle="tab"
                    data-bs-target="#tab-@tab.Id"
                    type="button" role="tab">
                @if (tab.Id == "en")
                {
                    <i class="fi fi-gb me-1"></i>
                }
                else
                {
                    <i class="fi fi-@tab.Id.ToLower() me-1"></i>
                }
                @tab.Label
            </button>
        </li>
    }
</ul>

<div class="tab-content border border-top-0 rounded-bottom p-4 bg-white shadow-sm" id="contentTabsContent">
    @foreach (var tab in tabs)
    {
        var c = tab.Record ?? new Models.HomePageContent { Language = tab.Id == "en" ? "en" : "ar", CountryCode = tab.Id == "en" ? null : tab.Id };
        var dir = tab.Id == "en" ? "ltr" : "rtl";

        <div class="tab-pane fade @(activeTab == tab.Id ? "show active" : "")"
             id="tab-@tab.Id" role="tabpanel">
            <form asp-action="Save" method="post" style="direction:@dir">
                @Html.AntiForgeryToken()
                <input type="hidden" name="Id" value="@c.Id" />
                <input type="hidden" name="Language" value="@c.Language" />
                <input type="hidden" name="CountryCode" value="@c.CountryCode" />
                <input type="hidden" name="tabId" value="@tab.Id" />

                <div class="accordion" id="accordion-@tab.Id">

                    <!-- ── Hero ──────────────────────────── -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#sec-hero-@tab.Id">
                                <i class="ti ti-speakerphone me-2"></i>
                                @(isAr ? "قسم الهيرو (البانر الرئيسي)" : "Hero Section")
                            </button>
                        </h2>
                        <div id="sec-hero-@tab.Id" class="accordion-collapse collapse show">
                            <div class="accordion-body">
                                <p class="text-muted small mb-3">
                                    @(isAr
                                        ? "العنوان يتكون من ثلاثة أجزاء: نص عادي + كلمة مميزة (تظهر بلون مختلف) + نص عادي. يمكن ترك الجزء الثالث فارغاً."
                                        : "The title has 3 parts: plain text + highlighted word (shown in accent color) + optional plain text suffix.")
                                </p>
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <label class="form-label">
                                            @(isAr ? "بداية العنوان" : "Title — Part 1")
                                        </label>
                                        <input type="text" class="form-control" name="HeroTitle" value="@c.HeroTitle"
                                               placeholder="@(isAr ? "مثال: ابحث عن المدرس المثالي لـ" : "e.g. Find the perfect tutor for")" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">
                                            @(isAr ? "الكلمة المميزة" : "Highlighted Word")
                                            <span class="badge bg-primary-subtle text-primary ms-1" style="font-size:.7rem;">accent</span>
                                        </label>
                                        <input type="text" class="form-control" name="HeroTitleHighlight" value="@c.HeroTitleHighlight"
                                               placeholder="@(isAr ? "مثال: الكلاس" : "e.g. Elclass")" />
                                    </div>
                                    <div class="col-md-4">
                                        <label class="form-label">
                                            @(isAr ? "نهاية العنوان (اختياري)" : "Title — Part 3 (optional)")
                                        </label>
                                        <input type="text" class="form-control" name="HeroTitleSuffix" value="@c.HeroTitleSuffix"
                                               placeholder="@(isAr ? "اختياري" : "optional")" />
                                    </div>
                                    <div class="col-12">
                                        <label class="form-label">@(isAr ? "النص الفرعي (تحت العنوان)" : "Subtitle")</label>
                                        <textarea class="form-control" name="HeroSubtitle" rows="2"
                                                  placeholder="@(isAr ? "جملة قصيرة تصف المنصة" : "A short description displayed under the title")">@c.HeroSubtitle</textarea>
                                    </div>
                                    <div class="col-md-5">
                                        <label class="form-label">@(isAr ? "نص زر الحجز (الزر الأساسي)" : "Primary Button Text")</label>
                                        <input type="text" class="form-control" name="HeroStartBtnText" value="@c.HeroStartBtnText"
                                               placeholder="@(isAr ? "مثال: احجز جلسة مجانية" : "e.g. Book a Free Session")" />
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Stats ─────────────────────────── -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#sec-stats-@tab.Id">
                                <i class="ti ti-chart-bar me-2"></i>
                                @(isAr ? "الإحصائيات (أرقام الهيرو)" : "Hero Stats")
                            </button>
                        </h2>
                        <div id="sec-stats-@tab.Id" class="accordion-collapse collapse">
                            <div class="accordion-body">
                                <p class="text-muted small mb-3">
                                    @(isAr
                                        ? "ثلاثة أرقام تظهر في قسم الهيرو أسفل أزرار الحجز (مثال: +5000 طالب نشط)."
                                        : "Three numbers shown in the hero section below the CTA buttons (e.g. +5000 Active Students).")
                                </p>
                                <div class="row g-3">
                                    @for (int i = 1; i <= 3; i++)
                                    {
                                        var numVal = i == 1 ? c.Counter1Num : i == 2 ? c.Counter2Num : c.Counter3Num;
                                        var lblVal = i == 1 ? c.Counter1Label : i == 2 ? c.Counter2Label : c.Counter3Label;
                                        <div class="col-md-4">
                                            <div class="card border p-3">
                                                <h6 class="mb-3 fw-semibold">@(isAr ? $"الرقم {i}" : $"Stat {i}")</h6>
                                                <label class="form-label small text-muted">@(isAr ? "الرقم" : "Number")</label>
                                                <input type="number" class="form-control mb-2"
                                                       name="Counter@(i)Num" value="@numVal"
                                                       placeholder="@(isAr ? "مثال: 5000" : "e.g. 5000")" />
                                                <label class="form-label small text-muted">@(isAr ? "التسمية" : "Label")</label>
                                                <input type="text" class="form-control"
                                                       name="Counter@(i)Label" value="@lblVal"
                                                       placeholder="@(isAr ? "مثال: طالب نشط" : "e.g. Active Students")" />
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── How It Works ───────────────────── -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#sec-how-@tab.Id">
                                <i class="ti ti-list-check me-2"></i>
                                @(isAr ? "كيف يعمل؟ (الخطوات الأربع)" : "How It Works — Steps")
                            </button>
                        </h2>
                        <div id="sec-how-@tab.Id" class="accordion-collapse collapse">
                            <div class="accordion-body">
                                <p class="text-muted small mb-3">
                                    @(isAr
                                        ? "يجب تعبئة عناوين الخطوات الأربع كاملةً حتى يظهر القسم في الصفحة."
                                        : "All 4 step titles must be filled for the section to appear on the page.")
                                </p>
                                <div class="row g-3">
                                    @{
                                        var steps = new[]
                                        {
                                            (1, c.Step1Title, c.Step1Desc),
                                            (2, c.Step2Title, c.Step2Desc),
                                            (3, c.Step3Title, c.Step3Desc),
                                            (4, c.Step4Title, c.Step4Desc),
                                        };
                                    }
                                    @foreach (var (num, title, desc) in steps)
                                    {
                                        <div class="col-md-6">
                                            <div class="card border p-3">
                                                <h6 class="mb-3 fw-semibold">
                                                    <span class="badge bg-primary rounded-circle me-1" style="width:22px;height:22px;line-height:22px;padding:0;display:inline-flex;align-items:center;justify-content:center;font-size:.75rem;">@num</span>
                                                    @(isAr ? $"الخطوة {num}" : $"Step {num}")
                                                </h6>
                                                <label class="form-label small text-muted">@(isAr ? "العنوان" : "Title")</label>
                                                <input type="text" class="form-control mb-2"
                                                       name="Step@(num)Title" value="@title"
                                                       placeholder="@(isAr ? "عنوان الخطوة" : "Step title")" />
                                                <label class="form-label small text-muted">@(isAr ? "الوصف" : "Description")</label>
                                                <textarea class="form-control" rows="2"
                                                          name="Step@(num)Desc"
                                                          placeholder="@(isAr ? "وصف مختصر" : "Brief description")">@desc</textarea>
                                            </div>
                                        </div>
                                    }
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- ── Quick Links ────────────────────── -->
                    <div class="accordion-item">
                        <h2 class="accordion-header">
                            <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                                    data-bs-target="#sec-links-@tab.Id">
                                <i class="ti ti-layout-grid me-2"></i>
                                @(isAr ? "إدارة أقسام أخرى" : "Manage Other Sections")
                            </button>
                        </h2>
                        <div id="sec-links-@tab.Id" class="accordion-collapse collapse">
                            <div class="accordion-body">
                                <div class="row g-3">
                                    <div class="col-md-4">
                                        <div class="card border p-3 h-100 d-flex flex-column">
                                            <h6 class="mb-1"><i class="ti ti-users me-1 text-primary"></i> @(isAr ? "المدرسون" : "Instructors")</h6>
                                            <p class="text-muted small flex-grow-1">
                                                @(isAr ? "إضافة وتعديل بيانات المدرسين التي تظهر في قسم المدرسين بالصفحة الرئيسية." : "Add and edit instructor profiles shown in the Teachers section.")
                                            </p>
                                            <a href="/Admin/Instructor" class="btn btn-outline-primary btn-sm" target="_blank">
                                                <i class="ti ti-arrow-up-right me-1"></i> @(isAr ? "إدارة المدرسين" : "Manage Instructors")
                                            </a>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card border p-3 h-100 d-flex flex-column">
                                            <h6 class="mb-1"><i class="ti ti-message-circle me-1 text-primary"></i> @(isAr ? "الشهادات والآراء" : "Testimonials")</h6>
                                            <p class="text-muted small flex-grow-1">
                                                @(isAr ? "إضافة وتعديل آراء الطلاب وأولياء الأمور التي تظهر في قسم الآراء." : "Add and edit student and parent reviews shown in the Testimonials section.")
                                            </p>
                                            <a href="/Admin/Testimonials?lang=@(tab.Id == "en" ? "en" : "ar")&country=@(tab.Id == "en" ? "" : tab.Id)"
                                               class="btn btn-outline-primary btn-sm" target="_blank">
                                                <i class="ti ti-arrow-up-right me-1"></i> @(isAr ? "إدارة الشهادات" : "Manage Testimonials")
                                            </a>
                                        </div>
                                    </div>
                                    <div class="col-md-4">
                                        <div class="card border p-3 h-100 d-flex flex-column">
                                            <h6 class="mb-1"><i class="ti ti-currency-dollar me-1 text-primary"></i> @(isAr ? "خطط الأسعار" : "Pricing Plans")</h6>
                                            <p class="text-muted small flex-grow-1">
                                                @(isAr ? "إضافة وتعديل خطط الاشتراك والأسعار وميزات كل خطة." : "Add and edit subscription plans, pricing, and features.")
                                            </p>
                                            <a href="/Admin/PricingPlans?lang=@(tab.Id == "en" ? "en" : "ar")&country=@(tab.Id == "en" ? "" : tab.Id)"
                                               class="btn btn-outline-primary btn-sm" target="_blank">
                                                <i class="ti ti-arrow-up-right me-1"></i> @(isAr ? "إدارة الخطط" : "Manage Plans")
                                            </a>
                                        </div>
                                    </div>
                                    <div class="col-md-4 mt-3">
                                        <div class="card border p-3 h-100 d-flex flex-column">
                                            <h6 class="mb-1"><i class="ti ti-help-circle me-1 text-primary"></i> @(isAr ? "الأسئلة الشائعة" : "FAQs")</h6>
                                            <p class="text-muted small flex-grow-1">
                                                @(isAr ? "إضافة وتعديل الأسئلة الشائعة التي تظهر في قسم FAQ في الصفحة الرئيسية." : "Add and edit FAQ entries shown in the FAQ accordion on the home page.")
                                            </p>
                                            <a href="/Admin/FAQs?lang=@(tab.Id == "en" ? "en" : "ar")&country=@(tab.Id == "en" ? "" : tab.Id)"
                                               class="btn btn-outline-primary btn-sm" target="_blank">
                                                <i class="ti ti-arrow-up-right me-1"></i> @(isAr ? "إدارة الأسئلة" : "Manage FAQs")
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                </div><!-- end accordion -->

                <div class="mt-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary px-4">
                        <i class="ti ti-device-floppy me-1"></i>
                        @(isAr ? "حفظ التغييرات" : "Save Changes")
                    </button>
                </div>
            </form>
        </div>
    }
</div>
