@using Models.ViewModels.Instructor
@model InstructorDetailsVM

@{
    var currentLang = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName;
    var isArabic = currentLang == "ar";
    var direction = isArabic ? "rtl" : "ltr";
}

<div class="container-fluid py-4" style="direction:@direction">
    <input type="hidden" id="instructorId" value="@Model.Instructor.Id" />

    <div class="d-flex justify-content-between align-items-center mb-4 header-section">
        <div>
            <h2 class="fw-bold mb-1 fs-3">
                <i class="fas fa-chalkboard-instructor text-orange me-2"></i>
                @(isArabic ? "إدارة المدرب" : "Instructor Management")
            </h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a href="/Admin/Instructor" class="text-muted text-decoration-none">@(isArabic ? "المدربين" : "Instructors")</a></li>
                    <li class="breadcrumb-item active text-orange" aria-current="page">@(isArabic? Model.Instructor.NameAr : Model.Instructor.NameEn)</li>
                </ol>
            </nav>
        </div>
        @if (!Model.Instructor.IsApproved)
        {
            <div class="d-flex gap-2">

                <button onclick="approveInstructor('@Model.Instructor.Id')"
                class="btn btn-success px-4 shadow-sm">
                    <i class="fas fa-check me-2"></i>
                    @(isArabic ? "قبول المدرب" : "Approve")
                </button>


                <button onclick="deleteInstructor('@Model.Instructor.Id')"
                class="btn btn-danger px-4 shadow-sm">
                    <i class="fas fa-trash me-2"></i>
                    @(isArabic ? "حذف المدرب" : "Delete")
                </button>
            </div>
        }
    </div>

    @* --- قسم الإحصائيات --- *@
    <div class="row mb-4">
        <div class="col-6 col-md-6 col-xl-3 mb-3">
            <a href="#crs">
                <div class="stat-card text-center">
                    <i class="fas fa-book fa-2x mb-2"></i>
                    <h3 class="text-white" id="coursesCountDisp">@Model.InstructorCourses.Count()</h3>
                    <p>@(isArabic ? "الكورسات" : "Courses")</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-6 col-xl-3 mb-3">
            <a href="#std">
                <div class="stat-card text-center">
                    <i class="fas fa-users fa-2x mb-2"></i>
                    <h3 class="text-white" id="studentsCountDisp">@Model.InstructorStudents.Count()</h3>
                    <p>@(isArabic ? "الطلاب" : "Students")</p>
                </div>
            </a>
        </div>
        <div class="col-6 col-md-6 col-xl-3 mb-3">
            <a href="#" onclick="openPaymentSummary(); return false;">
                <div class="stat-card text-center" style="background: linear-gradient(135deg,#2e7d32,#43a047);">
                    <i class="fas fa-file-invoice-dollar fa-2x mb-2"></i>
                    <h3 class="text-white"><i class="fas fa-eye"></i></h3>
                    <p>@(isArabic ? "ملخص الدفع" : "Payment Summary")</p>
                </div>
            </a>
        </div>
    </div>

    <div class="row">
        @* --- الكارت الجانبي (الصورة والبيانات السريعة) --- *@
        <div class="col-12 col-xl-4">
            <div class="card custom-card border-0 shadow-sm mb-4">
                <div class="card-header bg-white border-bottom-0 pb-0">
                    <h5 class="card-title"><i class="fas fa-image" style="color:var(--primary-orange)"></i> @(isArabic ? "الصورة الشخصية" : "Profile Photo")</h5>
                </div>
                <div class="card-body text-center">
                    <div class="position-relative d-inline-block mb-3">
                        <img id="profilePreview" class="rounded-circle img-thumbnail shadow-sm"
                             src="@(Model.Instructor.ApplicationUser.Img != null
                                                                  ? Url.Content("~/images/users/" + Model.Instructor.ApplicationUser.Img)
                                                                  : $"https://ui-avatars.com/api/?name={Model.Instructor.NameEn}&background=fffaf5&color=fd7e14&size=128")"
                             style="width:160px; height:160px; border: 4px solid var(--soft-orange); object-fit: cover;">
                    </div>
                    <form asp-action="ChangeProfilePhoto" method="post" enctype="multipart/form-data">
                        <input type="hidden" name="instructorId" value="@Model.Instructor.Id" />
                        <input type="file" id="photoInput" name="photo" accept="image/*" style="display:none;" />
                        <div class="px-3">
                            <button class="btn btn-orange-custom w-100 mb-2" type="button" onclick="document.getElementById('photoInput').click();">
                                <i class="fas fa-camera me-2"></i>@(isArabic ? "تغيير الصورة" : "Change Photo")
                            </button>
                            <button id="savePhotoBtn" class="btn btn-success w-100 d-none" type="submit">
                                <i class="fas fa-check me-2"></i>@(isArabic ? "تأكيد الصورة الجديدة" : "Confirm New Photo")
                            </button>
                        </div>
                    </form>
                    <hr class="mx-3 my-4 opacity-25">
                    <div class="text-start px-3 @(isArabic ? "text-end" : "")">
                        <p class="small text-muted mb-2"><i class="fas fa-envelope me-2"></i> @Model.Instructor.ApplicationUser.Email</p>
                        <p class="small text-muted mb-2"><i class="fas fa-user-pen me-2"></i> @Model.Instructor.ApplicationUser.UserName</p>
                        <p class="small text-muted mb-0"><i class="fas fa-phone me-2"></i> @(Model.Instructor.ApplicationUser.PhoneNumber ?? (isArabic ? "لا يوجد هاتف" : "No Phone"))</p>
                    </div>
                </div>
            </div>
        </div>

        @* --- الكارت الرئيسي (فورم بيانات المستخدم كاملة بدون حذف) --- *@
        <div class="col-12 col-xl-8" style="color:var(--primary-orange)">
            <div class="card custom-card border-0 shadow-sm">
                <div class="card-header bg-white d-flex justify-content-between align-items-center py-3">
                    <h5 class="card-title mb-0"><i class="fas fa-user-circle" style="color:var(--primary-orange)"></i> @(isArabic ? "ملف المدرب" : "Instructor Profile")</h5>
                    <button type="button" id="enableEditBtn" class="btn btn-outline-orange btn-sm shadow-sm">
                        <i class="fas fa-edit me-1"></i> @(isArabic ? "تعديل البيانات" : "Edit Profile")
                    </button>
                </div>
                <div class="card-body p-4">
                    <form asp-action="EditInstructorDetails" id="instructorForm" enctype="multipart/form-data">
                        <input type="hidden" asp-for="Instructor.Id" />

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Full Name (EN)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" asp-for="Instructor.NameEn" type="text" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted @(isArabic ? "text-start" : "text-end") d-block">الاسم بالكامل (AR)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" type="text" asp-for="Instructor.NameAr" style="text-align:right" readonly>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Specialization (EN)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" asp-for="Instructor.SpecializationEn" type="text" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted @(isArabic ? "text-start" : "text-end") d-block">التخصص (AR)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" type="text" asp-for="Instructor.SpecializationAr" style="text-align:right" readonly>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Email</label>
                                <input class="form-control form-editable bg-light border-0 py-2" type="email" asp-for="Instructor.ApplicationUser.Email" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">@(isArabic ? "رقم الهاتف" : "Phone Number")</label>
                                <input class="form-control form-editable bg-light border-0 py-2" asp-for="Instructor.ApplicationUser.PhoneNumber" readonly>
                            </div>
                        </div>

                        <div class="row g-3 mb-4">
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted">Address (EN)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" type="text" asp-for="Instructor.ApplicationUser.AddressEN" readonly>
                            </div>
                            <div class="col-md-6">
                                <label class="form-label small fw-bold text-muted @(isArabic ? "text-start" : "text-end") d-block">العنوان (AR)</label>
                                <input class="form-control form-editable bg-light border-0 py-2" type="text" asp-for="Instructor.ApplicationUser.AddressAR" style="text-align:right" readonly>
                            </div>
                        </div>

                       <div class="mb-4 col-md-6">
                            <label class="form-label small fw-bold text-muted">
                                <i class="fas fa-file-alt text-orange me-1"></i>
                                @(isArabic ? "السيرة الذاتية" : "Bio / CV")
                            </label>

                            
                            @if (!string.IsNullOrEmpty(Model.Instructor.Bio))
                            {
                                <div class="mb-2">
                                    <button type="button" class="btn btn-outline-orange btn-sm shadow-sm" data-bs-toggle="modal" data-bs-target="#bioModal">
                                        <i class="fas fa-file-pdf me-1"></i>
                                        @(isArabic ? "عرض الملف الحالي" : "View Current File")
                                    </button>
                                </div>
                            }

                            
                            <div class="bio-edit-section d-none">
                                <input type="file" name="BioFile" class="form-control bg-light border-0" accept=".txt,.pdf,.doc,.docx">
                                <div class="form-text">
                                    <i class="fas fa-info-circle text-muted"></i>
                                    @(isArabic ? "اتركه فارغاً إذا لم تريد تغيير الملف" : "Leave empty to keep current file")
                                </div>
                            </div>
                        </div>

                        <div id="formActions" class="d-none gap-2 mt-4 pt-3 border-top">
                            <button class="btn btn-orange-custom px-4 shadow-sm" type="submit">
                                <i class="fas fa-save me-2"></i> @(isArabic ? "حفظ التغييرات" : "Save Changes")
                            </button>
                            <button class="btn btn-light px-4 border" type="button" id="cancelEditBtn">
                                @(isArabic ? "إلغاء" : "Cancel")
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    @* --- جداول الكورسات والطلاب --- *@
    <div class="card custom-card mt-4">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-layer-group icon-primary"></i> @(isArabic ? "الكورسات المسؤولة" : "Managed Courses")</h5>
        </div>
        <div id="crs" class="card-body">
            <div class="table-responsive mb-3">
                <table id="InstructorCoursesTable" class="table admin-table w-100">
                    <thead>
                        <tr>
                            <th>#</th>
                            <th>@(isArabic ? "اسم الكورس" : "Course Name")</th>
                            <th class="text-center">@(isArabic ? "التحكم" : "Actions")</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="assign-section">
                <label class="fw-bold small mb-2"><i class="fas fa-plus-circle text-orange"></i> @(isArabic ? "إسناد كورس جديد" : "Assign New Course")</label>
                <div class="row g-2">
                    <div class="col-md-9"><select id="courseSelect" class="form-control"></select></div>
                    <div class="col-md-3"><button id="assignCourseBtn" class="btn btn-orange-custom w-100"><i class="fas fa-plus"></i> @(isArabic ? "إضافة" : "Assign")</button></div>
                </div>
            </div>
        </div>
    </div>

    <div id="std" class="card custom-card mt-4">
        <div class="card-header">
            <h5 class="card-title"><i class="fas fa-user-graduate icon-primary"></i> @(isArabic ? "الطلاب التابعين" : "Assigned Students")</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive mb-3">
                <table id="InstructorStudentsTable" class="table admin-table w-100">
                    <thead>
                        <tr><th>#</th>
                            <th>@(isArabic ? "اسم الطالب" : "Student Name")</th>
                            <th class="text-center">@(isArabic ? "المحاضرات المتاحة" : "Available Sessions")</th>
                            <th class="text-center">@(isArabic ? "سعر الساعة" : "Hourly Rate")</th>
                            <th class="text-center">@(isArabic ? "التحكم" : "Actions")</th></tr>
                    </thead>
                    <tbody></tbody>
                </table>
            </div>
            <div class="assign-section">
                <label class="fw-bold small mb-2"><i class="fas fa-user-plus text-orange"></i> @(isArabic ? "إسناد طالب جديد" : "Assign New Student")</label>
                <div class="row g-2">
                    <div class="col-md-9"><select id="studentSelect" class="form-control"></select></div>
                    <div class="col-md-3"><button id="assignStudentBtn" class="btn btn-orange-custom w-100"><i class="fas fa-user-plus"></i> @(isArabic ? "إضافة" : "Assign")</button></div>
                </div>
            </div>
        </div>
    </div>
</div>
<div class="modal fade" id="bioModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-file-alt text-orange me-2"></i>
                    @(isArabic ? "السيرة الذاتية" : "CV / Bio File")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-0" style="height: 70vh; background-color: #f8f9fa;">
                @{
                    var bioFileName = Model.Instructor.Bio ?? "";
                    var bioExt = System.IO.Path.GetExtension(bioFileName).ToLower();
                    var bioPath = Url.Content("~/uploads/instructor-bios/" + bioFileName);
                }

                @if (bioExt == ".pdf" || bioExt == ".txt")
                {
                    <iframe src="@bioPath" width="100%" height="100%" style="border:none;"></iframe>
                }
                else if (bioExt == ".mp4" || bioExt == ".webm" || bioExt == ".ogg")
                {
                    <div class="d-flex align-items-center justify-content-center h-100 bg-dark">
                        <video controls style="max-width: 100%; max-height: 100%; shadow: 0 4px 15px rgba(0,0,0,0.5);">
                            <source src="@bioPath" type="video/@bioExt.Replace(".", "")">
                            @(isArabic ? "متصفحك لا يدعم تشغيل الفيديو" : "Your browser does not support the video tag.")
                        </video>
                    </div>
                }
                else
                {
                    <div class="d-flex flex-column align-items-center justify-content-center h-100 text-muted">
                        <i class="fas fa-file-word fa-4x mb-3 text-orange"></i>
                        <p>@(isArabic ? "لا يمكن عرض هذا الملف مباشرة" : "Cannot preview this file type")</p>
                        <a href="@bioPath" class="btn btn-orange-custom" download>
                            <i class="fas fa-download me-1"></i>
                            @(isArabic ? "تحميل الملف" : "Download File")
                        </a>
                    </div>
                }
            </div>
            <div class="modal-footer">
                <a href="@bioPath" class="btn btn-orange-custom btn-sm" download>
                    <i class="fas fa-download me-1"></i>
                    @(isArabic ? "تحميل" : "Download")
                </a>
                <button type="button" class="btn btn-light btn-sm" data-bs-dismiss="modal">
                    @(isArabic ? "إغلاق" : "Close")
                </button>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="updateTimesModal" tabindex="-1">
    <div class="modal-dialog modal-sm modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title"><i class="fas fa-edit text-orange me-1"></i> @(isArabic ? "تعديل بيانات الطالب" : "Edit Student Data")</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <input type="hidden" id="editStudentId">
                <div class="mb-3">
                    <label class="form-label small fw-bold"><i class="fas fa-chalkboard-teacher text-orange me-1"></i> @(isArabic ? "عدد المحاضرات المتاحة" : "Available Sessions")</label>
                    <input type="number" id="newTimesCount" class="form-control" min="0">
                </div>
                <div>
                    <label class="form-label small fw-bold"><i class="fas fa-dollar-sign text-orange me-1"></i> @(isArabic ? "سعر الساعة" : "Hourly Rate")</label>
                    <div class="input-group">
                        <input type="number" id="newHourlyRate" class="form-control" min="0" step="0.01" placeholder="@(isArabic ? "اختياري" : "Optional")">
                        <select id="newHourlyRateCurrency" class="form-select" style="max-width:130px;">
                            <option value="EGP">🇪🇬 جنيه</option>
                            <option value="USD">🇺🇸 دولار</option>
                            <option value="SAR">🇸🇦 ريال</option>
                            <option value="AED">🇦🇪 درهم</option>
                        </select>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-orange-custom w-100" onclick="saveStudentData()">@(isArabic ? "حفظ التعديل" : "Save Changes")</button>
            </div>
        </div>
    </div>
</div>

<!-- Payment Summary Modal -->
<div class="modal fade" id="paymentSummaryModal" tabindex="-1">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header" style="background:linear-gradient(135deg,#2e7d32,#43a047);">
                <h5 class="modal-title text-white"><i class="fas fa-file-invoice-dollar me-2"></i>@(isArabic ? "ملخص الدفع" : "Payment Summary")</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-3" id="paymentSummaryBody">
                <div class="text-center py-5">
                    <i class="fas fa-spinner fa-spin fa-2x text-success"></i>
                    <p class="mt-2 text-muted">@(isArabic ? "جاري التحميل..." : "Loading...")</p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link href="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/css/select2.min.css" rel="stylesheet" />
    <script src="https://cdn.jsdelivr.net/npm/select2@4.1.0-rc.0/dist/js/select2.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>

    <script>
        $(document).ready(function () {
            const instructorId = $('#instructorId').val();
            const isAr = '@isArabic' === 'True';

            const langDt = {
                processing: isAr ? "جاري التحميل..." : "Loading...",
                search: isAr ? "بحث:" : "Search:",
                lengthMenu: isAr ? "عرض _MENU_" : "Show _MENU_",
                info: isAr ? "عرض _START_ إلى _END_ من _TOTAL_" : "Showing _START_ to _END_ of _TOTAL_",
                zeroRecords: isAr ? "لم يتم العثور على نتائج" : "No records found",
                paginate: { next: "»", previous: "«" }
            };

            // حل مشكلة الـ NaN وثبات الجدول
            var coursesTable = $('#InstructorCoursesTable').DataTable({
                processing: true, serverSide: true, ordering: false, language: langDt,
                ajax: { url: '/Admin/Instructor/GetInstructorCourses', type: 'POST', data: d => { d.instructorId = instructorId; } },
                columns: [
                    { data: null, render: (d, t, r, m) => m.row + m.settings._iDisplayStart + 1 },
                    { data: 'title', render: (data, t, row) => `<a href="/Admin/Course/Details/${row.courseId}" class="course-link">${data}</a>` },
                    { data: 'courseId', className: 'text-center', render: (id, t, row) => `
                        <button class="btn btn-sm btn-light border" onclick="confirmRemoveCourse('${id}', '${row.title.replace(/'/g, "\\'")}')"><i class="fas fa-trash text-danger"></i></button>`
                    }
                ]
            });

            var studentsTable = $('#InstructorStudentsTable').DataTable({
                processing: true, serverSide: true, ordering: false, language: langDt,
                ajax: { url: '/Admin/Instructor/GetInstructorStudents', type: 'POST', data: d => { d.instructorId = instructorId; } },
                columns: [
                    { data: null, render: (d, t, r, m) => m.row + m.settings._iDisplayStart + 1 },
                    { data: 'name', render: (data, t, row) => `<a href="/Admin/Student/Details/${row.studentId}" class="student-link">${data}</a>` },
                    {
                        data: 'timesCount',
                        className: 'text-center',
                        render: (data, t, row) => `
                        <span class="badge bg-light text-dark border p-2"
                        onclick="openEditModal('${row.studentId}', ${data}, ${row.hourlyRate ?? 'null'})"
                        style="cursor: pointer;" title="${isAr ? 'اضغط للتعديل' : 'Click to edit'}">
                        <i class="fas fa-edit text-orange me-1"></i> ${data}
                        </span>`
                    },
                    {
                        data: 'hourlyRate',
                        className: 'text-center',
                        render: (data, t, row) => {
                            const currencyLabels = { EGP: 'ج.م', USD: '$', SAR: 'ر.س', AED: 'د.إ' };
                            const symbol = currencyLabels[row.hourlyRateCurrency] || '';
                            const display = (data !== null && data !== undefined) ? `${data} ${symbol}` : '-';
                            const cur = row.hourlyRateCurrency || 'SAR';
                            return `<span class="badge bg-light text-dark border p-2"
                                onclick="openEditModal('${row.studentId}', ${row.timesCount}, ${data ?? 'null'}, '${cur}')"
                                style="cursor: pointer;" title="${isAr ? 'اضغط للتعديل' : 'Click to edit'}">
                                <i class="fas fa-edit text-orange me-1"></i>${display}
                            </span>`;
                        }
                    },
                    { data: 'studentId', className: 'text-center', render: (id, t, row) => `
                        <button class="btn btn-sm btn-light border" onclick="confirmRemoveStudent('${id}', '${row.name.replace(/'/g, "\\'")}')"><i class="fas fa-trash text-danger"></i></button>`
                    }
                ]
            });

            function initSelect2() {
                $('#courseSelect').select2({
                    placeholder: isAr ? 'ابحث عن كورس...' : 'Search course...',
                    minimumInputLength: 2, width: '100%',
                    ajax: { url: '/Admin/Instructor/SearchCourses', data: params => ({ term: params.term, instructorId: instructorId }), processResults: data => ({ results: data }) }
                });
                $('#studentSelect').select2({
                    placeholder: isAr ? 'ابحث عن طالب...' : 'Search student...',
                    minimumInputLength: 2, width: '100%',
                    ajax: { url: '/Admin/Instructor/SearchStudents', data: params => ({ term: params.term, instructorId: instructorId }), processResults: data => ({ results: data }) }
                });
            }
            initSelect2();

            // الإضافة بدون Reload
            $('#assignCourseBtn').on('click', function () {
                const courseId = $('#courseSelect').val();
                if (!courseId) return;
                $.post('/Admin/Instructor/AssignCourse', { instructorId, courseId }, function (res) {
                    if (res.success) {
                        coursesTable.ajax.reload(null, false);
                        $('#courseSelect').val(null).trigger('change');
                        Swal.fire({ icon: 'success', title: isAr ? 'تم' : 'Done', timer: 1000, showConfirmButton: false });
                    }
                });
            });

            $('#assignStudentBtn').on('click', function () {
                const studentId = $('#studentSelect').val();
                if (!studentId) return;
                $.post('/Admin/Instructor/AssignStudent', { instructorId, studentId }, function (res) {
                    if (res.success) {
                        studentsTable.ajax.reload(null, false);
                        $('#studentSelect').val(null).trigger('change');
                        Swal.fire({ icon: 'success', title: isAr ? 'تم' : 'Done', timer: 1000, showConfirmButton: false });
                    }
                });
            });

            // تعديل البيانات وتغيير الصورة (سكريبتك الأصلي)
            $('#enableEditBtn').on('click', function() {
                $('.form-editable').removeAttr('readonly').removeClass('bg-light');
                $('#formActions').removeClass('d-none').addClass('d-flex');
                                        $('.bio-edit-section').removeClass('d-none');
                $(this).hide();
            });
            $('#cancelEditBtn').on('click', () => location.reload());

            $('#photoInput').on('change', function (e) {
                const file = e.target.files[0];
                if (file) {
                    const reader = new FileReader();
                    reader.onload = e => $('#profilePreview').attr('src', e.target.result);
                    reader.readAsDataURL(file);
                    $('#savePhotoBtn').removeClass('d-none');
                }
            });
        });

        // الحذف مع SweetAlert المعدل
        function confirmRemoveCourse(id, name) {
            const isAr = '@isArabic' === 'True';
            Swal.fire({
                title: isAr ? 'متأكد؟' : 'Sure?',
                text: isAr ? `سيتم حذف كورس "${name}"` : `Remove course "${name}"?`,
                icon: 'warning',
                showCancelButton: true
            }).then(result => {
                if (result.isConfirmed) {
                    $.get('/Admin/Instructor/RemoveCourse', { courseId: id, instructorId: $('#instructorId').val() }, () => {
                        $('#InstructorCoursesTable').DataTable().ajax.reload(null, false);
                    });
                }
            });
        }

        function confirmRemoveStudent(id, name) {
            const isAr = '@isArabic' === 'True';
            Swal.fire({
                title: isAr ? 'متأكد؟' : 'Sure?',
                text: isAr ? `سيتم حذف الطالب "${name}"` : `Remove student "${name}"?`,
                icon: 'warning',
                showCancelButton: true
            }).then(result => {
                if (result.isConfirmed) {
                    $.get('/Admin/Instructor/RemoveStudent', { studentId: id, instructorId: $('#instructorId').val() }, () => {
                        $('#InstructorStudentsTable').DataTable().ajax.reload(null, false);
                    });
                }
            });
        }


        function openEditModal(studentId, currentCount, currentRate, currentCurrency) {
            $('#editStudentId').val(studentId);
            $('#newTimesCount').val(currentCount);
            $('#newHourlyRate').val(currentRate !== null && currentRate !== undefined ? currentRate : '');
            $('#newHourlyRateCurrency').val(currentCurrency || 'SAR');
            $('#updateTimesModal').modal('show');
        }

        function saveStudentData() {
            const studentId   = $('#editStudentId').val();
            const newCount    = $('#newTimesCount').val();
            const newRate     = $('#newHourlyRate').val();
            const currency    = $('#newHourlyRateCurrency').val();
            const instructorId = '@Model.Instructor.Id';
            const isAr = '@isArabic' === 'True';

            if (newCount === '' || parseInt(newCount) < 0) {
                Swal.fire(isAr ? 'خطأ' : 'Error', isAr ? 'برجاء إدخال عدد محاضرات صحيح' : 'Please enter a valid sessions count', 'error');
                return;
            }

            const req1 = $.post('/Admin/Instructor/UpdateStudentTimesCount', { studentId, instructorId, newCount });
            const req2 = $.post('/Admin/Instructor/UpdateHourlyRate', { studentId, instructorId, newRate: newRate !== '' ? newRate : null, currency });

            $.when(req1, req2).done(function (res1, res2) {
                const r1 = res1[0], r2 = res2[0];
                if (r1.success && r2.success) {
                    $('#updateTimesModal').modal('hide');
                    Swal.fire({ icon: 'success', title: isAr ? 'تم التحديث' : 'Updated', timer: 1500, showConfirmButton: false });
                    $('#InstructorStudentsTable').DataTable().ajax.reload(null, false);
                } else {
                    Swal.fire(isAr ? 'عذراً' : 'Error', r1.message || r2.message, 'error');
                }
            });
        }




        function approveInstructor(id) {
    const isAr = '@isArabic' === 'True';
    Swal.fire({
        title: isAr ? 'تأكيد القبول' : 'Confirm Approval',
        text: isAr ? 'هل تريد قبول هذا المدرب؟' : 'Are you sure you want to approve this instructor?',
        icon: 'question',
        showCancelButton: true,
        confirmButtonColor: '#198754',
        confirmButtonText: isAr ? 'نعم، قبول' : 'Yes, Approve',
        cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
    }).then(result => {
        if (result.isConfirmed) {
            $.post('/Admin/Instructor/Approve', { id }, function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: isAr ? 'تم القبول' : 'Approved!',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => location.reload());
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            });
        }
    });
}

function deleteInstructor(id) {
    const isAr = '@isArabic' === 'True';
    const token = $('input[name="__RequestVerificationToken"]').val();
    Swal.fire({
        title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
        text: isAr ? 'سيتم حذف المدرب نهائياً!' : 'This instructor will be permanently deleted!',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, Delete!',
        cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
    }).then(result => {
        if (result.isConfirmed) {
            $.post('/Admin/Instructor/Delete', { id, __RequestVerificationToken: token }, function (res) {
                if (res.success) {
                    Swal.fire({
                        icon: 'success',
                        title: isAr ? 'تم الحذف' : 'Deleted!',
                        timer: 1500,
                        showConfirmButton: false
                    }).then(() => window.location.href = '/Admin/Instructor');
                } else {
                    Swal.fire('Error', res.message, 'error');
                }
            });
        }
    });
}


        // ==================== Payment Summary ====================
        const _instrId = '@Model.Instructor.Id';
        const _isAr    = '@isArabic' === 'True';

        const _arabicMonths = ['يناير','فبراير','مارس','إبريل','مايو','يونيو','يوليو','أغسطس','سبتمبر','أكتوبر','نوفمبر','ديسمبر'];
        const _currSymbols  = { EGP: 'ج.م', USD: '$', SAR: 'ر.س', AED: 'د.إ' };

        function openPaymentSummary() {
            $('#paymentSummaryBody').html('<div class="text-center py-5"><i class="fas fa-spinner fa-spin fa-2x text-success"></i><p class="mt-2 text-muted">' + (_isAr ? 'جاري التحميل...' : 'Loading...') + '</p></div>');
            $('#paymentSummaryModal').modal('show');

            $.get('/Admin/Instructor/GetPaymentSummary', { instructorId: _instrId }, function (data) {
                renderPaymentSummary(data);
            }).fail(function () {
                $('#paymentSummaryBody').html('<div class="alert alert-danger">حدث خطأ أثناء التحميل</div>');
            });
        }

        function renderPaymentSummary(months) {
            if (!months || months.length === 0) {
                $('#paymentSummaryBody').html('<div class="alert alert-info text-center">' + (_isAr ? 'لا توجد بيانات' : 'No data found') + '</div>');
                return;
            }

            let html = '';

            months.forEach(function (m) {
                const monthLabel = _isAr ? (_arabicMonths[m.month - 1] + ' ' + m.year) : (new Date(m.year, m.month - 1).toLocaleString('en', { month: 'long' }) + ' ' + m.year);
                const allPaid   = m.students.length > 0 && m.students.every(s => s.isPaid);
                const hasData   = m.students.some(s => s.sessions > 0);

                html += `
                <div class="card border-0 shadow-sm mb-4">
                    <div class="card-header d-flex justify-content-between align-items-center" style="background:#f8f9fa;">
                        <h6 class="mb-0 fw-bold"><i class="fas fa-calendar-alt text-success me-2"></i>${monthLabel}</h6>
                        ${allPaid ? '<span class="badge bg-success fs-6 px-3 py-2"><i class="fas fa-check-circle me-1"></i>' + (_isAr ? 'تم الدفع' : 'Paid') + '</span>' : ''}
                    </div>
                    <div class="card-body p-0">
                        <div class="table-responsive">
                            <table class="table table-hover mb-0">
                                <thead class="table-light">
                                    <tr>
                                        <th>${_isAr ? 'الطالب' : 'Student'}</th>
                                        <th class="text-center">${_isAr ? 'المحاضرات' : 'Sessions'}</th>
                                        <th class="text-center">${_isAr ? 'سعر الساعة' : 'Rate/Hr'}</th>
                                        <th class="text-center">${_isAr ? 'الإجمالي الفرعي' : 'Subtotal'}</th>
                                        <th class="text-center">${_isAr ? 'الحالة' : 'Status'}</th>
                                        <th class="text-center">${_isAr ? 'تحديد' : 'Select'}</th>
                                    </tr>
                                </thead>
                                <tbody>`;

                m.students.forEach(function (s) {
                    const sym      = _currSymbols[s.currency] || s.currency;
                    const rateDisp = s.hourlyRate !== null ? (s.hourlyRate + ' ' + sym) : '-';
                    const subDisp  = s.hourlyRate !== null ? (s.subtotal.toFixed(2) + ' ' + sym) : '-';
                    const paidBadge = s.isPaid
                        ? `<span class="badge bg-success"><i class="fas fa-check me-1"></i>${_isAr ? 'مدفوع' : 'Paid'}</span>`
                        : `<span class="badge bg-warning text-dark">${_isAr ? 'لم يُدفع' : 'Unpaid'}</span>`;

                    html += `
                                    <tr>
                                        <td class="fw-semibold">${s.studentName}</td>
                                        <td class="text-center"><span class="badge bg-light text-dark border">${s.sessions}</span></td>
                                        <td class="text-center">${rateDisp}</td>
                                        <td class="text-center fw-bold">${subDisp}</td>
                                        <td class="text-center">${paidBadge}</td>
                                        <td class="text-center">
                                            <input type="checkbox" class="pay-cb form-check-input"
                                                data-sid="${s.studentId}" data-month="${m.month}" data-year="${m.year}"
                                                ${s.isPaid ? 'checked disabled' : ''}>
                                        </td>
                                    </tr>`;
                });

                html += `
                                </tbody>
                                <tfoot class="table-light fw-bold">
                                    <tr>
                                        <td colspan="3" class="text-end">${_isAr ? 'الإجمالي الكامل:' : 'Grand Total:'}</td>
                                        <td class="text-center text-success fs-6">${m.grandTotal > 0 ? m.grandTotal.toFixed(2) : '-'}</td>
                                        <td colspan="2"></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                    ${!allPaid ? `
                    <div class="card-footer bg-white d-flex justify-content-between align-items-center">
                        <button class="btn btn-sm" style="border:1px solid #2e7d32; color:#2e7d32;" onmouseover="this.style.background='#2e7d32';this.style.color='#fff'" onmouseout="this.style.background='';this.style.color='#2e7d32'" onclick="toggleSelectAll(${m.month}, ${m.year}, this)">
                            <i class="fas fa-check-square me-1"></i>${_isAr ? 'تحديد الكل' : 'Select All'}
                        </button>
                        <button class="btn btn-success px-4" onclick="markAsPaid(${m.month}, ${m.year})">
                            ${_isAr ? 'خالص ✔' : 'Mark as Paid ✔'}
                        </button>
                    </div>` : ''}
                </div>`;
            });

            $('#paymentSummaryBody').html(html);
        }

        function toggleSelectAll(month, year, btn) {
            const boxes = $(`.pay-cb[data-month="${month}"][data-year="${year}"]:not(:disabled)`);
            const allChecked = boxes.filter(':checked').length === boxes.length;
            boxes.prop('checked', !allChecked);
            const isAr = _isAr;
            $(btn).html(!allChecked
                ? `<i class="fas fa-square me-1"></i>${isAr ? 'إلغاء التحديد' : 'Deselect All'}`
                : `<i class="fas fa-check-square me-1"></i>${isAr ? 'تحديد الكل' : 'Select All'}`);
        }

        function markAsPaid(month, year) {
            const checked = [];
            $(`.pay-cb[data-month="${month}"][data-year="${year}"]:checked:not(:disabled)`).each(function () {
                checked.push($(this).data('sid'));
            });

            if (checked.length === 0) {
                Swal.fire(_isAr ? 'تنبيه' : 'Notice', _isAr ? 'برجاء تحديد طالب واحد على الأقل' : 'Please select at least one student', 'warning');
                return;
            }

            Swal.fire({
                title: _isAr ? 'تأكيد الدفع' : 'Confirm Payment',
                text: _isAr ? `سيتم تسجيل ${checked.length} طالب كمدفوع لهذا الشهر` : `Mark ${checked.length} student(s) as paid for this month?`,
                icon: 'question',
                showCancelButton: true,
                confirmButtonColor: '#2e7d32',
                confirmButtonText: _isAr ? 'نعم، خالص' : 'Yes, Mark Paid',
                cancelButtonText: _isAr ? 'إلغاء' : 'Cancel'
            }).then(function (result) {
                if (!result.isConfirmed) return;

                $.post('/Admin/Instructor/MarkMonthAsPaid', {
                    instructorId: _instrId,
                    month: month,
                    year: year,
                    studentIds: checked
                }).done(function () {
                        openPaymentSummary();
                        Swal.fire({ icon: 'success', title: _isAr ? 'تم التسجيل' : 'Saved!', timer: 1200, showConfirmButton: false });
                    }).fail(function () {
                        Swal.fire('Error', _isAr ? 'حدث خطأ' : 'Something went wrong', 'error');
                    });
            });
        }
        // =========================================================

    </script>
}