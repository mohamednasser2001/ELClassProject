@model Models.PricingPlan

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "تعديل خطة السعر" : "Edit Pricing Plan";
    var dir = Model.Language == "en" ? "ltr" : "rtl";
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h4 class="mb-0">
        <i class="ti ti-edit me-2"></i>
        @(isAr ? "تعديل خطة السعر" : "Edit Pricing Plan")
    </h4>
    <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
       class="btn btn-outline-secondary btn-sm">
        <i class="ti ti-arrow-left me-1"></i> @(isAr ? "رجوع" : "Back")
    </a>
</div>

<div class="row g-4">
    <div class="col-lg-8">
        <div class="card shadow-sm">
            <div class="card-body" style="direction:@dir">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" name="Id" value="@Model.Id" />
                    <input type="hidden" name="Language" value="@Model.Language" />
                    <input type="hidden" name="CountryCode" value="@Model.CountryCode" />
                    <input type="hidden" name="Currency" value="@Model.Currency" />

                    <div class="row g-3">

                        <!-- Name & Description -->
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">
                                @(isAr ? "اسم الخطة" : "Plan Name")
                                <span class="text-danger">*</span>
                            </label>
                            <input name="Name" class="form-control" value="@Model.Name" required />
                        </div>
                        <div class="col-md-6">
                            <label class="form-label fw-semibold">@(isAr ? "وصف الخطة (العنوان الفرعي)" : "Description (subtitle)")</label>
                            <input name="Description" class="form-control" value="@Model.Description" />
                        </div>

                        <!-- Prices -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">@(isAr ? "الأسعار" : "Prices")</label>
                            <div class="row g-2">
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">@(isAr ? "الشهري" : "Monthly")</label>
                                    <input name="MonthlyPrice" class="form-control" value="@Model.MonthlyPrice" />
                                </div>
                                <div class="col-md-6">
                                    <label class="form-label small text-muted">@(isAr ? "السنوي" : "Yearly")</label>
                                    <input name="YearlyPrice" class="form-control" value="@Model.YearlyPrice" />
                                </div>
                            </div>
                        </div>

                        <!-- Options -->
                        <div class="col-md-4">
                            <label class="form-label fw-semibold">@(isAr ? "الترتيب" : "Sort Order")</label>
                            <input type="number" name="SortOrder" class="form-control" value="@Model.SortOrder" min="0" />
                        </div>
                        <div class="col-md-4 d-flex align-items-end pb-1">
                            <div class="form-check">
                                <input type="checkbox" name="IsPopular" value="true" class="form-check-input" id="isPopular"
                                       @(Model.IsPopular ? "checked" : "") />
                                <label class="form-check-label" for="isPopular">
                                    @(isAr ? "الأكثر شعبية (مميز)" : "Most Popular (featured)")
                                </label>
                            </div>
                        </div>
                        <div class="col-md-4 d-flex align-items-end pb-1">
                            <div class="form-check">
                                <input type="checkbox" name="IsActive" value="true" class="form-check-input" id="isActive"
                                       @(Model.IsActive ? "checked" : "") />
                                <label class="form-check-label" for="isActive">
                                    @(isAr ? "نشط (ظاهر في الصفحة)" : "Active (visible on page)")
                                </label>
                            </div>
                        </div>

                        <!-- Features -->
                        <div class="col-12">
                            <label class="form-label fw-semibold">@(isAr ? "الميزات" : "Features")</label>
                            <div class="text-muted small mb-2">
                                @if (isAr)
                                {
                                    <span>ميزة واحدة في كل سطر. أضف <code>|1</code> في النهاية لميزة متاحة، أو <code>|0</code> لميزة غير متاحة.</span>
                                }
                                else
                                {
                                    <span>One feature per line. Append <code>|1</code> for an included feature, <code>|0</code> for excluded.</span>
                                }
                            </div>
                            <textarea name="Features" class="form-control font-monospace" rows="7">@Model.Features</textarea>
                        </div>
                    </div>

                    <div class="mt-4 d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i>
                            @(isAr ? "حفظ التغييرات" : "Save Changes")
                        </button>
                        <a asp-action="Index" asp-route-lang="@Model.Language" asp-route-country="@Model.CountryCode"
                           class="btn btn-outline-secondary">
                            @(isAr ? "إلغاء" : "Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-4">
        <!-- Live preview -->
        <div class="card @(Model.IsPopular ? "border-primary border-2" : "border") shadow-sm">
            @if (Model.IsPopular)
            {
                <div class="card-header bg-primary text-white text-center py-2 fw-semibold" style="font-size:.85rem;">
                    <i class="ti ti-star-filled me-1"></i>
                    @(isAr ? "الأكثر شعبية" : "Most Popular")
                </div>
            }
            <div class="card-body" style="direction:@dir">
                <h5 class="fw-bold mb-1">@(Model.Name ?? (isAr ? "اسم الخطة" : "Plan Name"))</h5>
                <p class="text-muted small mb-3">@(Model.Description ?? (isAr ? "الوصف" : "Description"))</p>
                <div class="mb-3">
                    <span class="fs-4 fw-bold text-primary">@(string.IsNullOrEmpty(Model.MonthlyPrice) ? "---" : Model.MonthlyPrice)</span>
                    <span class="text-muted small">/@(isAr ? "شهر" : "mo")</span>
                </div>
                @{
                    var feats = Model.ParsedFeatures();
                }
                @if (feats.Any())
                {
                    <ul class="list-unstyled small mb-0">
                        @foreach (var (text, isChecked) in feats)
                        {
                            <li class="d-flex align-items-center gap-1 mb-1 @(isChecked ? "" : "text-muted")">
                                <i class="ti @(isChecked ? "ti-check text-success" : "ti-x text-muted") flex-shrink-0" style="font-size:.8rem;"></i>
                                @text
                            </li>
                        }
                    </ul>
                }
            </div>
        </div>
        <p class="text-muted small text-center mt-2">
            <i class="ti ti-info-circle me-1"></i>
            @(isAr ? "معاينة تقريبية (السعر سيُعرض بعملة بلد المستخدم)" : "Approximate preview (price shown in user's currency)")
        </p>
    </div>
</div>
