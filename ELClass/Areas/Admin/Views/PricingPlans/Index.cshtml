@model List<Models.PricingPlan>
@using ELClass.Areas.Admin.Controllers

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "خطط الأسعار" : "Pricing Plans";
    var dir = isAr ? "rtl" : "ltr";

    string lang = ViewBag.Lang ?? "en";
    string? country = ViewBag.Country;
    var countries = (IEnumerable<(string Code, string NameAr, string NameEn)>)ViewBag.Countries;
}

<div class="d-flex justify-content-between align-items-center mb-3" style="direction:@dir">
    <h4 class="mb-0">
        <i class="ti ti-currency-dollar me-2"></i>
        @(isAr ? "إدارة خطط الأسعار" : "Manage Pricing Plans")
    </h4>
    <a asp-action="Create" asp-route-lang="@lang" asp-route-country="@country" class="btn btn-primary btn-sm">
        <i class="ti ti-plus me-1"></i> @(isAr ? "إضافة خطة" : "Add Plan")
    </a>
</div>

<!-- Language / Country Tabs -->
<ul class="nav nav-tabs mb-4" style="direction:ltr; flex-wrap:wrap; gap:4px;">
    <li class="nav-item">
        <a class="nav-link @(lang == "en" ? "active" : "")"
           asp-action="Index" asp-route-lang="en" asp-route-country="">
            <i class="fi fi-gb me-1"></i> English
        </a>
    </li>
    @foreach (var c in countries)
    {
        <li class="nav-item">
            <a class="nav-link @(lang == "ar" && country == c.Code ? "active" : "")"
               asp-action="Index" asp-route-lang="ar" asp-route-country="@c.Code">
                <i class="fi fi-@c.Code.ToLower() me-1"></i>
                @(isAr ? c.NameAr : c.NameEn)
            </a>
        </li>
    }
</ul>

@if (!Model.Any())
{
    <div class="text-center py-5 text-muted">
        <i class="ti ti-currency-dollar" style="font-size:3rem;"></i>
        <p class="mt-2">@(isAr ? "لا توجد خطط بعد." : "No pricing plans yet.")</p>
    </div>
}
else
{
    <div class="row g-3">
        @foreach (var plan in Model.OrderBy(p => p.SortOrder))
        {
            var features = plan.ParsedFeatures();
            <div class="col-lg-4 col-md-6">
                <div class="card shadow-sm h-100 @(plan.IsPopular ? "border-primary border-2" : "")">
                    @if (plan.IsPopular)
                    {
                        <div class="card-header bg-primary text-white text-center py-2 fw-semibold" style="font-size:.85rem;">
                            <i class="ti ti-star-filled me-1"></i>
                            @(isAr ? "الأكثر شعبية" : "Most Popular")
                        </div>
                    }
                    <div class="card-body d-flex flex-column" style="direction:@dir">
                        <div class="d-flex justify-content-between align-items-start mb-1">
                            <h5 class="card-title mb-0">@plan.Name</h5>
                            @if (!plan.IsActive)
                            {
                                <span class="badge bg-secondary-subtle text-secondary" style="font-size:.7rem;">@(isAr ? "مخفي" : "Hidden")</span>
                            }
                        </div>
                        <p class="text-muted small mb-3">@plan.Description</p>

                        <div class="mb-3">
                            <div class="d-flex align-items-baseline gap-1">
                                <span class="fs-4 fw-bold text-primary">@plan.MonthlyPrice</span>
                                <span class="text-muted small">/@(isAr ? "شهر" : "mo")</span>
                            </div>
                            <div class="text-muted small">
                                @plan.YearlyPrice /@(isAr ? "سنة" : "yr")
                                <span class="text-muted" style="font-size:.75rem;">(@(isAr ? "السعر الأساسي — يُحوَّل تلقائياً" : "base price — auto-converted"))</span>
                            </div>
                        </div>

                        @if (features.Any())
                        {
                            <ul class="list-unstyled small flex-grow-1 mb-3">
                                @foreach (var (text, isChecked) in features)
                                {
                                    <li class="d-flex align-items-center gap-1 mb-1 @(isChecked ? "" : "text-muted")">
                                        <i class="ti @(isChecked ? "ti-check text-success" : "ti-x text-muted") flex-shrink-0" style="font-size:.8rem;"></i>
                                        @text
                                    </li>
                                }
                            </ul>
                        }
                        else
                        {
                            <div class="text-muted small flex-grow-1 mb-3 fst-italic">@(isAr ? "لا توجد ميزات مضافة" : "No features added")</div>
                        }

                        <div class="d-flex gap-2 mt-auto">
                            <a asp-action="Edit" asp-route-id="@plan.Id" class="btn btn-sm btn-outline-primary flex-grow-1">
                                <i class="ti ti-edit me-1"></i> @(isAr ? "تعديل" : "Edit")
                            </a>
                            <form asp-action="Delete" method="post" style="display:inline;"
                                  onsubmit="return confirm('@(isAr ? "حذف هذه الخطة؟" : "Delete this plan?")')">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="id" value="@plan.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-danger">
                                    <i class="ti ti-trash"></i>
                                </button>
                            </form>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
}
