@using ELClass.services
@model IEnumerable<Models.Appointment>

@{
    var isArabic = CultureHelper.IsArabic;
}

<div class="p-6 bg-gray-50 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-calendar-alt text-blue-800"></i>
                @(isArabic ? "إدارة جدول المحاضرات" : "Lectures Schedule Management")
            </h1>
            <p class="text-gray-500 text-sm mt-1">@(isArabic ? "تعديل موعد واحد يطبق على جميع الطلاب المشتركين" : "Editing one appointment applies to all linked students")</p>
        </div>

        <div class="flex items-center gap-3">
            <div class="flex items-center gap-2">
                <label class="text-xs font-bold text-gray-500 uppercase">@(isArabic ? "تصفية بالمحاضر:" : "Filter:")</label>
                <select id="instructorFilter" class="rounded-lg border-gray-300 text-sm py-2 dark:bg-white focus:ring-blue-500 shadow-sm">
                    <option value="all">@(isArabic ? "كل المحاضرين" : "All Instructors")</option>
                    @foreach (var instructor in Model.Where(m => m.Instructor != null).Select(m => m.Instructor).GroupBy(i => i.Id).Select(g => g.First()))
                    {
                        <option value="@instructor!.Id">@(isArabic? instructor!.NameAr: instructor!.NameEn)</option>
                    }
                </select>
            </div>
        </div>
        @* <a href="/Admin/Appointment/AddNewAppointment" class="inline-flex items-center px-5 py-2.5 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 w-fit">
            <i class="fas fa-plus text-sm"></i>
            @(isArabic ? "إضافة ميعاد جديد" : "Add New Appointment")
        </a> *@
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-right">
                <thead class="bg-gray-50 text-gray-600 font-semibold border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-center">#</th>
                        <th class="px-6 py-4">@(isArabic ? "الكورس" : "Course")</th>
                        <th class="px-6 py-4">@(isArabic ? "المحاضر" : "Instructor")</th>
                        <th class="px-6 py-4">@(isArabic ? "اليوم / الوقت" : "Day / Time")</th>
                        <th class="px-6 py-4 text-center">@(isArabic ? "عدد الطلاب" : "Students")</th>
                        <th class="px-6 py-4">@(isArabic ? "الحالة" : "Status")</th>
                        <th class="px-6 py-4 text-center">@(isArabic ? "الإجراءات" : "Actions")</th>
                    </tr>
                </thead>
               
        

                <tbody class="divide-y divide-gray-50" id="appointmentsTableBody">
                    @foreach (var item in Model.Select((value, index) => new { value, index }))
                    {
                        <tr class="hover:bg-blue-50/30 appointment-row transition-colors" data-instructor-id="@item.value.InstructorId">
                            <td class="px-6 py-4 text-center text-gray-400 font-medium row-index">@(item.index + 1)</td>

                            <td class="px-6 py-4">
                                <div class="font-bold text-gray-900">@(isArabic? item.value.Course?.TitleAr : item.value.Course?.TitleEn)</div>
                                
                            </td>

                            <td class="px-6 py-4 text-center">
                                <a href="/Admin/Instructor/Details/@item.value.InstructorId"
                                       class="inline-flex items-center px-3 py-1 text-blue-700 rounded-full font-bold hover:bg-blue-100 transition-colors">
                                    <i class="fas fa-user mx-1 text-xs text-blue-400"></i>
                                    @(isArabic? item.value.Instructor?.NameAr : item.value.Instructor?.NameEn)
                                </a>
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-gray-900 font-medium">
                                        <i class="far fa-calendar-alt ml-1 text-blue-500"></i>
                                        <span data-egypt-dt='@item.value.StartDateTime.ToString("yyyy-MM-ddTHH:mm:ss")' data-dt-format="date">@item.value.StartDateTime.ToString("yyyy-MM-dd")</span>
                                    </span>
                                    <span class="text-orange-600 text-xs mt-1">
                                        <i class="far fa-clock"></i>
                                        <span data-egypt-dt='@item.value.StartDateTime.ToString("yyyy-MM-ddTHH:mm:ss")' data-dt-format="time">@item.value.StartDateTime.ToString("hh:mm tt")</span>
                                        (@item.value.DurationInHours @(isArabic ? "ساعة" : "Hrs"))
                                    </span>
                                </div>
                            </td>

                            <td class="px-6 py-4 text-center">
                                <a href="/Admin/Appointment/ManageStudents/@item.value.Id"
                                       class="inline-flex items-center px-3 py-1 bg-blue-50 text-blue-700 rounded-full font-bold hover:bg-blue-100 transition-colors">
                                    <i class="fas fa-users mx-1 text-xs text-blue-400"></i>
                                    @item.value.StudentAppointments.Count
                                </a>
                            </td>

                            <td class="px-6 py-4">
                                @if (item.value.IsActive)
                                {
                                    <span class="flex items-center gap-1.5 text-green-600 font-bold animate-pulse">
                                        <span class="w-2 h-2 bg-green-500 rounded-full"></span>
                                        @(isArabic ? "مباشر الآن" : "Live Now")
                                    </span>
                                }
                                else if (item.value.StartDateTime > DateTime.Now)
                                {
                                    <span class="text-blue-500 flex items-center gap-1">
                                        <i class="fas fa-hourglass-start text-xs"></i>
                                        @(isArabic ? "قادم" : "Upcoming")
                                    </span>
                                }
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex justify-center gap-2">
                                    @* <a href="/Admin/Appointment/Edit/@item.value.Id" class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg border border-gray-100" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </a> *@

                                    @if (item.value.IsActive)
                                    {
                                        @if (!string.IsNullOrWhiteSpace(item.value.MeetingLink))
                                        {
                                            <a href="@item.value.MeetingLink" target="_blank" rel="noopener noreferrer"
                                               class="p-2 text-green-500 hover:bg-green-50 rounded-lg border border-green-200 bg-green-50/50 shadow-sm animate-bounce"
                                               title="@(isArabic ? "انضم الآن خارجياً" : "Join Now (External)")">
                                                <i class="fas fa-video"></i>
                                            </a>
                                        }
                                        else
                                        {
                                            <span class="p-2 text-amber-500 bg-amber-50 border border-amber-200 rounded-lg"
                                                  title="@(isArabic ? "مباشر — بدون رابط خارجي" : "Live — No external link")">
                                                <i class="fas fa-circle-dot animate-pulse"></i>
                                            </span>
                                        }
                                    }
                                    else
                                    {
                                        <span class="p-2 text-gray-300 bg-gray-50 border border-gray-100 rounded-lg cursor-not-allowed"
                                              title="@(isArabic ? "الموعد غير متاح حالياً" : "Meeting not available yet")">
                                            <i class="fas fa-video-slash"></i>
                                        </span>
                                    }

                                    @* <button onclick="deleteAppointment(@item.value.Id)" class="p-2 text-red-500 hover:bg-red-50 rounded-lg border border-gray-100" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </button> *@
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100" id="paginationContainer">
            <div class="text-sm text-gray-500" id="paginationInfo"></div>
            <div class="flex items-center gap-1" id="paginationControls"></div>
        </div>
    </div>
</div>

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

@section Scripts {
    <script>
        const ROWS_PER_PAGE = 10;
        const isAr = "@isArabic".toLowerCase() === "true";
        let currentPage = 1;

        (function () {
            function localizeEgyptTimes() {
                document.querySelectorAll('[data-egypt-dt]').forEach(function (el) {
                    var raw = el.getAttribute('data-egypt-dt');
                    var fmt = el.getAttribute('data-dt-format') || 'time';
                    var d = new Date(raw + '+02:00');
                    if (isNaN(d.getTime())) return;
                    try {
                        if (fmt === 'date') {
                            el.textContent = d.toLocaleDateString(undefined, { year: 'numeric', month: '2-digit', day: '2-digit' });
                        } else if (fmt === 'date-long') {
                            el.textContent = d.toLocaleDateString(undefined, { weekday: 'long', year: 'numeric', month: 'long', day: '2-digit' });
                        } else if (fmt === 'date-short') {
                            el.textContent = d.toLocaleDateString(undefined, { weekday: 'short', day: '2-digit', month: 'short' });
                        } else if (fmt === 'time') {
                            el.textContent = d.toLocaleTimeString(undefined, { hour: '2-digit', minute: '2-digit' });
                        }
                    } catch (e) {}
                });
            }
            document.addEventListener('DOMContentLoaded', localizeEgyptTimes);
        })();
        let filteredRows = [];

        function getAllRows() {
            return Array.from(document.querySelectorAll('.appointment-row'));
        }

        function applyFilterAndPaginate(selectedId) {
            const all = getAllRows();
            filteredRows = selectedId === 'all'
                ? all
                : all.filter(r => r.getAttribute('data-instructor-id') === selectedId);
            currentPage = 1;
            renderPage();
        }

        function renderPage() {
            const all = getAllRows();
            all.forEach(r => r.style.display = 'none');

            const start = (currentPage - 1) * ROWS_PER_PAGE;
            const pageRows = filteredRows.slice(start, start + ROWS_PER_PAGE);

            pageRows.forEach((row, i) => {
                row.style.display = '';
                const cell = row.querySelector('.row-index');
                if (cell) cell.textContent = start + i + 1;
            });

            updatePaginationUI();
        }

        function updatePaginationUI() {
            const total = filteredRows.length;
            const totalPages = Math.max(1, Math.ceil(total / ROWS_PER_PAGE));
            const start = Math.min((currentPage - 1) * ROWS_PER_PAGE + 1, total);
            const end = Math.min(currentPage * ROWS_PER_PAGE, total);

            document.getElementById('paginationInfo').textContent = isAr
                ? `عرض ${start}–${end} من ${total}`
                : `Showing ${start}–${end} of ${total}`;

            const controls = document.getElementById('paginationControls');
            controls.innerHTML = '';

            const btnClass = 'px-3 py-1.5 text-sm rounded-lg border transition-colors';
            const activeClass = 'bg-blue-800 text-white border-blue-800 font-semibold';
            const inactiveClass = 'bg-white text-gray-600 border-gray-200 hover:bg-gray-50';
            const disabledClass = 'bg-gray-50 text-gray-300 border-gray-100 cursor-not-allowed';

            // زر السابق
            const prev = document.createElement('button');
            prev.className = `${btnClass} ${currentPage === 1 ? disabledClass : inactiveClass}`;
            prev.innerHTML = isAr ? '&#8250; السابق' : '&lsaquo; Prev';
            prev.disabled = currentPage === 1;
            prev.onclick = () => { currentPage--; renderPage(); };
            controls.appendChild(prev);

            // أرقام الصفحات
            const maxVisible = 5;
            let pageStart = Math.max(1, currentPage - Math.floor(maxVisible / 2));
            let pageEnd = Math.min(totalPages, pageStart + maxVisible - 1);
            if (pageEnd - pageStart < maxVisible - 1) pageStart = Math.max(1, pageEnd - maxVisible + 1);

            for (let p = pageStart; p <= pageEnd; p++) {
                const btn = document.createElement('button');
                btn.className = `${btnClass} ${p === currentPage ? activeClass : inactiveClass}`;
                btn.textContent = p;
                btn.onclick = (function (page) { return () => { currentPage = page; renderPage(); }; })(p);
                controls.appendChild(btn);
            }

            // زر التالي
            const next = document.createElement('button');
            next.className = `${btnClass} ${currentPage === totalPages ? disabledClass : inactiveClass}`;
            next.innerHTML = isAr ? 'التالي &#8249;' : 'Next &rsaquo;';
            next.disabled = currentPage === totalPages;
            next.onclick = () => { currentPage++; renderPage(); };
            controls.appendChild(next);
        }

        document.getElementById('instructorFilter').addEventListener('change', function () {
            applyFilterAndPaginate(this.value);
        });

        // تهيئة عند التحميل
        applyFilterAndPaginate('all');


        function deleteAppointment(id) {
            Swal.fire({
                title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
                text: isAr ? 'لن تتمكن من استعادة هذا الموعد!' : "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, delete it!',
                cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/Admin/Appointment/Delete', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire(
                                isAr ? 'تم الحذف!' : 'Deleted!',
                                isAr ? 'تم حذف الموعد بنجاح.' : 'The appointment has been deleted.',
                                'success'
                            ).then(() => location.reload());
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }
    </script>
}