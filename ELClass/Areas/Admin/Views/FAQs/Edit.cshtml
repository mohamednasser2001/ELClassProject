@model Models.FAQ
@using ELClass.Areas.Admin.Controllers

@{
    var isAr = System.Threading.Thread.CurrentThread.CurrentCulture.Name.StartsWith("ar");
    ViewData["Title"] = isAr ? "تعديل سؤال" : "Edit FAQ";
    var dir = isAr ? "rtl" : "ltr";

    string lang = ViewBag.Lang ?? "en";
    string? country = ViewBag.Country;
    var countries = (IEnumerable<(string Code, string NameAr, string NameEn)>)ViewBag.Countries;
    string countryLabel = lang == "en" ? "English" :
        countries.FirstOrDefault(c => c.Code == country).NameEn ?? country ?? "";
}

<div class="d-flex align-items-center gap-2 mb-4" style="direction:@dir">
    <a asp-action="Index" asp-route-lang="@lang" asp-route-country="@country" class="btn btn-sm btn-outline-secondary">
        <i class="ti ti-arrow-left"></i>
    </a>
    <h4 class="mb-0">
        <i class="ti ti-help-circle me-2"></i>
        @(isAr ? "تعديل سؤال شائع" : "Edit FAQ")
        <span class="badge bg-primary-subtle text-primary ms-2" style="font-size:.75rem;">@countryLabel</span>
    </h4>
</div>

<div class="row g-4" style="direction:@dir">
    <div class="col-lg-7">
        <div class="card shadow-sm">
            <div class="card-body">
                <form asp-action="Edit" method="post">
                    @Html.AntiForgeryToken()
                    <input type="hidden" asp-for="Id" />
                    <input type="hidden" asp-for="Language" value="@lang" />
                    <input type="hidden" asp-for="CountryCode" value="@country" />

                    <div class="mb-3">
                        <label asp-for="Question" class="form-label fw-semibold">
                            @(isAr ? "السؤال" : "Question") <span class="text-danger">*</span>
                        </label>
                        <input asp-for="Question" class="form-control" id="inp-q" />
                        <span asp-validation-for="Question" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Answer" class="form-label fw-semibold">
                            @(isAr ? "الإجابة" : "Answer") <span class="text-danger">*</span>
                        </label>
                        <textarea asp-for="Answer" class="form-control" rows="5" id="inp-a"></textarea>
                        <span asp-validation-for="Answer" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-sm-6">
                            <label asp-for="SortOrder" class="form-label fw-semibold">
                                @(isAr ? "الترتيب" : "Sort Order")
                            </label>
                            <input asp-for="SortOrder" class="form-control" type="number" min="0" />
                            <div class="form-text">@(isAr ? "0 = الأول" : "0 = first")</div>
                        </div>
                        <div class="col-sm-6 d-flex align-items-center">
                            <div class="form-check mt-4">
                                <input asp-for="IsActive" class="form-check-input" type="checkbox" />
                                <label asp-for="IsActive" class="form-check-label">
                                    @(isAr ? "مفعّل (يظهر في الصفحة)" : "Active (visible on page)")
                                </label>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="ti ti-device-floppy me-1"></i>
                            @(isAr ? "حفظ التغييرات" : "Save Changes")
                        </button>
                        <a asp-action="Index" asp-route-lang="@lang" asp-route-country="@country"
                           class="btn btn-outline-secondary">
                            @(isAr ? "إلغاء" : "Cancel")
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="col-lg-5">
        <div class="card border-0 bg-body-secondary">
            <div class="card-body">
                <p class="text-muted small fw-semibold mb-3">
                    <i class="ti ti-eye me-1"></i>
                    @(isAr ? "معاينة مباشرة:" : "Live preview:")
                </p>
                <div class="border rounded bg-white p-3">
                    <div class="d-flex justify-content-between align-items-center" style="cursor:pointer;">
                        <span class="fw-semibold small" id="prev-q">@(Model.Question ?? "")</span>
                        <span style="font-size:1.2rem; color:var(--bs-primary)">+</span>
                    </div>
                    <div class="mt-2 pt-2 border-top text-muted small" id="prev-a">@(Model.Answer ?? "")</div>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    document.getElementById('inp-q')?.addEventListener('input', function () {
        document.getElementById('prev-q').textContent = this.value;
    });
    document.getElementById('inp-a')?.addEventListener('input', function () {
        document.getElementById('prev-a').textContent = this.value;
    });
</script>
