@using ELClass.services
@using System.Security.Claims
@{

    var isArabic = CultureHelper.IsArabic;
    var currentLang = isArabic ?"ar" :"en";
    var direction = currentLang == "ar" ? "rtl" : "ltr";
}

@Html.AntiForgeryToken()
<div class="container-fluid" style="direction: @direction;">
    <div class="row">
        <div class="col-12">
            <div class="card custom-card">
                <div class="card-header d-flex justify-content-between align-items-center">
                    <h3 class="card-title">
                        <i class="fas fa-user-graduate icon-primary"></i>
                        @(currentLang == "ar" ? "قائمة الطلاب" : "Students List")
                    </h3>

                   
                </div>

                <div class="card-body p-2 p-md-4">
                    <div class="table-responsive">
                        <table id="StudentsTable" class="table">
                            <thead>
                                <tr>
                                    <th style="text-align: @(currentLang == "ar" ? "right" : "left")">#</th>
                                    <th style="text-align: @(currentLang == "ar" ? "right" : "left")">@(currentLang == "ar" ? "الاسم" : "Name")</th>
                                    <th style="text-align: center">@(currentLang == "ar" ? "المواعيد المتاحة" : "Available Sessions")</th>
                                    <th style="text-align: center">@(currentLang == "ar" ? "التحكم" : "Actions")</th>
                                    
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>


<div class="modal fade" id="appointmentModal" tabindex="-1">
    <div class="modal-dialog modal-lg modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-calendar-plus text-orange me-2"></i>
                    <span id="modalStudentName"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">

           
                <div style="display:none">
                    <select id="modalCourseSelect" class="form-control"></select>
                </div>

   
                <div class="mb-4" id="extraStudentsSection" style="display:none">
                    <label class="small fw-bold text-muted mb-2">
                        <i class="fas fa-users text-orange me-1"></i>
                        @(isArabic ? "إضافة طلاب آخرين (اختياري)" : "Add more students (optional)")
                    </label>
                    <select id="extraStudentsSelect" class="form-control" multiple></select>
                    <div class="form-text">
                        @(isArabic ? "الطلاب المسجلين في نفس الكورس مع نفس المدرس" : "Students enrolled in same course with this instructor")
                    </div>
               
                    <div id="selectedStudentsTags" class="d-flex flex-wrap gap-2 mt-2"></div>
                </div>


                <div class="mb-4">
                    <label class="small fw-bold text-muted mb-2">
                        <i class="fas fa-link text-orange me-1"></i>
                        @(isArabic ? "رابط الاجتماع" : "Meeting Link")
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-video text-orange"></i>
                        </span>
                        <input type="url" id="sharedMeetingLink" class="form-control bg-light border-start-0"
                               placeholder="https://...">
                    </div>
                </div>

                @* <div class="mb-4">
                    <label class="small fw-bold text-muted mb-2">
                        <i class="fas fa-hourglass-half text-orange me-1"></i>
                        @(isArabic ? "المدة (بالساعات)" : "Duration (Hours)")
                    </label>
                    <input type="number" id="sharedDuration" class="form-control" value="1" min="1" style="width:120px">
                </div> *@


                <div class="d-flex align-items-center justify-content-between mb-4 p-3 bg-light rounded-3">
                    <div>
                        <span class="small fw-bold text-muted">
                            @(isArabic ? "المرات المتبقية" : "Remaining Sessions")
                        </span>
                        <h3 class="mb-0 text-orange fw-bold" id="remainingCount">0</h3>
                    </div>
                    <div class="d-flex align-items-center gap-2">
                        <button type="button" class="btn btn-sm btn-light border px-3" id="removeSlotBtn">
                            <i class="fas fa-minus text-danger"></i>
                        </button>
                        <span class="fw-bold" id="slotsCount">0</span>
                        <span class="text-muted small">@(isArabic ? "مواعيد" : "slots")</span>
                        <button type="button" class="btn btn-sm btn-light border px-3" id="addSlotBtn">
                            <i class="fas fa-plus text-orange"></i>
                        </button>
                    </div>
                </div>

       
                <div id="slotsContainer"></div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">
                    @(isArabic ? "إلغاء" : "Cancel")
                </button>
                <button type="button" class="btn btn-orange-custom px-4" id="saveAppointmentsBtn">
                    <i class="fas fa-save me-1"></i>
                    @(isArabic ? "حفظ المواعيد" : "Save Appointments")
                </button>
            </div>
        </div>
    </div>
</div>



<style>
    /* إجبار الجدول على أخذ العرض الكامل */
    #StudentsTable {
        width: 100% !important;
        margin: 0 auto;
    }

    /* تحسين شكل الـ Card وتقليل الفراغات الجانبية */
    .card-body {
        padding: 1.5rem !important;
    }

    /* تنسيق شريط البحث ليكون أقرب للجدول */
    .dataTables_filter {
        margin-bottom: 15px;
    }

    /* لضمان توسيط الجدول في الشاشات الكبيرة */
    .table-responsive {
        display: block;
        width: 100%;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }
</style>


@section scripts {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css">

    <script>
        var currentLang = '@currentLang';

        var languageSettings = {
            ar: {
                processing: "جاري التحميل...",
                search: "بحث:",
                lengthMenu: "_MENU_",
                info: "عرض _START_ إلى _END_ من _TOTAL_",
                zeroRecords: "لم يتم العثور على نتائج",
                paginate: { next: "»", previous: "«" }
            },
            en: {
                processing: "Loading...",
                search: "Search:",
                lengthMenu: "_MENU_",
                info: "Showing _START_ to _END_ of _TOTAL_",
                zeroRecords: "No matching records found",
                paginate: { next: "»", previous: "«" }
            }
        };

        $(document).ready(function () {
            $('#StudentsTable').DataTable({
                processing: true,
                serverSide: true,
                stateSave: true,
                ordering: true,
                stateSave: true,
                "order": [[1, "desc"]],
                ajax: {
                    url: '@Url.Action("GetStudents", "Student", new { area = "Instructor" })',
                    type: 'POST',
                    data: function(d) { d.language = currentLang; }
                },
                columns: [
                    {
                        data: null,
                        width:"10%",
                        orderable: false,
                        render: function (data, type, row, meta) {
                            return `<span class="text-muted small">${meta.row + meta.settings._iDisplayStart + 1}</span>`;
                        }
                    },
                    {
                        data: 'name',
                        width:"50%",
                        render: function (data, type, row) {
                            return `<i class="fas fa-user-circle me-1 icon-primary" style="opacity:0.7"></i> ${data}
                                    <br><small class="text-muted"><i class="fas fa-book me-1 text-orange" style="opacity:0.7"></i>${row.courseName}</small>`;
                        }
                    },
                    {
                        data: 'timesCount',
                        width: "20%",
                        className: 'text-center',
                        render: function (data, type, row) {
                            return `<span class="badge bg-soft-orange text-orange fw-bold" style="font-size: 0.9rem;">
                                        <i class="fas fa-clock me-1"></i> ${data}
                                    </span>`;
                        }
                    },
                    {
                        data: null,
                        width: "20%",
                        orderable: false,
                        className: 'text-center',
                        render: function (data, type, row) {
                            return `<button class="btn btn-sm btn-orange-custom" onclick="openAppointmentModal('${row.id}', '${row.name}', ${row.courseId})">
                                        <i class="fas fa-calendar-plus me-1"></i>
                                        ${currentLang === 'ar' ? 'إضافة ميعاد' : 'Add Appointment'}
                                    </button>`;
                        }
                    }
                
                ],
                language: languageSettings[currentLang],
                pageLength: 10,
                responsive: true,
                dom: "<'row'<'col-sm-12 col-md-6'l><'col-sm-12 col-md-6'f>>" +
                     "<'row'<'col-sm-12'tr>>" +
                     "<'row'<'col-sm-12 col-md-5'i><'col-sm-12 col-md-7'p>>",
            });
        });







        var maxSessions = 0;
        var currentStudentId = '';
        var selectedStudentIds = [];
        var slots = [];

        function openAppointmentModal(studentId, studentName, courseId) {
            currentStudentId = studentId;
            selectedStudentIds = [studentId]; // الطالب الأساسي دايماً موجود
            slots = [];
            $('#slotsContainer').empty();
            $('#modalStudentName').text(studentName);
            $('#sharedMeetingLink').val('');
    
            $('#extraStudentsSection').hide();
            $('#selectedStudentsTags').empty();
            $('#modalCourseSelect').empty().append(`<option value="${courseId}">${courseId}</option>`);
            $('#modalCourseSelect').val(courseId);

            //  الـ TimesCount
            $.get('@Url.Action("GetStudentTimesCount", "Student", new { area = "Instructor" })',
                { studentId: studentId },
                function(res) {
                    maxSessions = res.timesCount;
                    updateCounters();
                }
            );

            //  الكورسات المشتركة
   
            loadExtraStudents(courseId);
            new bootstrap.Modal(document.getElementById('appointmentModal')).show();
        }

        
        function loadExtraStudents(courseId) {
            $('#extraStudentsSection').show();

            if ($('#extraStudentsSelect').hasClass('select2-hidden-accessible'))
                $('#extraStudentsSelect').select2('destroy');

            $('#extraStudentsSelect').select2({
                placeholder: currentLang === 'ar' ? 'ابحث عن طالب...' : 'Search student...',
                allowClear: true,
                width: '100%',
                dropdownParent: $('#appointmentModal'),
                ajax: {
                    url: '@Url.Action("SearchStudentsForAppointment", "Student", new { area = "Instructor" })',
                    dataType: 'json',
                    delay: 300,
                    data: params => ({
                        term: params.term,
                        courseId: courseId,
                        excludeStudentId: currentStudentId
                    }),
                    processResults: data => ({ results: data })
                }
            });
            $('#extraStudentsSelect').off('select2:select').on('select2:select', function(e) {
                var sId = e.params.data.id;
                var sName = e.params.data.text;
                if (!selectedStudentIds.includes(sId)) {
                    selectedStudentIds.push(sId);
                    addStudentTag(sId, sName);
                }
            });
        }



        function addStudentTag(studentId, studentName) {
            var tag = `<span class="badge bg-light border text-dark px-3 py-2" id="tag-${studentId}">
                            <i class="fas fa-user text-orange me-1"></i>${studentName}
                            <button type="button" class="btn-close btn-close-sm ms-1" style="font-size:0.6rem"
                                    onclick="removeStudentTag('${studentId}')"></button>
                       </span>`;
            $('#selectedStudentsTags').append(tag);
        }

        function removeStudentTag(studentId) {
            selectedStudentIds = selectedStudentIds.filter(id => id !== studentId && id !== currentStudentId);
            selectedStudentIds.unshift(currentStudentId); // الطالب الأساسي دايماً موجود
            $(`#tag-${studentId}`).remove();
        }

        function updateCounters() {
            var remaining = maxSessions - slots.length;
            $('#remainingCount').text(remaining < 0 ? 0 : remaining);
            $('#slotsCount').text(slots.length);
        }

        function addSlot() {
            var slotIndex = slots.length;
            slots.push({});

            var slotHtml = `
                <div class="slot-item border rounded-3 p-3 mb-3" id="slot-${slotIndex}">
                    <div class="d-flex justify-content-between align-items-center mb-2">
                        <span class="fw-bold small text-orange">
                            <i class="fas fa-calendar me-1"></i>
                            ${currentLang === 'ar' ? 'ميعاد' : 'Appointment'} #${slotIndex + 1}
                        </span>
                        <button type="button" class="btn btn-sm btn-light border text-danger"
                                onclick="removeSlot(${slotIndex})">
                            <i class="fas fa-trash"></i>
                        </button>
                    </div>
                    <div class="row g-2">
                               <div class="col-md-6">
                                    <label class="small text-muted mb-1">${currentLang === 'ar' ? 'التاريخ' : 'Date'}</label>
                                    <div class="d-flex align-items-center gap-2">
                                        <input type="date" class="form-control slot-date" data-index="${slotIndex}"
                                               min="${new Date().toISOString().split('T')[0]}"
                                               onchange="updateDayName(this)">
                                        <span class="slot-day-name fw-bold text-orange small" style="white-space:nowrap;min-width:50px"></span>
                                    </div>
                                </div>
                                                <div class="col-md-6">
                            <label class="small text-muted mb-1">${currentLang === 'ar' ? 'الوقت' : 'Time'}</label>
                            <input type="time" class="form-control slot-time" data-index="${slotIndex}">
                        </div>
                    </div>
                </div>`;

            $('#slotsContainer').append(slotHtml);
            updateCounters();
        }

        function removeSlot(index) {
            $(`#slot-${index}`).remove();
            slots = [];
            $('.slot-item').each(function(i) {
                $(this).attr('id', `slot-${i}`);
                $(this).find('.slot-date').attr('data-index', i);
                $(this).find('.slot-time').attr('data-index', i);
                $(this).find('button[onclick]').attr('onclick', `removeSlot(${i})`);
                $(this).find('.fw-bold.small').html(
                    `<i class="fas fa-calendar me-1"></i> ${currentLang === 'ar' ? 'ميعاد' : 'Appointment'} #${i + 1}`
                );
                slots.push({});
            });
            updateCounters();
        }

        $('#addSlotBtn').on('click', addSlot);
        $('#removeSlotBtn').on('click', function() {
            if (slots.length > 0) removeSlot(slots.length - 1);
        });

        $('#saveAppointmentsBtn').on('click', function() {
            var meetingLink = $('#sharedMeetingLink').val();
            var duration = parseInt($('#sharedDuration').val()) || 1;
            var courseId = $('#modalCourseSelect').val();

            if (!courseId) {
                Swal.fire('', currentLang === 'ar' ? 'اختر الكورس' : 'Select a course', 'warning');
                return;
            }
            if (!meetingLink) {
                Swal.fire('', currentLang === 'ar' ? 'أدخل رابط الاجتماع' : 'Enter meeting link', 'warning');
                return;
            }
            if (slots.length === 0) {
                Swal.fire('', currentLang === 'ar' ? 'أضف ميعاد واحد على الأقل' : 'Add at least one appointment', 'warning');
                return;
            }

            var appointments = [];
            var valid = true;

            $('.slot-item').each(function() {
                var date = $(this).find('.slot-date').val();
                var time = $(this).find('.slot-time').val();
                if (!date || !time) { valid = false; return false; }
                appointments.push({
                    startDateTime: date + 'T' + time,
                    durationInHours: duration,
                    meetingLink: meetingLink
                });
            });

            if (!valid) {
                Swal.fire('', currentLang === 'ar' ? 'أكمل بيانات كل المواعيد' : 'Complete all appointment fields', 'warning');
                return;
            }

            var btn = $(this);
            btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

            $.ajax({
                url: '/Instructor/Student/CreateBulk',
                type: 'POST',
                contentType: 'application/json',
                data: JSON.stringify({
                    studentIds: selectedStudentIds,
                    courseId: parseInt(courseId),
                    appointments: appointments
                }),
                success: function(res) {
                    btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (currentLang === 'ar' ? 'حفظ المواعيد' : 'Save Appointments'));
                    if (res.success) {
                        bootstrap.Modal.getInstance(document.getElementById('appointmentModal')).hide();
                        Swal.fire({ icon: 'success', title: currentLang === 'ar' ? 'تم بنجاح' : 'Success', text: res.message, timer: 1500, showConfirmButton: false });
                    } else {
                        Swal.fire('Error', res.message, 'error');
                    }
                },
                error: function() {
                    btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (currentLang === 'ar' ? 'حفظ المواعيد' : 'Save Appointments'));
                    Swal.fire('Error', currentLang === 'ar' ? 'فشل الاتصال' : 'Connection failed', 'error');
                }
            });
        });

        function updateDayName(input) {
            var daySpan = $(input).siblings('.slot-day-name');
            if (!input.value) { daySpan.text(''); return; }

            var date = new Date(input.value);
            var days = currentLang === 'ar'
                ? ['الأحد', 'الاثنين', 'الثلاثاء', 'الأربعاء', 'الخميس', 'الجمعة', 'السبت']
                : ['Sunday', 'Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday'];

            daySpan.text(days[date.getDay()]);
        }

    </script>
}