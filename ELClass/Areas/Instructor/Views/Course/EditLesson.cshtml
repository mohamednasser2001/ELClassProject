@using Models
@model Lesson
@{
    var isArabic = ELClass.services.CultureHelper.IsArabic;
}

<div class="bg-white dark:bg-slate-900 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="w-full px-2 sm:px-6 py-4">
        <div class="flex items-center gap-4 mb-6 bg-slate-50 dark:bg-slate-800 p-4 rounded-lg shadow-sm">
            <a asp-action="Details" asp-route-id="@Model.CourseId" class="p-2 bg-white dark:bg-slate-700 rounded-full shadow-sm hover:text-blue-700 transition-colors flex items-center justify-center">
                <span class="material-icons">@(isArabic ? "arrow_forward" : "arrow_back")</span>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-800 dark:text-white flex items-center gap-2">
                    <i class="fas fa-edit text-blue-800"></i>
                    @(isArabic ? $"تعديل محاضرة: {Model.Title}" : $"Edit Lesson: {Model.Title}")
                </h1>
                <p class="text-gray-500 text-sm mt-1">
                    @(isArabic ? "تعديل بيانات وموارد المحاضرة" : "Edit lesson details and resources")
                </p>
            </div>
        </div>

        <div class="bg-white dark:bg-slate-800 rounded-lg shadow-md border border-slate-200 dark:border-slate-700 overflow-hidden">
            <form asp-action="EditLesson" method="post" enctype="multipart/form-data" class="p-4 md:p-6 space-y-5">
                <input type="hidden" asp-for="Id" />
                <input type="hidden" asp-for="CourseId" />

                <div>
                    <label asp-for="Title" class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-1.5">@(isArabic ? "عنوان المحاضرة" : "Lesson Title")</label>
                    <input asp-for="Title" class="w-full rounded-md border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-white focus:ring-blue-800 focus:border-blue-800 text-sm" />
                </div>

                <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                    
                    @* قسم المواد العلمية - Materials *@
                    <div class="space-y-3">
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
                            <i class="fas fa-file-upload text-orange-500 me-1"></i>
                            @(isArabic ? "ملفات المحاضرة" : "Lesson Materials")
                        </label>

                        @if (Model.LessonMaterials.Any())
                        {
                            <div class="bg-slate-50 dark:bg-slate-700/50 p-3 rounded-lg space-y-2">
                                <p class="text-[10px] font-bold text-slate-400 uppercase">
                                    @(isArabic ? "المواد الحالية:" : "Current Materials:")
                                </p>
                                @foreach (var m in Model.LessonMaterials)
                                {
                                    var ext = m.FileUrl.Split('.').Last().ToLower();
                                    <div class="flex items-center gap-2 text-xs">
                                        <i class="fas fa-file-@(ext == "pdf" ? "pdf text-red-400" : "alt text-blue-400")"></i>
                                        <a href="/uploads/materials/@m.FileUrl" target="_blank"
                                               class="text-blue-600 hover:underline truncate max-w-[180px]">
                                            Material .@ext
                                        </a>
                                    </div>
                                }
                                <p class="text-[10px] text-slate-400 italic mt-1">
                                    @(isArabic ? "لو رفعت ملفات جديدة هتتبدل" : "Uploading new files will replace these")
                                </p>
                            </div>
                        }

                        <input type="file" name="materials" multiple
                               class="block w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:bg-blue-50 file:text-blue-700 border border-dashed border-slate-300 p-2 rounded-lg">
                    </div>

                    @* قسم الواجبات - Assignments *@
                    <div class="space-y-3">
                        <label class="block text-sm font-bold text-slate-700 dark:text-slate-300">
                            <i class="fas fa-tasks text-blue-500 me-1"></i>
                            @(isArabic ? "ملفات الواجبات" : "Assignment Files")
                        </label>

                        @if (Model.LessonAssignments.Any())
                        {
                            <div class="bg-slate-50 dark:bg-slate-700/50 p-3 rounded-lg space-y-2">
                                <p class="text-[10px] font-bold text-slate-400 uppercase">
                                    @(isArabic ? "الواجبات الحالية:" : "Current Assignments:")
                                </p>
                                @foreach (var a in Model.LessonAssignments)
                                {
                                    var ext = a.FileUrl.Split('.').Last().ToLower();
                                    <div class="flex items-center gap-2 text-xs">
                                        <i class="fas fa-file-@(ext == "pdf" ? "pdf text-red-400" : "alt text-green-400")"></i>
                                        <a href="/uploads/assignments/@a.FileUrl" target="_blank"
                                               class="text-blue-600 hover:underline truncate max-w-[180px]">
                                            Assignment .@ext
                                        </a>
                                    </div>
                                }
                                <p class="text-[10px] text-slate-400 italic mt-1">
                                    @(isArabic ? "لو رفعت ملفات جديدة هتتبدل" : "Uploading new files will replace these")
                                </p>
                            </div>
                        }

                        <input type="file" name="assignments" multiple
                               class="block w-full text-xs text-slate-500 file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:bg-blue-50 file:text-blue-700 border border-dashed border-slate-300 p-2 rounded-lg">
                    </div>

                </div>

                <div class="flex items-center justify-end gap-3 pt-5 border-t border-slate-100 dark:border-slate-700">
                    <a asp-action="Details" asp-route-id="@Model.CourseId" class="text-slate-500 hover:text-slate-800 text-sm font-medium transition-colors">
                        @(isArabic ? "إلغاء" : "Cancel")
                    </a>
                    <button type="submit" class="bg-blue-800 hover:bg-blue-700 text-white px-6 py-2 rounded-md font-bold shadow-md transition-all active:scale-95 text-sm">
                        @(isArabic ? "تحديث المحاضرة" : "Update Lesson")
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}