@using Models
@using ELClass.services
@model Lesson

@{
    ViewData["Title"] = "Add New Lesson";
    var isArabic = CultureHelper.IsArabic;
}

<div class="p-6 bg-gray-50 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">


    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div class="flex items-center gap-3">
            <a asp-action="Details" asp-route-id="@Model.CourseId"
                   class="p-2 bg-white border border-gray-100 rounded-lg shadow-sm hover:bg-gray-50 text-gray-500 hover:text-blue-700 transition-colors">
                <i class="fas fa-arrow-@(isArabic ? "right" : "left") text-sm"></i>
            </a>
            <div>
                <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                    <i class="fas fa-plus-circle text-blue-800"></i>
                    @(isArabic ? "إضافة محاضرة جديدة" : "Add New Lesson")
                </h1>
                <p class="text-gray-500 text-sm mt-1">
                    @(isArabic ? "إدارة موارد الكورس" : "Course Resource Management")
                </p>
            </div>
        </div>
    </div>


    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <form asp-action="CreateLesson" method="post" class="p-6 space-y-6">

            <input type="hidden" asp-for="CourseId" />

        
            <div>
                <label asp-for="Title" class="block text-sm font-semibold text-gray-700 mb-1.5">
                    <i class="fas fa-book text-xs text-blue-400 me-1"></i>
                    @(isArabic ? "عنوان المحاضرة" : "Lesson Title")
                </label>
                <input asp-for="Title"
                       placeholder="@(isArabic ? "أدخل اسم المحاضرة..." : "Enter lesson name...")"
                       class="w-full rounded-lg border-gray-200 bg-gray-50 focus:ring-blue-800 focus:border-blue-800 text-sm" />
                <span asp-validation-for="Title" class="text-red-500 text-xs mt-1 block"></span>
            </div>


            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="LectureDate" class="block text-sm font-semibold text-gray-700 mb-1.5">
                        <i class="far fa-calendar-alt text-xs text-blue-400 me-1"></i>
                        @(isArabic ? "تاريخ المحاضرة" : "Lecture Date")
                    </label>
                    <input asp-for="LectureDate" type="date"
                           class="w-full rounded-lg border-gray-200 bg-gray-50 focus:ring-blue-800 focus:border-blue-800 text-sm" />
                </div>

                <div>
                    <label asp-for="DriveLink" class="block text-sm font-semibold text-gray-700 mb-1.5">
                        <i class="fab fa-google-drive text-xs text-blue-400 me-1"></i>
                        @(isArabic ? "رابط جوجل درايف" : "Google Drive Link")
                    </label>
                    <div class="relative">
                        <span class="absolute @(isArabic ? "right-3" : "left-3") top-2.5 text-gray-400">
                            <i class="fas fa-link text-xs"></i>
                        </span>
                        <input asp-for="DriveLink"
                               placeholder="@(isArabic ? "الصق الرابط هنا..." : "Paste link here...")"
                               class="w-full @(isArabic ? "pr-9" : "pl-9") rounded-lg border-gray-200 bg-gray-50 focus:ring-blue-800 focus:border-blue-800 text-sm" />
                    </div>
                </div>
            </div>

    
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
                <div>
                    <label asp-for="LecturePdfUrl" class="block text-sm font-semibold text-gray-700 mb-1.5">
                        <i class="fas fa-file-pdf text-xs text-orange-400 me-1"></i>
                        @(isArabic ? "رابط PDF المحاضرة" : "Lecture PDF URL")
                    </label>
                    <div class="relative">
                        <span class="absolute @(isArabic ? "right-3" : "left-3") top-2.5 text-orange-400">
                            <i class="fas fa-file-pdf text-xs"></i>
                        </span>
                        <input asp-for="LecturePdfUrl"
                               placeholder="@(isArabic ? "رابط الـ PDF" : "Link to PDF")"
                               class="w-full @(isArabic ? "pr-9" : "pl-9") rounded-lg border-gray-200 bg-gray-50 focus:ring-blue-800 focus:border-blue-800 text-sm" />
                    </div>
                </div>

                <div>
                    <label asp-for="AssignmentPdfUrl" class="block text-sm font-semibold text-gray-700 mb-1.5">
                        <i class="fas fa-file-alt text-xs text-blue-400 me-1"></i>
                        @(isArabic ? "رابط PDF الواجب" : "Assignment PDF URL")
                    </label>
                    <div class="relative">
                        <span class="absolute @(isArabic ? "right-3" : "left-3") top-2.5 text-blue-400">
                            <i class="fas fa-file-alt text-xs"></i>
                        </span>
                        <input asp-for="AssignmentPdfUrl"
                               placeholder="@(isArabic ? "رابط الواجب" : "Link to Task")"
                               class="w-full @(isArabic ? "pr-9" : "pl-9") rounded-lg border-gray-200 bg-gray-50 focus:ring-blue-800 focus:border-blue-800 text-sm" />
                    </div>
                </div>
            </div>


            <div class="flex items-center justify-end gap-3 pt-5 border-t border-gray-100">
                <a asp-action="Details" asp-route-id="@Model.CourseId"
                       class="px-5 py-2.5 text-sm font-medium text-gray-500 hover:text-gray-800 border border-gray-200 rounded-lg bg-white hover:bg-gray-50 transition-colors no-underline">
                    @(isArabic ? "إلغاء" : "Cancel")
                </a>
                <button type="submit"
                        class="inline-flex items-center px-5 py-2.5 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 text-sm">
                    <i class="fas fa-save text-sm"></i>
                    @(isArabic ? "إضافة المحاضرة" : "Create Lesson")
                </button>
            </div>

        </form>
    </div>
</div>

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}