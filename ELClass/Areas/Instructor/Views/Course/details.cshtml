@{
    if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        Layout = "_AdminLayout";
    else
        Layout = "_InstrcutorLayout";
}

@using Models
@using ELClass.services
@model IEnumerable<Lesson>

@{
    ViewData["Title"] = "Lecture Management";
    var isArabic = CultureHelper.IsArabic;
    int index = 1;
}

<div class="p-6 bg-gray-50 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">


    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center">
                    <i class="fas fa-user-tie text-blue-800 text-xl"></i>
                </div>
        
                <div>
                    <h1 class="text-2xl font-bold text-gray-800">
                        @(isArabic ? "إدارة المحاضرات" : "Lecture Management")
                    </h1>
                    <p class="text-gray-500 text-sm mt-1">
                        @(isArabic ? "الكورس: " : "Course: ")
                        <span class="font-semibold text-gray-700">@ViewData["CourseTitle"]</span>
                    </p>
                </div>
            </div>

        </div>
        <a asp-action="CreateLesson" asp-route-courseId="@ViewData["CourseId"]"
               class="inline-flex items-center px-5 py-2.5 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 w-fit no-underline">
            <i class="fas fa-plus text-sm"></i>
            @(isArabic ? "إضافة محاضرة" : "Add Lecture")
        </a>
    </div>


    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 font-semibold border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-center">#</th>
                        <th class="px-6 py-4 text-@(isArabic ? "right" : "left")">
                            @(isArabic ? "اسم المحاضرة" : "Name")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "رابط الدرايف" : "Drive Link")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "الملفات" : "PDFs")
                        </th>
                        <th class="px-6 py-4 text-@(isArabic ? "right" : "left")">
                            @(isArabic ? "تاريخ المحاضرة" : "Lecture Date")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "الإجراءات" : "Actions")
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        <tr class="hover:bg-blue-50/30 transition-colors">

      
                            <td class="px-6 py-4 text-center text-gray-400 font-medium">@(index++)</td>

     
                            <td class="px-6 py-4">
                                <span class="text-gray-900 font-bold flex items-center gap-2">
                                    <i class="fas fa-book text-xs text-blue-400"></i>
                                    @item.Title
                                </span>
                            </td>

              
                            <td class="px-6 py-4 text-center">
                                @if (!string.IsNullOrEmpty(item.DriveLink))
                                {
                                    <a href="@item.DriveLink" target="_blank"
                                           class="inline-flex items-center justify-center p-2 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors border border-blue-100"
                                           title="@(isArabic ? "فتح الرابط" : "Open Link")">
                                        <i class="fas fa-cloud-download-alt text-sm"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-gray-300">—</span>
                                }
                            </td>

                            <td class="px-6 py-4 text-center">
                                <div class="flex justify-center gap-2">
                                    @if (!string.IsNullOrEmpty(item.LecturePdfUrl))
                                    {
                                        <a href="@item.LecturePdfUrl" target="_blank"
                                               class="inline-flex items-center justify-center p-2 rounded-lg bg-orange-50 text-orange-500 hover:bg-orange-100 transition-colors border border-orange-100"
                                               title="@(isArabic ? "ملف المحاضرة" : "Lecture PDF")">
                                            <i class="fas fa-file-pdf text-sm"></i>
                                        </a>
                                    }
                                    @if (!string.IsNullOrEmpty(item.AssignmentPdfUrl))
                                    {
                                        <a href="@item.AssignmentPdfUrl" target="_blank"
                                               class="inline-flex items-center justify-center p-2 rounded-lg bg-blue-50 text-blue-500 hover:bg-blue-100 transition-colors border border-blue-100"
                                               title="@(isArabic ? "ملف الواجب" : "Assignment PDF")">
                                            <i class="fas fa-file-alt text-sm"></i>
                                        </a>
                                    }
                                    @if (string.IsNullOrEmpty(item.LecturePdfUrl) && string.IsNullOrEmpty(item.AssignmentPdfUrl))
                                    {
                                        <span class="text-gray-300">—</span>
                                    }
                                </div>
                            </td>

                            <td class="px-6 py-4">
                                <span class="text-gray-700 font-medium flex items-center gap-1">
                                    <i class="far fa-calendar-alt text-xs text-gray-400"></i>
                                    @{
                                        var culture = isArabic
                                            ? new System.Globalization.CultureInfo("ar-EG")
                                            : System.Globalization.CultureInfo.InvariantCulture;
                                    }
                                    @item.LectureDate.ToString("dddd, dd MMM yyyy", culture)
                                </span>
                            </td>

        
                            <td class="px-6 py-4">
                                <div class="flex justify-center gap-2">
                                    <a asp-action="EditLesson" asp-route-id="@item.Id"
                                           class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition-colors border border-gray-100"
                                           title="@(isArabic ? "تعديل" : "Edit")">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button"
                                            onclick="confirmDelete('@item.Id')"
                                            class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors border border-gray-100"
                                            title="@(isArabic ? "حذف" : "Delete")">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center text-gray-400">
                                <i class="fas fa-chalkboard text-4xl mb-3 block text-gray-200"></i>
                                @(isArabic ? "لا توجد محاضرات بعد" : "No lectures found")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

@section Scripts {
    <script>
        function confirmDelete(id) {
        const isAr = "@isArabic".toLowerCase() === "true";

        Swal.fire({
        title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
        text: isAr ? 'سيتم حذف المحاضرة نهائياً!' : 'This lesson will be permanently deleted!',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, delete it!',
        cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Instructor/Course/DeleteLesson/' + id;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '__RequestVerificationToken';
        tokenInput.value = token;

        form.appendChild(tokenInput);
        document.body.appendChild(form);
        form.submit();
        }
        });
        }
    </script>
}