@{
    if (User.IsInRole("Admin") || User.IsInRole("SuperAdmin"))
        Layout = "_AdminLayout";
    else
        Layout = "_InstrcutorLayout";
}

@using Models
@using ELClass.services
@model IEnumerable<Lesson>

@{
    ViewData["Title"] = "Lecture Management";
    var isArabic = CultureHelper.IsArabic;
    int index = 1;
}

<div class="p-6 bg-gray-50 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">


    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
            <div class="flex items-start gap-4">
                <div class="flex-shrink-0 w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center">
                    <i class="fas fa-user-tie text-blue-800 text-xl"></i>
                </div>
        
                <div>
                    <h1 class="text-2xl font-bold text-gray-800">
                        @(isArabic ? "إدارة المحاضرات" : "Lecture Management")
                    </h1>
                    <p class="text-gray-500 text-sm mt-1">
                        @(isArabic ? "الكورس: " : "Course: ")
                        <span class="font-semibold text-gray-700">@ViewData["CourseTitle"]</span>
                    </p>
                </div>
            </div>

        </div>
        <a asp-action="CreateLesson" asp-route-courseId="@ViewData["CourseId"]"
               class="inline-flex items-center px-5 py-2.5 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 w-fit no-underline">
            <i class="fas fa-plus text-sm"></i>
            @(isArabic ? "إضافة محاضرة" : "Add Lecture")
        </a>
    </div>


    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm">
                <thead class="bg-gray-50 text-gray-600 font-semibold border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-center">#</th>
                        <th class="px-6 py-4 text-@(isArabic ? "right" : "left")">
                            @(isArabic ? "اسم المحاضرة" : "Name")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "رابط الدرايف" : "Drive Link")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "الملفات" : "PDFs")
                        </th>
                        <th class="px-6 py-4 text-@(isArabic ? "right" : "left")">
                            @(isArabic ? "تاريخ المحاضرة" : "Lecture Date")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "الطلاب" : "Students")
                        </th>
                        <th class="px-6 py-4 text-center">
                            @(isArabic ? "الإجراءات" : "Actions")
                        </th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model)
                    {
                        var materialsJson = System.Text.Json.JsonSerializer.Serialize(
                           item.LessonMaterials.Select(m => m.FileUrl).ToList()
                       );
                        var assignmentsJson = System.Text.Json.JsonSerializer.Serialize(
                            item.LessonAssignments.Select(a => a.FileUrl).ToList()
                        );


                        var studentsJson = System.Text.Json.JsonSerializer.Serialize(
                            item.StudentLessons.Select(sl => new
                            {
                                id = sl.Id,
                                studentId = sl.StudentId,
                                name = isArabic ? sl.Student?.NameAr : sl.Student?.NameEn,
                                degree = sl.Degree
                            }).ToList()
                        );

                        <tr class="hover:bg-blue-50/30 transition-colors"
                            data-lesson-id="@item.Id"
                            data-materials="@materialsJson"
                            data-assignments="@assignmentsJson"
                            data-students="@studentsJson">

      
                            <td class="px-6 py-4 text-center text-gray-400 font-medium">@(index++)</td>

     
                            <td class="px-6 py-4">
                                <span class="text-gray-900 font-bold flex items-center gap-2">
                                    <i class="fas fa-book text-xs text-blue-400"></i>
                                    @item.Title
                                </span>
                            </td>

              
                            <td class="px-6 py-4 text-center">
                                @if (!string.IsNullOrEmpty(item.DriveLink))
                                {
                                    <a href="@item.DriveLink" target="_blank"
                                           class="inline-flex items-center justify-center p-2 rounded-lg bg-blue-50 text-blue-600 hover:bg-blue-100 transition-colors border border-blue-100"
                                           title="@(isArabic ? "فتح الرابط" : "Open Link")">
                                        <i class="fas fa-cloud-download-alt text-sm"></i>
                                    </a>
                                }
                                else
                                {
                                    <span class="text-gray-300">—</span>
                                }
                            </td>

                            <td class="px-6 py-4 text-center">
                                @{
                                    var hasMaterials = item.LessonMaterials.Any();
                                    var hasAssignments = item.LessonAssignments.Any();
                                }
                                @if (hasMaterials || hasAssignments)
                                {
                                    <button onclick="openFilesModal(@item.Id, '@item.Title')"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-blue-50 text-blue-700 hover:bg-blue-100 rounded-lg transition-colors border border-blue-100 text-xs font-semibold">
                                        <i class="fas fa-folder-open text-xs"></i>
                                        @(isArabic ? "عرض الملفات" : "View Files")
                                        <span class="bg-blue-200 text-blue-800 rounded-full px-1.5 py-0.5 text-[10px] font-bold">
                                            @(item.LessonMaterials.Count + item.LessonAssignments.Count)
                                        </span>
                                    </button>
                                }
                                else
                                {
                                    <span class="text-gray-300">—</span>
                                }
                            </td>

                            <td class="px-6 py-4">
                                <span class="text-gray-700 font-medium flex items-center gap-1">
                                    <i class="far fa-calendar-alt text-xs text-gray-400"></i>
                                    @{
                                        var culture = isArabic
                                            ? new System.Globalization.CultureInfo("ar-EG")
                                            : System.Globalization.CultureInfo.InvariantCulture;
                                    }
                                    @item.LectureDate.ToString("dddd, dd MMM yyyy", culture)
                                </span>
                            </td>

                            <td class="px-6 py-4 text-center">
                                @{
                                    var studentCount = item.StudentLessons.Count;
                                }
                                @if (studentCount > 0)
                                {
                                    <button onclick="openStudentsModal(@item.Id, '@item.Title')"
                                            class="inline-flex items-center gap-1.5 px-3 py-1.5 bg-green-50 text-green-700 hover:bg-green-100 rounded-full transition-colors border border-green-100 text-xs font-semibold">
                                        <i class="fas fa-users text-xs"></i>
                                        @studentCount
                                    </button>
                                }
                                else
                                {
                                    <span class="text-gray-300 text-xs">—</span>
                                }
                            </td>


                            <td class="px-6 py-4">
                                <div class="flex justify-center gap-2">
                                    <a asp-action="EditLesson" asp-route-id="@item.Id"
                                           class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition-colors border border-gray-100"
                                           title="@(isArabic ? "تعديل" : "Edit")">
                                        <i class="fas fa-edit"></i>
                                    </a>
                                    <button type="button"
                                            onclick="confirmDelete('@item.Id')"
                                            class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors border border-gray-100"
                                            title="@(isArabic ? "حذف" : "Delete")">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }

                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="px-6 py-16 text-center text-gray-400">
                                <i class="fas fa-chalkboard text-4xl mb-3 block text-gray-200"></i>
                                @(isArabic ? "لا توجد محاضرات بعد" : "No lectures found")
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

<div class="modal fade" id="filesModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header border-b border-gray-100">
                <h5 class="modal-title flex items-center gap-2 text-gray-800 font-bold text-sm">
                    <i class="fas fa-folder-open text-blue-800"></i>
                    <span id="filesModalTitle"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4 space-y-4">

                <div id="materialsSection">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2 flex items-center gap-1">
                        <i class="fas fa-file-upload text-orange-400"></i>
                        @(isArabic ? "ملفات المحاضرة" : "Lesson Materials")
                    </p>
                    <div id="materialsList" class="space-y-2"></div>
                </div>

                <hr class="border-gray-100" id="filesDivider">

       
                <div id="assignmentsSection">
                    <p class="text-xs font-bold text-gray-500 uppercase tracking-wide mb-2 flex items-center gap-1">
                        <i class="fas fa-tasks text-blue-400"></i>
                        @(isArabic ? "ملفات الواجبات" : "Assignment Files")
                    </p>
                    <div id="assignmentsList" class="space-y-2"></div>
                </div>

            </div>

            <div class="modal-footer border-t border-gray-100">
                <button type="button" class="btn btn-light border px-4 rounded-lg" data-bs-dismiss="modal">
                    @(isArabic ? "إغلاق" : "Close")
                </button>
            </div>
        </div>
    </div>
</div>




<div class="modal fade" id="studentsModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content border-0 shadow-lg">

            <div class="modal-header border-b border-gray-100">
                <h5 class="modal-title flex items-center gap-2 text-gray-800 font-bold text-sm">
                    <i class="fas fa-users text-green-600"></i>
                    <span id="studentsModalTitle"></span>
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>

            <div class="modal-body p-4">
                <div id="studentsEvalList" class="space-y-2"></div>
            </div>

            <div class="modal-footer border-t border-gray-100">
                <button type="button" class="btn btn-light border px-4 rounded-lg" data-bs-dismiss="modal">
                    @(isArabic ? "إغلاق" : "Close")
                </button>
                <button type="button" id="saveStudentDegreesBtn"
                        class="inline-flex items-center px-5 py-2 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 text-sm">
                    <i class="fas fa-save me-1"></i>
                    @(isArabic ? "حفظ التعديلات" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
</div>

@Html.AntiForgeryToken()
<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

@section Scripts {
    <script>
        function confirmDelete(id) {
        const isAr = "@isArabic".toLowerCase() === "true";

        Swal.fire({
        title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
        text: isAr ? 'سيتم حذف المحاضرة نهائياً!' : 'This lesson will be permanently deleted!',
        icon: 'warning',
        showCancelButton: true,
        confirmButtonColor: '#d33',
        cancelButtonColor: '#3085d6',
        confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, delete it!',
        cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
        }).then((result) => {
        if (result.isConfirmed) {
        const form = document.createElement('form');
        form.method = 'POST';
        form.action = '/Instructor/Course/DeleteLesson/' + id;

        const token = document.querySelector('input[name="__RequestVerificationToken"]').value;
        const tokenInput = document.createElement('input');
        tokenInput.type = 'hidden';
        tokenInput.name = '__RequestVerificationToken';
        tokenInput.value = token;

        form.appendChild(tokenInput);
        document.body.appendChild(form);
        form.submit();
        }
        });
        }


        var isAr = "@isArabic".toLowerCase() === "true";
        var uploadsBase = '/uploads/';

        function openFilesModal(lessonId, lessonTitle) {
        document.getElementById('filesModalTitle').textContent = lessonTitle;

        // اجيب البيانات من الـ data attributes على الـ row
        var row = document.querySelector('tr[data-lesson-id="' + lessonId + '"]');
        var materials = JSON.parse(row.dataset.materials || '[]');
        var assignments = JSON.parse(row.dataset.assignments || '[]');

        renderFilesList('materialsList', 'materialsSection', materials, 'materials', 'orange');
        renderFilesList('assignmentsList', 'assignmentsSection', assignments, 'assignments', 'blue');

        // إخفاء الـ divider لو أحدهم فاضي
        var showDivider = materials.length > 0 && assignments.length > 0;
        document.getElementById('filesDivider').style.display = showDivider ? 'block' : 'none';

        new bootstrap.Modal(document.getElementById('filesModal')).show();
        }

        function renderFilesList(listId, sectionId, files, folder, color) {
        var section = document.getElementById(sectionId);
        var list = document.getElementById(listId);

        if (!files || files.length === 0) {
        section.style.display = 'none';
        return;
        }

        section.style.display = 'block';
        list.innerHTML = '';

        files.forEach(function (fileName, i) {
        var ext = fileName.split('.').pop().toLowerCase();
        var icon = getFileIcon(ext, color);
        var fileUrl = '/uploads/' + folder + '/' + fileName;
        var displayName = (isAr ? 'ملف' : 'File') + ' ' + (i + 1) + ' .' + ext;

        list.innerHTML +=
        '<a href="' + fileUrl + '" target="_blank" ' +
        'class="flex items-center gap-3 p-2.5 rounded-lg border border-gray-100 hover:bg-gray-50 transition-colors group no-underline">' +
        '<div class="w-8 h-8 rounded-lg bg-' + color + '-50 flex items-center justify-center flex-shrink-0">' +
        '<i class="' + icon + ' text-' + color + '-500 text-sm"></i>' +
        '</div>' +
        '<span class="text-gray-700 text-sm font-medium group-hover:text-' + color + '-700 transition-colors">' + displayName + '</span>' +
        '<i class="fas fa-external-link-alt text-xs text-gray-300 group-hover:text-' + color + '-400 ms-auto transition-colors"></i>' +
        '</a>';
        });
        }

        function getFileIcon(ext, color) {
        var icons = {
        'pdf': 'fas fa-file-pdf',
        'doc': 'fas fa-file-word', 'docx': 'fas fa-file-word',
        'xls': 'fas fa-file-excel', 'xlsx': 'fas fa-file-excel',
        'ppt': 'fas fa-file-powerpoint', 'pptx': 'fas fa-file-powerpoint',
        'jpg': 'fas fa-file-image', 'jpeg': 'fas fa-file-image',
        'png': 'fas fa-file-image', 'gif': 'fas fa-file-image',
        'zip': 'fas fa-file-archive', 'rar': 'fas fa-file-archive',
        'mp4': 'fas fa-file-video', 'mp3': 'fas fa-file-audio',
        };
        return icons[ext] || 'fas fa-file';
        }


        var currentLessonId = 0;

        function openStudentsModal(lessonId, lessonTitle) {
        currentLessonId = lessonId;
        document.getElementById('studentsModalTitle').textContent = lessonTitle;

        var row = document.querySelector('tr[data-lesson-id="' + lessonId + '"]');
        var students = JSON.parse(row.dataset.students || '[]');

        var html = '';
        if (!students || students.length === 0) {
        html = '<div class="text-center text-gray-400 py-8">' +
        '<i class="fas fa-users text-3xl mb-2 block text-gray-200"></i>' +
        (isAr ? 'لا يوجد طلاب في هذا الدرس' : 'No students in this lesson') +
        '</div>';
        } else {
        students.forEach(function (s) {
        html +=
        '<div class="flex items-center justify-between p-3 bg-gray-50 rounded-xl border border-gray-100">' +
        '<div class="flex items-center gap-3">' +
        '<div class="w-9 h-9 rounded-full bg-green-100 d-flex align-items-center justify-content-center text-green-700 font-bold text-sm flex-shrink-0">' +
        (s.name ? s.name.charAt(0) : '?') +
        '</div>' +
        '<span class="font-semibold text-gray-800 text-sm">' + (s.name || '—') + '</span>' +
        '</div>' +
        '<div class="d-flex align-items-center gap-2">' +
        '<label class="text-xs text-gray-500 font-medium">' + (isAr ? 'الدرجة' : 'Score') + '</label>' +
        '<input type="number" min="0" max="10" value="' + s.degree + '" ' +
        'data-student-lesson-id="' + s.id + '" ' +
        'data-student-id="' + s.studentId + '" ' +
        'class="student-degree-input form-control form-control-sm text-center rounded-lg border-gray-200" style="width:75px">' +
        '<span class="text-xs text-gray-400">/ 10</span>' +
        '</div>' +
        '</div>';
        });
        }

        document.getElementById('studentsEvalList').innerHTML = html;
        new bootstrap.Modal(document.getElementById('studentsModal')).show();
        }

        $('#saveStudentDegreesBtn').on('click', function () {
        var updates = [];
        $('.student-degree-input').each(function () {
        updates.push({
        studentLessonId: parseInt($(this).data('student-lesson-id')),
        degree: parseFloat($(this).val()) || 0
        });
        });

        if (updates.length === 0) return;

        var btn = $(this);
        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
        url: '/instructor/Course/UpdateStudentDegrees',
        type: 'POST',
        contentType: 'application/json',
        data: JSON.stringify(updates),
        success: function (res) {
        btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (isAr ? 'حفظ التعديلات' : 'Save Changes'));
        if (res.success) {
        Swal.fire({
        icon: 'success',
        title: isAr ? 'تم الحفظ' : 'Saved',
        timer: 1200,
        showConfirmButton: false
        }).then(function () {
        bootstrap.Modal.getInstance(document.getElementById('studentsModal')).hide();
        location.reload();
        });
        } else {
        Swal.fire('Error', res.message, 'error');
        }
        },
        error: function () {
        btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (isAr ? 'حفظ التعديلات' : 'Save Changes'));
        Swal.fire('Error', isAr ? 'فشل الاتصال' : 'Connection failed', 'error');
        }
        });
        });


    </script>
}