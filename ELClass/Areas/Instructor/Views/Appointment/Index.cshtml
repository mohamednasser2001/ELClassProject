@using ELClass.services
@model IEnumerable<Models.Appointment>

@{
    var isArabic = CultureHelper.IsArabic;
}

<div class="p-6 bg-gray-50 min-h-screen" dir="@(isArabic ? "rtl" : "ltr")">
    <div class="flex flex-col md:flex-row md:items-center justify-between mb-8 gap-4">
        <div>
            <h1 class="text-2xl font-bold text-gray-800 flex items-center gap-2">
                <i class="fas fa-calendar-alt text-blue-800"></i>
                @(isArabic ? "إدارة جدول المحاضرات" : "Lectures Schedule Management")
            </h1>
            <p class="text-gray-500 text-sm mt-1">@(isArabic ? "تعديل موعد واحد يطبق على جميع الطلاب المشتركين" : "Editing one appointment applies to all linked students")</p>
        </div>
        @* <a href="/instructor/Appointment/AddNewAppointment" class="inline-flex items-center px-5 py-2.5 bg-blue-800 hover:bg-blue-700 text-white font-medium rounded-lg transition-all shadow-sm gap-2 w-fit">
            <i class="fas fa-plus text-sm"></i>
            @(isArabic ? "إضافة ميعاد جديد" : "Add New Appointment")
        </a> *@
    </div>

    <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
            <table class="w-full text-sm text-right">
                <thead class="bg-gray-50 text-gray-600 font-semibold border-b border-gray-100">
                    <tr>
                        <th class="px-6 py-4 text-center">#</th>
                        <th class="px-6 py-4">@(isArabic ? "الكورس" : "Course")</th>
                        <th class="px-6 py-4">@(isArabic ? "اليوم / الوقت" : "Day / Time")</th>
                        <th class="px-6 py-4 text-center">@(isArabic ? "عدد الطلاب" : "Students")</th>
                        <th class="px-6 py-4">@(isArabic ? "الحالة" : "Status")</th>
                        <th class="px-6 py-4 text-center">@(isArabic ? "الإجراءات" : "Actions")</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-gray-50">
                    @foreach (var item in Model.Select((value, index) => new { value, index }))
                    {
                        <tr class="hover:bg-blue-80/30 transition-colors">
                            <td class="px-6 py-4 text-center text-gray-400 font-medium">@(item.index + 1)</td>

                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-gray-900 font-bold">
                                        @(isArabic? item.value.Course?.TitleAr : item.value.Course?.TitleEn)
                                    </span>
                                    
                                </div>
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex flex-col">
                                    <span class="text-gray-900 font-medium flex items-center gap-1">
                                        <i class="far fa-calendar-alt text-xs text-gray-400"></i>
                                        @{
                                            var culture = isArabic
                                                ? new System.Globalization.CultureInfo("ar-EG")
                                                : System.Globalization.CultureInfo.InvariantCulture;
                                        }
                                        @item.value.StartDateTime.ToString("dddd, dd MMM yyyy", culture)
                                    </span>
                                    <span class="text-orange-600 text-xs font-semibold mt-1">
                                        <i class="far fa-clock"></i>
                                        @item.value.StartDateTime.ToString("hh:mm tt")
                                        <span class="text-gray-300 mx-1">|</span>
                                        <span class="text-gray-500">
                                            @item.value.DurationInHours @(isArabic ? "ساعة" : "Hrs")
                                        </span>
                                    </span>
                                </div>
                            </td>

                            <td class="px-6 py-4 text-center">
                                <a href="/instructor/Appointment/ManageStudents/@item.value.Id"
                                   class="inline-flex items-center px-3 py-1 bg-blue-50 text-blue-700 rounded-full font-bold hover:bg-blue-100 transition-colors cursor-pointer">
                                    <i class="fas fa-users mr-1 ml-1 text-xs text-blue-400"></i>
                                    @item.value.StudentAppointments.Count
                                </a>
                            </td>

                            <td class="px-6 py-4">
                                @if (item.value.IsActive)
                                {
                                    @if (!string.IsNullOrEmpty(item.value.MeetingLink))
                                    {
                                        <a href="@item.value.MeetingLink" target="_blank"
                                               class="p-2 text-green-500 hover:bg-green-50 rounded-lg transition-colors border border-green-200 bg-green-50/50 shadow-sm"
                                               title="@(isArabic ? "انضم الآن" : "Join Now")">
                                            <i class="fas fa-video animate-pulse"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        <span class="p-2 text-amber-500 bg-amber-50 border border-amber-200 rounded-lg cursor-help"
                                              title="@(isArabic ? "لا يوجد رابط للمكان" : "No link provided")">
                                            <i class="fas fa-exclamation-triangle"></i>
                                        </span>
                                    }
                                }
                                else
                                {
                                    <span class="text-blue-500  items-center gap-1">
                                        <i class="fas fa-hourglass-start text-xs"></i>
                                        @(isArabic ? "قادم" : "Upcoming")
                                    </span>
                                }
                            </td>

                            <td class="px-6 py-4">
                                <div class="flex justify-center gap-2">
                                    @* زر التعديل *@
                                    <button onclick="openEditModal(@item.value.Id, '@item.value.StartDateTime.ToString("yyyy-MM-ddTHH:mm")', @item.value.DurationInHours, '@item.value.MeetingLink')"
                                            class="p-2 text-blue-500 hover:bg-blue-50 rounded-lg transition-colors border border-gray-100" title="Edit">
                                        <i class="fas fa-edit"></i>
                                    </button>

                                    @if (item.value.IsActive)
                                    {
                                        @* الزرار وهو شغال *@
                                        <a href="@item.value.MeetingLink" target="_blank"
                                           class="p-2 text-green-500 hover:bg-green-50 rounded-lg transition-colors border border-green-200 bg-green-50/50 shadow-sm"
                                           title="@(isArabic ? "انضم الآن" : "Join Now")">
                                            <i class="fas fa-video animate-pulse"></i>
                                        </a>
                                    }
                                    else
                                    {
                                        @* الزرار وهو غير نشط (مقفول) *@
                                        <span class="p-2 text-gray-300 bg-gray-50 border border-gray-100 rounded-lg cursor-not-allowed"
                                              title="@(isArabic ? "الموعد غير متاح حالياً" : "Meeting not available yet")">
                                            <i class="fas fa-video-slash"></i>
                                        </span>
                                    }

                                    @* زر الحذف *@
                                    <button onclick="deleteAppointment(@item.value.Id)" class="p-2 text-red-500 hover:bg-red-50 rounded-lg transition-colors border border-gray-100" title="Delete">
                                        <i class="fas fa-trash-alt"></i>
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>



<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-dialog-centered">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">
                    <i class="fas fa-edit text-orange me-2"></i>
                    @(isArabic ? "تعديل الميعاد" : "Edit Appointment")
                </h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body p-4">
                <input type="hidden" id="editAppointmentId">

                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-2">
                        <i class="fas fa-calendar text-orange me-1"></i>
                        @(isArabic ? "التاريخ والوقت" : "Date & Time")
                    </label>
                    <input type="datetime-local" id="editStartDateTime" class="form-control">
                </div>

                
                    <input type="hidden" id="editDuration" class="form-control" value="1">

                <div class="mb-3">
                    <label class="small fw-bold text-muted mb-2">
                        <i class="fas fa-link text-orange me-1"></i>
                        @(isArabic ? "رابط الاجتماع" : "Meeting Link")
                    </label>
                    <div class="input-group">
                        <span class="input-group-text bg-white border-end-0">
                            <i class="fas fa-video text-orange"></i>
                        </span>
                        <input type="url" id="editMeetingLink" class="form-control bg-light border-start-0"
                               placeholder="https://...">
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-light border px-4" data-bs-dismiss="modal">
                    @(isArabic ? "إلغاء" : "Cancel")
                </button>
                <button type="button" class="btn btn-orange-custom px-4" id="saveEditBtn">
                    <i class="fas fa-save me-1"></i>
                    @(isArabic ? "حفظ التعديلات" : "Save Changes")
                </button>
            </div>
        </div>
    </div>
</div>

<script src="https://cdn.tailwindcss.com?plugins=forms,typography"></script>

@section Scripts{
    <script>
        function deleteAppointment(id) {
            const isAr = "@isArabic".toLowerCase() === "true";

            Swal.fire({
                title: isAr ? 'هل أنت متأكد؟' : 'Are you sure?',
                text: isAr ? 'لن تتمكن من استعادة هذا الموعد!' : "You won't be able to revert this!",
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#d33',
                cancelButtonColor: '#3085d6',
                confirmButtonText: isAr ? 'نعم، احذف' : 'Yes, delete it!',
                cancelButtonText: isAr ? 'إلغاء' : 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.post('/instructor/Appointment/Delete', { id: id }, function (res) {
                        if (res.success) {
                            Swal.fire(
                                isAr ? 'تم الحذف!' : 'Deleted!',
                                isAr ? 'تم حذف الموعد بنجاح.' : 'The appointment has been deleted.',
                                'success'
                            ).then(() => {
                                
                                location.reload();
                               
                            });
                        } else {
                            Swal.fire('Error', res.message, 'error');
                        }
                    });
                }
            });
        }




        function openEditModal(id, startDateTime, duration, meetingLink) {
        $('#editAppointmentId').val(id);
        $('#editStartDateTime').val(startDateTime);
        $('#editDuration').val(duration);
        $('#editMeetingLink').val(meetingLink);
        new bootstrap.Modal(document.getElementById('editModal')).show();
        }

        $('#saveEditBtn').on('click', function() {
        var id = $('#editAppointmentId').val();
        var startDateTime = $('#editStartDateTime').val();
        var duration = $('#editDuration').val();
        var meetingLink = $('#editMeetingLink').val();
        var isAr = "@isArabic".toLowerCase() === "true";

        if (!startDateTime || !duration || !meetingLink) {
        Swal.fire('', isAr ? 'أكمل جميع البيانات' : 'Fill all fields', 'warning');
        return;
        }

        var btn = $(this);
        btn.prop('disabled', true).html('<i class="fas fa-spinner fa-spin"></i>');

        $.ajax({
        url: '/instructor/Appointment/Edit',
        type: 'POST',
        data: {
        id: id,
        startDateTime: startDateTime,
        durationInHours: duration,
        meetingLink: meetingLink
        },
        success: function(res) {
        btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (isAr ? 'حفظ التعديلات' : 'Save Changes'));
        if (res.success) {
        bootstrap.Modal.getInstance(document.getElementById('editModal')).hide();
        Swal.fire({
        icon: 'success',
        title: isAr ? 'تم بنجاح' : 'Success',
        timer: 1500,
        showConfirmButton: false
        }).then(() => location.reload());
        } else {
        Swal.fire('Error', res.message, 'error');
        }
        },
        error: function() {
        btn.prop('disabled', false).html('<i class="fas fa-save me-1"></i> ' + (isAr ? 'حفظ التعديلات' : 'Save Changes'));
        Swal.fire('Error', isAr ? 'فشل الاتصال' : 'Connection failed', 'error');
        }
        });
        });


    </script>
}