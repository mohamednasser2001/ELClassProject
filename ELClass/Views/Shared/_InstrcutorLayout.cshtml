@using DataAccess.Repositories.IRepositories
@using Microsoft.AspNetCore.Identity
@using Models
@inject UserManager<ApplicationUser> UserManager
@inject IUnitOfWork _unitOfWork
@{
    var user        = await UserManager.GetUserAsync(User);
    var userId = user.Id;
    var isInstructor = User.IsInRole("Instructor");
    var userImage   = user?.Img;
    var displayName = user?.NameEN ?? user?.UserName;
    var isArabic    = System.Globalization.CultureInfo.CurrentCulture.TwoLetterISOLanguageName == "ar";
    var dir         = isArabic ? "rtl" : "ltr";

    int pendingStudentsCount = 0;
    if (isInstructor && !string.IsNullOrEmpty(userId))
    {
        var instructorStudents = await _unitOfWork.InstructorStudentRepository
            .GetAsync(x => x.InstructorId == userId && x.TimesCount > 0);
        pendingStudentsCount = instructorStudents.Count();
    }
}

<!doctype html>
<html lang="@(isArabic ? "ar" : "en")" dir="@dir" style="--el-role-color:#7C3AED;--el-role-light:#F5F3FF;--el-primary-rgb:124,58,237;">
