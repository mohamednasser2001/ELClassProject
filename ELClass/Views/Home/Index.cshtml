    <!-- Top Bar End -->
    <!-- Banner Start -->
    <div id="home" class="el-banner-wrapper">
        <div class="container">
            <div class="el-banner-parent">
                <div class="el-banner-flex">
                    <div class="el-banner-left">
                        <h1>
                            @(c?.HeroTitle ?? (isArabic ? "ابحث عن المدرس المثالي لطفلك" : "Get Started With"))
                            <span>@(c?.HeroTitleHighlight ?? (isArabic ? "الكلاس" : "ElClass"))</span>
                            @(c?.HeroTitleSuffix ?? (isArabic ? "" : " Online | Offline Courses"))
                        </h1>
                        <p class="el-para">
                            @(c?.HeroSubtitle ?? (isArabic
                                ? "نساعد الطلاب على تحقيق أهدافهم التعليمية بشكل أسرع وأكثر كفاءة. تعلم عبر الإنترنت في أي مكان وأي وقت."
                                : "We help students reach their life goals faster and more efficiently. Growing online learning. From this side you read and buy online courses anywhere, any time."))
                        </p>
                        <div class="el-banner-btns">
                            <!-- زرار ابدأ الآن (أكبر) -->
                            <a href="#ContactUsSection" class="el-btn el-hero-start-btn">
                                @(c?.HeroStartBtnText ?? (isArabic ? "ابدأ الآن" : "get started"))
                            </a>

                            <!-- حاوية الصورة وزرار التشغيل (ستايل يوتيوب) -->
                            <div class="el-video-thumb-wrapper">
                                <img src="/Images/thumbnails/@(c?.PlayVideoText)" alt="Video Thumbnail" class="el-video-thumb-img" />
                                <a class="video-popup el-youtube-play-btn" href="#" onclick="openVideoModal()" title="تشغيل الفيديو">
                                    <!-- SVG مطابق لزرار يوتيوب الرسمي -->
                                    <svg viewBox="0 0 68 48" xmlns="http://www.w3.org/2000/svg">
                                        <path d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="#FF0000"/>
                                        <path d="M45,24 27,14 27,34" fill="#FFFFFF"/>
                                    </svg>
                                </a>
                            </div>
                        </div>

                        <!-- Video Modal -->
                        <div id="videoModal" style="display:none; position:fixed; inset:0; background:rgba(0,0,0,0.8); z-index:9999999; align-items:center; justify-content:center;">
                            <div style="position:relative; width:90%; max-width:800px;">
                                <button onclick="closeVideoModal()"
                                        style="position:absolute; top:-40px; right:0; background:none; border:none; color:#fff; font-size:32px; cursor:pointer; line-height:1;">
                                    &times;
                                </button>
                                <div id="videoContainer"></div>
                            </div>
                        </div>
                    </div>
                    <div class="el-banner-right">
                        <div class="el-banner-reslt-box">
                            <img src="~/HomePageAssets/assets/img/star.png" class="el-star-smile" alt="star">
                            <h4>@(isArabic ? "نتائج متميزة" : "Brilliant Results")</h4>
                            <div class="el-reslt-flex">
                                <img src="~/HomePageAssets/assets/img/r1.png" alt="student image">
                                <div class="el-reslt-info">
                                    <h4>@(isArabic ? "أحمد محمد" : "John Deo")</h4>
                                    <p>@(isArabic ? "طالب ثانوي" : "M.Sc. Students")</p>
                                </div>
                                <div class="el-reslt-grade">
                                    <span>A+</span>
                                </div>
                            </div>
                            <div class="el-reslt-flex">
                                <img src="~/HomePageAssets/assets/img/r2.png" alt="student image">
                                <div class="el-reslt-info">
                                    <h4>@(isArabic ? "فاطمة علي" : "Emma Score")</h4>
                                    <p>@(isArabic ? "طالبة جامعية" : "MBA Students")</p>
                                </div>
                                <div class="el-reslt-grade">
                                    <span>A+</span>
                                </div>
                            </div>
                            <div class="el-reslt-flex">
                                <img src="~/HomePageAssets/assets/img/r3.png" alt="student image">
                                <div class="el-reslt-info">
                                    <h4>@(isArabic ? "محمود سعيد" : "Charlie Burns")</h4>
                                    <p>@(isArabic ? "طالب إعدادي" : "CA Students")</p>
                                </div>
                                <div class="el-reslt-grade">
                                    <span>A+</span>
                                </div>
                            </div>
                        </div>
                        <div class="el-banner-img">
                            <img src="~/HomePageAssets/assets/img/freepik__-17-__4652.png" alt="banner girl">
                        </div>
                    </div>
                </div>

               
            </div>
        </div>
    </div>
    
    <!-- Banner End -->
    <!-- Counter Start -->
    <div  class="el-counter-wrapper">
        <div class="container">
            <div class="el-counter-parent">
                <img src="~/HomePageAssets/assets/img/stdss.png" alt="students">
                <div class="el-count">
                    <div class="el-counting" data-to="@(c?.Counter1Num ?? 22000)">0</div>
                    <div class="el-count-heading">
                        <h5>@(c?.Counter1Label ?? (isArabic ? "قصص نجاح" : "Success Stories"))</h5>
                    </div>
                </div>
                <div class="el-count">
                    <div class="el-counting" data-to="@(c?.Counter2Num ?? 6500)">0</div>
                    <div class="el-count-heading">
                        <h5>@(c?.Counter2Label ?? (isArabic ? "مدرس خبير" : "Expert Instructor"))</h5>
                    </div>
                </div>
                <div class="el-count">
                    <div class="el-counting" data-to="@(c?.Counter3Num ?? 5000)">0</div>
                    <div class="el-count-heading">
                        <h5>@(c?.Counter3Label ?? (isArabic ? "طالب نشط" : "Active Student"))</h5>
                    </div>
                </div>
                <div class="el-count">
                    <div class="el-counting" data-to="@(c?.Counter4Num ?? 2000)">0</div>
                    <div class="el-count-heading">
                        <h5>@(c?.Counter4Label ?? (isArabic ? "ساعة فيديو" : "Hours Video Classes"))</h5>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Counter End -->
    <!-- About Section Start -->
    <div id="feature" class="el-about-wrapper p-3">
        <div class="container">
            <div class="row gy-4 align-items-center">
                <div class="col-lg-6">
                    <div class="el-about-img">
