@using ELClass.services
@using Models.ViewModels
@using Models
@{
    Layout = "_HomePageLayout";
    var isArabic = CultureHelper.IsArabic;
}
@model HomePageIndexVM
@{
    var c = Model.Content;
    // Country data for selector (Arabic only)
    var countries = new[]
    {
        ("SA", "السعودية"),
        ("AE", "الإمارات"),
        ("KW", "الكويت"),
        ("BH", "البحرين"),
        ("OM", "عُمان"),
        ("EG", "مصر"),
        ("QA", "قطر"),
    };
}

<!DOCTYPE html>
<html lang="@(isArabic ? "ar" : "en")" dir="@(isArabic ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
    <title>@(isArabic ? "منصة التعليم - ابحث عن مدرسك المثالي" : "Education Platform - Find Your Perfect Tutor")</title>

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@300;400;500;600;700;800;900&family=El+Messiri:wght@700&display=swap" rel="stylesheet">

    <!-- CSS -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/gh/lipis/flag-icons@7.2.3/css/flag-icons.min.css" />
    <link rel="stylesheet" href="~/css/HomePage.css" />
    <link rel="stylesheet" href="~/css/HomePage2.css" />
</head>
<body>

    <!-- Top Bar Start -->
    <div class="el-top-header-bar">
        <div class="container">
            <div class="el-top-bar-flex">
                <div class="el-top-header-left">
                    <p>@(c?.WelcomeText ?? (isArabic ? "مرحباً بك في الكلاس" : "Welcome To ElClass"))</p>
                </div>
                @if (isArabic)
                {
                   
                    var countryFlags = new Dictionary<string, string>
                    {
                        {"SA","sa"}, {"AE","ae"}, {"KW","kw"},
                        {"BH","bh"}, {"OM","om"}, {"EG","eg"}, {"QA","qa"}
                    };
    
                    var selCode = (Model.SelectedCountry ?? "SA").ToUpper();
                    var selName = countries.FirstOrDefault(x => x.Item1 == selCode).Item2 ?? "السعودية";
                    var flagClass = selCode.ToLower();
                    @* var selFlag = countryFlags.ContainsKey(Model.SelectedCountry ?? "") ? countryFlags[Model.SelectedCountry!] : countryFlags[countries[0].Item1]; *@
                    <div class="el-country-picker" id="elCountryPicker">
                        <button type="button" class="el-country-btn" onclick="toggleCountryDropdown(event)">
                               <span class="fi fi-@flagClass"></span> 
                                <span class="el-country-label">@selName</span>
                            <svg class="el-country-chevron" width="10" height="6" viewBox="0 0 10 6" fill="none">
                                <path d="M1 1L5 5L9 1" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
                            </svg>
                        </button>
                        <ul class="el-country-menu" role="listbox">
                            @foreach (var (code, name) in countries)
                            {
                                var lowerCode = code.ToLower();
                                var active = code == selCode;
                                <li role="option" class="el-country-option @(active ? "active" : "")" onclick="selectCountry('@code')">
                                    <span class="fi fi-@lowerCode"></span> <span>@name</span>
                                     @if (active) { <svg class="el-country-check" width="12" height="9" viewBox="0 0 12 9" fill="none"><path d="M1 4L4.5 7.5L11 1" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg> }
                                </li>
                            }
                        </ul>
                        <form id="elCountryForm" action="/Home/SetCountry" method="post" style="display:none;">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="returnUrl" value="@Context.Request.Path" />
                            <input type="hidden" name="country" id="elCountryInput" value="@selCode" />
                        </form>
                    </div>
                    <style>
                        .el-country-picker { position: relative; z-index: 100; }
                        .el-country-btn {
                            display: inline-flex; align-items: center; gap: 6px;
                            background: rgba(255,255,255,0.08);
                            border: 1px solid rgba(255,255,255,0.22);
                            color: #fff; border-radius: 20px;
                            padding: 4px 12px 4px 8px;
                            font-size: 13px; font-family: inherit; cursor: pointer;
                            transition: background .2s, border-color .2s;
                            white-space: nowrap;
                        }
                        .el-country-btn:hover { background: rgba(255,255,255,0.16); border-color: rgba(255,255,255,0.45); }
                        .el-country-flag { font-size: 16px; line-height: 1; }
                        .el-country-chevron { transition: transform .25s; flex-shrink: 0; opacity: .8; }
                        .el-country-picker.open .el-country-chevron { transform: rotate(180deg); }
                        .el-country-menu {
                            display: none; position: absolute;
                            top: calc(100% + 8px); right: 0;
                            background: #0b2340;
                            border: 1px solid rgba(255,255,255,0.15);
                            border-radius: 12px; padding: 6px;
                            margin: 0; list-style: none;
                            min-width: 148px;
                            box-shadow: 0 8px 28px rgba(0,0,0,0.45);
                            animation: elDropIn .18s ease;
                        }
                        .el-country-picker.open .el-country-menu { display: block; }
                        @@keyframes elDropIn {
                            from { opacity: 0; transform: translateY(-6px) scale(.97); }
                            to   { opacity: 1; transform: translateY(0)   scale(1); }
                        }
                        .el-country-option {
                            display: flex; align-items: center; gap: 8px;
                            padding: 7px 10px; border-radius: 8px;
                            color: rgba(255,255,255,0.82); font-size: 13px;
                            cursor: pointer; transition: background .15s;
                        }
                        .el-country-option:hover { background: rgba(255,255,255,0.1); color: #fff; }
                        .el-country-option.active { background: rgba(255,255,255,0.12); color: #fff; font-weight: 600; }
                        .el-country-check { margin-right: auto; color: #4fc3f7; flex-shrink: 0; }
                    </style>
                    <script>
                        function toggleCountryDropdown(e) {
                            e.stopPropagation();
                            document.getElementById('elCountryPicker').classList.toggle('open');
                        }
                        function selectCountry(code) {
                            var input = document.getElementById('elCountryInput');
                            var form = document.getElementById('elCountryForm');
    
                            if(input && form) {
                                input.value = code; 
                                form.submit();
                            }
                        }
                        document.addEventListener('click', function () {
                            var p = document.getElementById('elCountryPicker');
                            if (p) p.classList.remove('open');
                        });
                    </script>
                }
                <div class="el-top-header-right">
                    <p>
                        <img src="~/HomePageAssets/assets/img/phone-icon.svg" alt="phone icon" width="16" height="16">
                        @(isArabic ? "للاستفسار اتصل بنا على" : "For any question call us at")
                        <span>@(c?.PhoneNumber ?? "+(321) 321654897")</span>
                    </p>
                    <div class="el-social-icons">
