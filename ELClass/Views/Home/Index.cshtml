    @if (Model.Articles.Any())
    {
    <div class="el-blog-wrapper">
        <div class="swiper-button-prev"></div>
        <div class="swiper-button-next"></div>
        <div class="container">
            <div class="el-team-heading text-center">
                <h4 class="el-top-heading-center">@(c?.BlogTopHeading ?? (isArabic ? "مدونتنا" : "Our Blogs"))</h4>
                <h2 class="el-main-heading">@(c?.BlogMainHeading ?? (isArabic ? "أخبار ونصائح ورؤى" : "News, Tips, Blogs & Insights"))</h2>
                <p class="gray-p">@(c?.BlogParagraph ?? "")</p>
            </div>
                <div class="swiper el-blog-slider-parent">
                    <div class="swiper-wrapper" style="max-height:570px">
                        @{int blogColorIdx = 0;}
                        @foreach (var article in Model.Articles)
                        {
                            blogColorIdx++;
                            var boxClass = blogColorIdx == 1 ? "el-blog-box-1" : blogColorIdx == 2 ? "el-blog-box-2" : "el-blog-box-3";
                            if (blogColorIdx > 3) blogColorIdx = 0;
                            <div class="swiper-slide">
                                <div class="el-blog-box @boxClass">
                                    <div class="el-blog-img">
                                        @if (!string.IsNullOrEmpty(article.ImageFileName))
                                        {
                                            <img src="/uploads/articles/@article.ImageFileName" alt="@article.Title">
                                        }
                                        else
                                        {
                                            <img src="~/HomePageAssets/assets/img/b1.png" alt="Blog Image">
                                        }
                                        @if (!string.IsNullOrEmpty(article.Category))
                                        {
                                            <h4>@article.Category</h4>
                                        }
                                    </div>
                                    <div class="el-blog-content">
                                        <h4>@article.Title</h4>
                                        <p class="el-para">
                                            @article.Description
                                            <a href="@(string.IsNullOrEmpty(article.ReadMoreUrl) ? "javascript:;" : article.ReadMoreUrl)"
                                               @(string.IsNullOrEmpty(article.ReadMoreUrl) ? "" : "target=\"_blank\" rel=\"noopener\"")
                                               class="el-orange-btn">@(c?.BlogReadMoreText ?? (isArabic ? "اقرأ المزيد" : "read more"))</a>
                                        </p>
                                        <div class="el-blog-footer">
                                            <p class="el-para">@article.PublishedDate.ToString("dd MMM yyyy")</p>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
        </div>
    </div>
    }
