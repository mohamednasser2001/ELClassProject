    <!-- Testimonial Section Start -->
    <div class="el-testmnl-wrapper">
        <div class="container">
            <div class="el-team-heading text-center">
                <h4 class="el-top-heading-center">@(c?.TestimonialsTopHeading ?? (isArabic ? "آراء العملاء" : "Testimonials"))</h4>
                <h2 class="el-main-heading">@(c?.TestimonialsMainHeading ?? (isArabic ? "ماذا يقول طلابنا عنا" : "What Our Students Say About Us"))</h2>
                <p class="gray-p">@(c?.TestimonialsParagraph ?? "")</p>
            </div>
            <div class="row align-items-center">
                <div class="col-xl-7 col-lg-12">
                    <div class="el-tesml-main-parent">
                        <div class="swiper-button-prev"></div>
                        <div class="swiper-button-next"></div>
                        <div class="swiper el-testmnl-slider" dir="ltr">
                            <div class="swiper-wrapper">
                                @foreach (var t in Model.Testimonials)
                                {
                                    <div class="swiper-slide">
                                        <div class="el-tm-banner-media custom-card">
                                            @if (!string.IsNullOrEmpty(t.ImageFileName))
                                            {
                                                <img src="/uploads/testimonials/@t.ImageFileName" alt="@t.Name">
                                            }
                                            else
                                            {
                                                <div style="width:100%;height:200px;background:#0053B3;display:flex;align-items:center;justify-content:center;color:#fff;font-size:3rem;font-weight:700;">
                                                    @(t.Name?.Substring(0, 1) ?? "?")
                                                </div>
                                            }
                                            <div class="el-tm-banner-media_content info-box">
                                                <h6>@t.Name</h6>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
                <div class="col-xl-5 col-lg-12">
                    <div class="swiper el-temnl-text-slider">
                        <div class="swiper-wrapper">
                            @foreach (var t in Model.Testimonials)
                            {
                                var fullStars = (int)Math.Floor((double)t.Rating);
                                var hasHalf = (t.Rating - fullStars) >= 0.5m;
                                <div class="swiper-slide">
                                    <div class="el-temsl-text-slider">
                                        <img src="~/HomePageAssets/assets/img/qoute.png" alt="quote image">
                                        <p class="gray-p">@t.Quote</p>
                                        <div class="el-tesmnl-rating">
                                            <img src="~/HomePageAssets/assets/img/like-star.png" alt="rating">
                                            <span>@t.Rating.ToString("0.0")</span>
                                            <span class="el-temnl-rating">
                                                @for (int si = 0; si < 5; si++)
                                                {
                                                    if (si < fullStars)
                                                    {
                                                        <img src="~/HomePageAssets/assets/img/star.png" alt="star">
                                                    }
                                                    else
                                                    {
                                                        <img src="~/HomePageAssets/assets/img/star-grey.png" alt="star">
                                                    }
                                                }
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            }
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <!-- Testimonial Section End -->
    <!-- Pricing Section Start -->
    <div id="pricing" class="el-pricing-wrapper">
        <div class="container">
            <div class="el-team-heading text-center">
                <h4 class="el-top-heading-center">@(c?.PricingTopHeading ?? (isArabic ? "خطط الأسعار" : "Pricing Plans"))</h4>
                <h2 class="el-main-heading">@(c?.PricingMainHeading ?? (isArabic ? "أسعار شفافة وبسيطة" : "Transparent And Simple Pricing"))</h2>
                <p class="el-para">@(c?.PricingParagraph ?? "")</p>
            </div>
            @if (Model.PricingPlans.Any())
            {
                var monthlyPlans = Model.PricingPlans.ToList();
                <div class="el-pricing-main-parent">
                    <div class="el-pricing-btn">
                        <ul class="nav nav-tabs" id="pricingTab" role="tablist">
                            <li class="nav-item" role="presentation">
                                <button class="nav-link active" id="monthly-tab" data-bs-toggle="tab" data-bs-target="#monthly" type="button" role="tab">
                                    @(c?.PricingMonthlyLabel ?? (isArabic ? "شهري" : "Monthly"))
                                </button>
                            </li>
                            <li class="nav-item" role="presentation">
                                <button class="nav-link" id="yearly-tab" data-bs-toggle="tab" data-bs-target="#yearly" type="button" role="tab">
                                    @(c?.PricingYearlyLabel ?? (isArabic ? "سنوي" : "Yearly"))
                                </button>
                            </li>
                        </ul>
                    </div>
                    <div class="tab-content" id="pricingTabContent">
                        <div class="tab-pane fade show active" id="monthly" role="tabpanel">
                            <div class="row gy-4">
                                @foreach (var plan in monthlyPlans)
                                {
                                    <div class="col-lg-4 col-md-6">
                                        <div class="el-price-box">
                                            @if (plan.IsPopular)
                                            {
                                                <h4 class="el-popular-plan">@(isArabic ? "الأكثر شعبية" : "Most Popular")</h4>
                                            }
                                            <div class="el-price-inner">
                                                <div class="el-price-head">
                                                    <div class="el-price-img">
                                                        <img src="~/HomePageAssets/assets/img/@(plan.IsPopular ? "standard-icon" : plan.SortOrder == 0 ? "basic-icon" : "premium-icon").png" alt="Icon">
                                                    </div>
                                                    <h4 class="el-plan-name">@plan.Name</h4>
                                                    <p class="el-para">@plan.Description</p>
                                                    <h1>@(isArabic ? plan.MonthlyPrice : plan.Currency)@(isArabic ? " " : "")@(isArabic ? plan.Currency : plan.MonthlyPrice)<span>@(isArabic ? "/شهرياً" : "/Month")</span></h1>
                                                    <a href="javascript:;" class="el-btn">@(c?.PricingBtnText ?? (isArabic ? "ابدأ الآن" : "Get Started Now"))</a>
                                                </div>
                                                <div class="el-pricing-list">
                                                    <ul>
                                                        @foreach (var (text, isChecked) in plan.ParsedFeatures())
                                                        {
                                                            <li class="el-para">
                                                                <img src="~/HomePageAssets/assets/img/@(isChecked ? "checked" : "unchecked").png" alt="icon">
                                                                @text
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                        <div class="tab-pane fade" id="yearly" role="tabpanel">
                            <div class="row gy-4">
                                @foreach (var plan in monthlyPlans)
                                {
                                    <div class="col-lg-4 col-md-6">
                                        <div class="el-price-box">
                                            @if (plan.IsPopular)
                                            {
                                                <h4 class="el-popular-plan">@(isArabic ? "الأكثر شعبية" : "Most Popular")</h4>
                                            }
                                            <div class="el-price-inner">
                                                <div class="el-price-head">
                                                    <div class="el-price-img">
                                                        <img src="~/HomePageAssets/assets/img/@(plan.IsPopular ? "standard-icon" : plan.SortOrder == 0 ? "basic-icon" : "premium-icon").png" alt="Icon">
                                                    </div>
                                                    <h4 class="el-plan-name">@plan.Name</h4>
                                                    <p class="el-para">@plan.Description</p>
                                                    <h1>@(isArabic ? plan.YearlyPrice : plan.Currency)@(isArabic ? " " : "")@(isArabic ? plan.Currency : plan.YearlyPrice)<span>@(isArabic ? "/سنوياً" : "/Yearly")</span></h1>
                                                    <a href="javascript:;" class="el-btn">@(c?.PricingBtnText ?? (isArabic ? "ابدأ الآن" : "Get Started Now"))</a>
                                                </div>
                                                <div class="el-pricing-list">
                                                    <ul>
                                                        @foreach (var (text, isChecked) in plan.ParsedFeatures())
                                                        {
                                                            <li class="el-para">
                                                                <img src="~/HomePageAssets/assets/img/@(isChecked ? "checked" : "unchecked").png" alt="icon">
                                                                @text
                                                            </li>
                                                        }
                                                    </ul>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
    <!-- Pricing Section End -->
