@using ELClass.services
@using Models.ViewModels
@using Models
@using System.Text.Json
@{
    Layout = null;
    var isArabic = CultureHelper.IsArabic;
    var initLang = isArabic ? "ar" : "en";
    var initCountry = Model?.SelectedCountry ?? "SA";

    // ── Helpers ──────────────────────────────────────────
    static float ParsePrice(string? s)
    {
        if (string.IsNullOrWhiteSpace(s)) return 0;
        var clean = new string(s.Where(c => char.IsDigit(c) || c == '.').ToArray());
        return float.TryParse(clean, out var v) ? v : 0;
    }

    static string SafeTag(string? s, int len = 4)
    {
        if (string.IsNullOrWhiteSpace(s)) return "EL";
        return s.Length > len ? s[..len] : s;
    }

    // ── Instructors ───────────────────────────────────────
    var approvedInstructors = Model?.Instructors.Where(i => i.IsApproved).ToList() ?? new();

    var teachersAr = approvedInstructors.Select(i => new
    {
        name = i.NameAr,
        subj = i.SpecializationAr,
        rate = "4.9",
        reviews = "0",
        price = "---",
        tag = SafeTag(i.SpecializationAr, 4)
    });

    var teachersEn = approvedInstructors.Select(i => new
    {
        name = i.NameEn,
        subj = i.SpecializationEn,
        rate = "4.9",
        reviews = "0",
        price = "---",
        tag = SafeTag(i.SpecializationEn, 4)
    });

    // ── Testimonials ──────────────────────────────────────
    var testimonialsData = (Model?.Testimonials ?? new()).Select(t => new
    {
        quote = t.Quote ?? "",
        name  = t.Name ?? "",
        role  = ""
    });

    // ── FAQs ──────────────────────────────────────────────
    var faqData = (Model?.FAQs ?? new()).Select(f => new { q = f.Question ?? "", a = f.Answer ?? "" });

    // ── Pricing Plans ─────────────────────────────────────
    var pricingData = (Model?.PricingPlans ?? new()).Select(p => new
    {
        name     = p.Name ?? "",
        tag      = p.Description ?? "",
        priceM   = ParsePrice(p.MonthlyPrice),
        priceY   = ParsePrice(p.YearlyPrice),
        feats    = p.ParsedFeatures().Select(f => f.Text).ToList(),
        featured = p.IsPopular
    });

    // ── HomePageContent ───────────────────────────────────
    var hc = Model?.Content;

    var jsonOpts = new JsonSerializerOptions { WriteIndented = false };
}
@model HomePageIndexVM
<!DOCTYPE html>
<html lang="@initLang" dir="@(isArabic ? "rtl" : "ltr")" data-theme="light">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@(isArabic ? "الكلاس · منصة التعليم الخصوصي" : "Elclass · Private Tutoring Platform")</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/elclass-landing.css" asp-append-version="true" />
</head>
<body>
    <div id="root"></div>

    @* ── Server initial state ──────────────────────────── *@
    <script>
        window.__ELCLASS_INIT__ = {
            lang: "@initLang",
            country: "@initCountry",
            isLoggedIn: @(User.Identity?.IsAuthenticated == true ? "true" : "false"),
            heroMediaUrl: @Html.Raw(!string.IsNullOrWhiteSpace(hc?.HeroMediaUrl) ? $"\"/images/hero-media/{hc!.HeroMediaUrl}\"" : "null"),
            heroMediaType: @Html.Raw(!string.IsNullOrWhiteSpace(hc?.HeroMediaType) ? $"\"{hc!.HeroMediaType}\"" : "null"),
            showTeacherCard: @Html.Raw(hc == null || hc.ShowTeacherCard ? "true" : "false"),
            showProgressCard: @Html.Raw(hc == null || hc.ShowProgressCard ? "true" : "false"),
            showBadgeCard: @Html.Raw(hc == null || hc.ShowBadgeCard ? "true" : "false"),
            showPricingSection: @Html.Raw(hc == null || hc.ShowPricingSection ? "true" : "false")
        };
    </script>

    @* ── CDN scripts ───────────────────────────────────── *@
    <script src="https://unpkg.com/react@@18.3.1/umd/react.development.js"
            integrity="sha384-hD6/rw4ppMLGNu3tX5cjIb+uRZ7UkRJ6BPkLpg4hAu/6onKUg4lLsHAs9EBPT82L"
            crossorigin="anonymous"></script>
    <script src="https://unpkg.com/react-dom@@18.3.1/umd/react-dom.development.js"
            integrity="sha384-u6aeetuaXnQ38mYT8rp6sbXaQe3NL9t+IBXmnYxwkUI2Hw4bsp2Wvmx4yRQF1uAm"
            crossorigin="anonymous"></script>
    <script src="https://unpkg.com/@@babel/standalone@@7.29.0/babel.min.js"
            integrity="sha384-m08KidiNqLdpJqLq95G/LEi8Qvjl/xUYll3QILypMoQ65QorJ9Lvtp2RXYGBFj1y"
            crossorigin="anonymous"></script>

    @* ── Hardcoded content base ────────────────────────── *@
    <script src="~/js/elclass-content.js" asp-append-version="true"></script>

    @* ── DB data overrides ─────────────────────────────── *@
    <script>
    (function () {
        var c = window.ELCLASS_CONTENT;
        if (!c) return;

        @* ── Teachers ──────────────────────────────────── *@
        @if (approvedInstructors.Any())
        {
            <text>
        c.ar.teachers.list = @Html.Raw(JsonSerializer.Serialize(teachersAr, jsonOpts));
        c.en.teachers.list = @Html.Raw(JsonSerializer.Serialize(teachersEn, jsonOpts));
            </text>
        }

        @* ── Testimonials (current lang/country from server) *@
        @if (Model?.Testimonials?.Any() == true)
        {
            <text>
        c["@initLang"].testimonials.list = @Html.Raw(JsonSerializer.Serialize(testimonialsData, jsonOpts));
            </text>
        }

        @* ── FAQs ──────────────────────────────────────── *@
        @if (Model?.FAQs?.Any() == true)
        {
            <text>
        c["@initLang"].faq.list = @Html.Raw(JsonSerializer.Serialize(faqData, jsonOpts));
            </text>
        }

        @* ── Pricing Plans ─────────────────────────────── *@
        @if (Model?.PricingPlans?.Any() == true)
        {
            <text>
        c["@initLang"].pricing.plans = @Html.Raw(JsonSerializer.Serialize(pricingData, jsonOpts));
            </text>
        }

        @* ── Hero / Content fields ─────────────────────── *@
        @if (hc != null)
        {
            if (!string.IsNullOrWhiteSpace(hc.HeroTitle) || !string.IsNullOrWhiteSpace(hc.HeroTitleHighlight))
            {
                var t0 = hc.HeroTitle ?? "";
                var t1 = hc.HeroTitleHighlight ?? "";
                var t2 = hc.HeroTitleSuffix ?? "";
                <text>
        c["@initLang"].hero.titleA = [@Html.Raw(JsonSerializer.Serialize(t0)), @Html.Raw(JsonSerializer.Serialize(t1)), @Html.Raw(JsonSerializer.Serialize(t2))];
                </text>
            }
            if (!string.IsNullOrWhiteSpace(hc.HeroSubtitle))
            {
                <text>
        c["@initLang"].hero.sub = @Html.Raw(JsonSerializer.Serialize(hc.HeroSubtitle));
                </text>
            }
            if (!string.IsNullOrWhiteSpace(hc.HeroStartBtnText))
            {
                <text>
        c["@initLang"].hero.ctaPrimary = @Html.Raw(JsonSerializer.Serialize(hc.HeroStartBtnText));
                </text>
            }
            if (hc.Counter1Num.HasValue && !string.IsNullOrWhiteSpace(hc.Counter1Label))
            {
                <text>
        c["@initLang"].hero.stat1 = [@Html.Raw(JsonSerializer.Serialize("+" + hc.Counter1Num)), @Html.Raw(JsonSerializer.Serialize(hc.Counter1Label))];
                </text>
            }
            if (hc.Counter2Num.HasValue && !string.IsNullOrWhiteSpace(hc.Counter2Label))
            {
                <text>
        c["@initLang"].hero.stat2 = [@Html.Raw(JsonSerializer.Serialize("+" + hc.Counter2Num)), @Html.Raw(JsonSerializer.Serialize(hc.Counter2Label))];
                </text>
            }
            if (hc.Counter3Num.HasValue && !string.IsNullOrWhiteSpace(hc.Counter3Label))
            {
                <text>
        c["@initLang"].hero.stat3 = [@Html.Raw(JsonSerializer.Serialize("+" + hc.Counter3Num)), @Html.Raw(JsonSerializer.Serialize(hc.Counter3Label))];
                </text>
            }
            // How-it-works steps
            var steps = new[]
            {
                new { n = isArabic ? "١" : "1", h = hc.Step1Title, p = hc.Step1Desc },
                new { n = isArabic ? "٢" : "2", h = hc.Step2Title, p = hc.Step2Desc },
                new { n = isArabic ? "٣" : "3", h = hc.Step3Title, p = hc.Step3Desc },
                new { n = isArabic ? "٤" : "4", h = hc.Step4Title, p = hc.Step4Desc },
            };
            var validSteps = steps.Where(s => !string.IsNullOrWhiteSpace(s.h)).ToArray();
            if (validSteps.Length == 4)
            {
                <text>
        c["@initLang"].how.steps = @Html.Raw(JsonSerializer.Serialize(validSteps, jsonOpts));
                </text>
            }
        }
    })();
    </script>

    @* ── JSX app files ─────────────────────────────────── *@
    <script type="text/babel" src="~/js/elclass-tweaks.js" asp-append-version="true"></script>
    <script type="text/babel" src="~/js/elclass-app.js" asp-append-version="true"></script>
</body>
</html>
