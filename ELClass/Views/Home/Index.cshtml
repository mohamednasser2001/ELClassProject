    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>

    <script>
        // Counter Animation
        document.addEventListener('DOMContentLoaded', function() {
            const counters = document.querySelectorAll('.el-counting');

            const animateCounter = (counter) => {
                const target = parseInt(counter.getAttribute('data-to'));
                const duration = 2000;
                const increment = target / (duration / 16);
                let current = 0;

                const updateCounter = () => {
                    current += increment;
                    if (current < target) {
                        counter.textContent = Math.floor(current);
                        requestAnimationFrame(updateCounter);
                    } else {
                        counter.textContent = target;
                    }
                };

                updateCounter();
            };

            const observerOptions = {
                threshold: 0.5
            };

            const observer = new IntersectionObserver((entries) => {
                entries.forEach(entry => {
                    if (entry.isIntersecting) {
                        animateCounter(entry.target);
                        observer.unobserve(entry.target);
                    }
                });
            }, observerOptions);

            counters.forEach(counter => observer.observe(counter));
        });

        // Swiper Sliders
            const courseSwiper = new Swiper('.el-tab-slider-parent', {
            slidesPerView: 1,      // افتراضياً للموبايل
            spaceBetween: 20,
            loop: true,
            speed: 800,
            autoHeight: false,
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            },
            // هذه الإعدادات ضرورية جداً لعمل السلايدر داخل الـ Tabs
            observer: true,
            observeParents: true,
            // أزرار التنقل (تأكد من وجودها في الـ HTML أو تفعيلها هنا)
            navigation: {
                nextEl: '.swiper-button-next',
                prevEl: '.swiper-button-prev',
            },
            // جعل السلايدر متجاوب حسب حجم الشاشة
            breakpoints: {
                768: {
                    slidesPerView: 2,
                    spaceBetween: 30,
                },
                1024: {
                    slidesPerView: 3,
                    spaceBetween: 30,
                }
            }
        });
        // كود إضافي للتأكد من تحديث السلايدر عند التبديل بين الـ Tabs
        $('button[data-bs-toggle="tab"]').on('shown.bs.tab', function (e) {
            // تحديث السلايدر لإعادة حساب الارتفاع الحقيقي فوراً
            if (typeof courseSwiper !== 'undefined') {
                courseSwiper.update();
                courseSwiper.updateSize();
                courseSwiper.updateSlides();
            }
        });

        const teamSwiper = new Swiper('.el-team-parent', {
            slidesPerView: 1,
            spaceBetween: 30,
            autoHeight: true,
            loop: true,
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            },
            pagination: {
                el: '.swiper-pagination',
                clickable: true,
            },
            breakpoints: {
                640: {
                    slidesPerView: 2,
                },
                768: {
                    slidesPerView: 3,
                },
                1024: {
                    slidesPerView: 4,
                },
            }
        });
        // تهيئة سلايدر الصور
        const testimonialsSwiper = new Swiper('.el-testmnl-slider', {
            effect: 'coverflow',
            grabCursor: true,
            centeredSlides: true,
            slidesPerView: 'auto',
            loop: true,
            speed: 800,
            observer: true,
            observeParents: true,
            autoplay: {
                delay: 4000,
                disableOnInteraction: false,
            },
            coverflowEffect: {
                rotate: 0,
                stretch: 60,
                depth: 200,
                modifier: 1,
                slideShadows: false,
            },
            navigation: {
                nextEl: '.el-tesml-main-parent .swiper-button-next',
                prevEl: '.el-tesml-main-parent .swiper-button-prev',
            },
        });

        // سلايدر النصوص (تعديل السرعة ليتزامن مع الصور)
        const testimonialsTextSwiper = new Swiper('.el-temnl-text-slider', {
            slidesPerView: 1,
            loop: true,
            speed: 1000,        // نفس سرعة الصور لضمان التزامن
            grabCursor: true,
            effect: 'slide',    // الحركة الافتراضية هي الانزلاق من اليمين لليسار
            spaceBetween: 50,   // مسافة بين النصوص أثناء الحركة عشان ميبانوش لازقين في بعض
            autoHeight: true,
        });

        // الربط
        testimonialsSwiper.controller.control = testimonialsTextSwiper;
        testimonialsTextSwiper.controller.control = testimonialsSwiper;

        const blogSwiper = new Swiper('.el-blog-slider-parent', {
            slidesPerView: 1,
            spaceBetween: 30,
            navigation: {
                nextEl: '.el-blog-wrapper .swiper-button-next',
                prevEl: '.el-blog-wrapper .swiper-button-prev',
            },
            breakpoints: {
                640: {
                    slidesPerView: 2,
                },
                1024: {
                    slidesPerView: 3,
                },
            }
        });


        window.addEventListener('scroll', function() {
            const body = document.body;
            // إذا نزل المستخدم أكتر من 50 بكسل
            if (window.scrollY > 50) {
                body.classList.add('header-scrolled');
            } else {
                body.classList.remove('header-scrolled');
            }
        });

    </script>
    <script>
    var videoUrl = "@(c?.VideoUrl ?? "https://youtu.be/D0UnqGm_miA?si=M-FnoMWqNdepVQqz")";

    function getEmbedUrl(url) {
    // YouTube
    var ytMatch = url.match(/(?:youtu\.be\/|youtube\.com\/(?:watch\?v=|embed\/))([^?&]+)/);
    if (ytMatch) return "https://www.youtube.com/embed/" + ytMatch[1] + "?autoplay=1";

    // Vimeo
    var vimeoMatch = url.match(/vimeo\.com\/(\d+)/);
    if (vimeoMatch) return "https://player.vimeo.com/video/" + vimeoMatch[1] + "?autoplay=1";

    // Direct video file (mp4, webm, etc.) - هنستخدم <video> tag بدل iframe
    if (url.match(/\.(mp4|webm|ogg)(\?.*)?$/i)) return "direct:" + url;

    // أي لينك تاني - هيتفتح في iframe زي ما هو
    return url;
}

    function openVideoModal() {
    var embed = getEmbedUrl(videoUrl);
    var container = document.getElementById('videoContainer');

    if (embed.startsWith("direct:")) {
        container.innerHTML = `
            <video controls autoplay 
                   style="width:100%; border-radius:8px; display:block;">
                <source src="${embed.replace('direct:', '')}" />
            </video>`;
    } else {
        container.innerHTML = `
            <div style="position:relative; padding-bottom:56.25%; height:0;">
                <iframe src="${embed}"
                        style="position:absolute; top:0; left:0; width:100%; height:100%; border:none; border-radius:8px;"
                        allow="autoplay; encrypted-media" allowfullscreen></iframe>
            </div>`;
    }

    document.getElementById('videoModal').style.display = 'flex';
    document.body.style.overflow = 'hidden';
    document.getElementById('elCountryPicker').style.zIndex = '1';
    var picker = document.getElementById('elCountryPicker');
    if (picker) picker.style.visibility = 'hidden';
}

function closeVideoModal() {
    document.getElementById('videoContainer').innerHTML = ''; // بيوقف الفيديو فوراً
    document.getElementById('videoModal').style.display = 'none';
    document.body.style.overflow = '';

    document.getElementById('elCountryPicker').style.zIndex = '100';
    var picker = document.getElementById('elCountryPicker');
    if (picker) picker.style.visibility = 'visible';
}

    // إغلاق لو ضغط برا الفيديو
    document.getElementById('videoModal').addEventListener('click', function (e) {
        if (e.target === this) closeVideoModal();
    });

    // إغلاق بـ Escape
    document.addEventListener('keydown', function (e) {
        if (e.key === 'Escape') closeVideoModal();
    });
</script>


