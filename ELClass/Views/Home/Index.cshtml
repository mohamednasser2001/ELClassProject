    <div id="CoursesSection" class="el-course-wrapper">
        <div class="container">
            <div class="el-course-heading text-center">
                <h4 class="el-top-heading-center">@(c?.CoursesTopHeading ?? (isArabic ? "فئات الدورات" : "COURSES Categories"))</h4>
                <h2 class="el-main-heading">@(c?.CoursesMainHeading ?? (isArabic ? "احصل على دعم تعليمي في جميع المواد" : "We Bring The Good Education To Life"))</h2>
                <p class="gray-p">
                    @(c?.CoursesParagraph ?? (isArabic
                        ? "مجموعة متنوعة من المواد الدراسية من الروضة حتى الجامعة"
                        : "Get latest news in your inbox. Consectetur adipiscing elitadipiscing elitse ddo eiusmod tempor incididunt ut labore et dolore."))
                </p>
            </div>

            <!-- Subjects Filter -->
            <style>
            .el-flt-bar{display:flex;flex-wrap:wrap;justify-content:center;gap:10px;margin-bottom:36px}
            .el-flt-btn{background:transparent;border:1.5px solid #dde3ef;color:#555;border-radius:50px;padding:8px 22px;font-size:14px;font-family:inherit;cursor:pointer;transition:all .25s;white-space:nowrap}
            .el-flt-btn:hover{border-color:#0053B3;color:#0053B3}
            .el-flt-btn.active{background:#0053B3;border-color:#0053B3;color:#fff}
            .el-sbj-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:24px;margin-top:8px}
            @@media(max-width:1199px){.el-sbj-grid{grid-template-columns:repeat(3,1fr)}}
            @@media(max-width:767px){.el-sbj-grid{grid-template-columns:repeat(2,1fr);gap:16px}}
            .el-sbj-card{background:#fff;border-radius:16px;padding:24px 18px 20px;text-align:center;box-shadow:0 4px 18px rgba(0,0,0,.07);transition:transform .25s,box-shadow .25s;display:flex;flex-direction:column;align-items:center;gap:12px}
            .el-sbj-card:hover{transform:translateY(-5px);box-shadow:0 10px 32px rgba(0,0,0,.13)}
            .el-sbj-card.el-sbj-hidden{display:none !important}
            .el-sbj-icon{width:72px;height:72px;border-radius:20px;display:flex;align-items:center;justify-content:center;font-size:32px;line-height:1;box-shadow:0 6px 20px rgba(0,0,0,.18)}
            .el-sbj-card h4{font-size:16px;font-weight:700;color:#1a2340;margin:0}
            .el-sbj-card p{font-size:13px;color:#777;margin:0;line-height:1.5}
            .el-sbj-card .el-orange-btn{margin-top:4px;font-size:12px;padding:6px 18px}
            @@keyframes elSbjIn{from{opacity:0;transform:scale(.95) translateY(8px)}to{opacity:1;transform:scale(1) translateY(0)}}
            .el-sbj-card{animation:elSbjIn .35s ease both}
            </style>

            <div class="el-flt-bar">
                <button class="el-flt-btn active" data-filter="all">@(isArabic ? "جميع المواد" : "All Courses")</button>
                <button class="el-flt-btn" data-filter="science">@(isArabic ? "العلوم" : "Science")</button>
                <button class="el-flt-btn" data-filter="math">@(isArabic ? "الرياضيات" : "Mathematics")</button>
                <button class="el-flt-btn" data-filter="languages">@(isArabic ? "اللغات" : "Languages")</button>
                <button class="el-flt-btn" data-filter="social">@(isArabic ? "الاجتماعيات" : "Social Studies")</button>
            </div>

            @{
                var subjects = new (string En, string Ar, string DescEn, string DescAr, string Cat, string Emoji, string Grad)[]
                {
                    ("Biology",          "أحياء",             "Learn biology with expert tutors",       "تعلم علم الأحياء مع مدرسين متخصصين",   "science",   "🧬", "linear-gradient(135deg,#0053B3,#1a7fe8)"),
                    ("Chemistry",        "كيمياء",            "Discover chemistry with our experts",    "اكتشف عالم الكيمياء مع خبرائنا",         "science",   "⚗️", "linear-gradient(135deg,#FF5722,#FF8A65)"),
                    ("Physics",          "فيزياء",            "Master physics concepts step by step",   "أتقن مفاهيم الفيزياء خطوة بخطوة",        "science",   "⚡", "linear-gradient(135deg,#00897B,#26C6DA)"),
                    ("Mathematics",      "رياضيات",           "Improve your math skills with ease",     "طور مهاراتك في الرياضيات بسهولة",        "math",      "📐", "linear-gradient(135deg,#7B1FA2,#CE93D8)"),
                    ("Algebra",          "جبر",               "Understand algebra from the ground up",  "افهم الجبر من الأساس",                   "math",      "✏️", "linear-gradient(135deg,#E91E63,#F48FB1)"),
                    ("Statistics",       "إحصاء",             "Analyze data and understand statistics", "حلل البيانات وافهم الإحصاء",              "math",      "📊", "linear-gradient(135deg,#0288D1,#4FC3F7)"),
                    ("Arabic Language",  "اللغة العربية",     "Strengthen your Arabic language skills", "قوّي مهاراتك في اللغة العربية",           "languages", "📖", "linear-gradient(135deg,#2E7D32,#66BB6A)"),
                    ("English Language", "اللغة الإنجليزية",  "Speak and write English confidently",    "تحدث واكتب الإنجليزية بثقة",             "languages", "🔤", "linear-gradient(135deg,#1565C0,#42A5F5)"),
                    ("French Language",  "اللغة الفرنسية",    "Learn French with native-level tutors",  "تعلم الفرنسية مع مدرسين متمرسين",        "languages", "🗣️", "linear-gradient(135deg,#C62828,#EF9A9A)"),
                    ("History",          "تاريخ",             "Explore world and regional history",     "استكشف التاريخ العالمي والمحلي",           "social",    "🏛️", "linear-gradient(135deg,#F57F17,#FFCA28)"),
                    ("Geography",        "جغرافيا",           "Understand our world's geography",       "افهم جغرافية عالمنا",                    "social",    "🌍", "linear-gradient(135deg,#4E342E,#A1887F)"),
                    ("Islamic Studies",  "تربية إسلامية",     "Deepen your Islamic knowledge",          "عمّق معرفتك بالتربية الإسلامية",          "social",    "☪️", "linear-gradient(135deg,#00695C,#4DB6AC)"),
                };
            }
            <div class="el-sbj-grid" id="elSbjGrid">
                @foreach (var s in subjects)
                {
                    <div class="el-sbj-card" data-cat="@s.Cat">
                        <div class="el-sbj-icon" style="background:@s.Grad">@s.Emoji</div>
                        <h4>@(isArabic ? s.Ar : s.En)</h4>
                        <p>@(isArabic ? s.DescAr : s.DescEn)</p>
                        <a href="#ContactUsSection" class="el-orange-btn">@(isArabic ? "احجز الآن" : "Enroll Now")</a>
                    </div>
                }
            </div>

            <script>
            (function(){
                var btns = document.querySelectorAll('.el-flt-btn');
                var cards = document.querySelectorAll('#elSbjGrid .el-sbj-card');
                btns.forEach(function(btn){
                    btn.addEventListener('click', function(){
                        btns.forEach(function(b){ b.classList.remove('active'); });
                        btn.classList.add('active');
                        var f = btn.getAttribute('data-filter');
                        cards.forEach(function(c){
                            c.classList.toggle('el-sbj-hidden', f !== 'all' && c.getAttribute('data-cat') !== f);
                        });
                    });
                });
            })();
            </script>
        </div>
    </div>
